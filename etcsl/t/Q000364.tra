}  @q[Gilgamec,Enkidu]{“Did you see the leprous man?”} @q[Enkidu,Gilgamec]{“He twitches like an ox as the worms eat at him.”} @q[Gilgamec,Enkidu]{“Did you see him who fell in battle?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“His father and mother are not there to hold his head, and his wife weeps.”} @q[Gilgamec,Enkidu]{“Did you see the spirit of him who has no funerary offerings?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“He eats the scraps and the crumbs …… tossed out in the street.”} @q[Gilgamec,Enkidu]{“Did you see him hit by a ship's board 
{@noteanchor{1 ms. adds:} when diving (?)
} ? How does he fare?”} @q[Enkidu,Gilgamec]{“@q{“Alas, my mother!”} the man cries to her, as he pulls out the ship's board ……, he …… cross beam …… crumbs.”} @q[Gilgamec,Enkidu]{“Did you see my little stillborn children who never knew existence?”} @q[Enkidu,Gilgamec]{“I saw them.”} @q[Gilgamec,Enkidu]{“How do they fare?”} @q[Enkidu,Gilgamec]{“They play at a table of gold and silver, laden with honey and ghee.”} @q[Gilgamec,Enkidu]{“Did you see him who died ……?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“He lies on a bed of the gods.”} @q[Gilgamec,Enkidu]{“Did you see him who was set on fire?”} @q[Enkidu,Gilgamec]{“I did not see him. His spirit is not about. His smoke went up to the sky.”}



@h A version from Urim (UET 6 58)

@(2.1 = 1-7) @q[Gilgamec,Enkidu]{“Did you see him who fell down from the roof?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“They cannot …… his bones.”} @q[Gilgamec,Enkidu]{“Did you see him who was struck in (?) a flood-storm of (?) @wDN{Iškur}?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“He twitches like an ox as the worms eat at him.”} @q[Gilgamec,Enkidu]{“Did you see the leprous man?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“His food is set apart, his water is set apart, he eats the food offered (?) to him, he drinks the water offered (?) to him. He lives outside the city.”}

@(2.8 = 8-19) @q[Gilgamec,Enkidu]{“Did you see him who had no respect for the word of his mother and father?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“@q{“O my body! O my limbs!”} he never ceases to cry.”} @q[Gilgamec,Enkidu]{“Did you see him who was reached by the curse of his mother and father?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“He is deprived of an heir. His spirit roams about.”} @q[Gilgamec,Enkidu]{“Did you see him who …… the name of his god?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“His spirit …….”} @q[Gilgamec,Enkidu]{“Did you see the spirit of him who has no funerary offerings?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“He eats the scraps and the crumbs …… tossed out in the street.”} @q[Gilgamec,Enkidu]{“Did you see my little stillborn children who never knew existence?”}@q[Enkidu,Gilgamec]{“I saw them.”} @q[Gilgamec,Enkidu]{“How do they fare?”} @q[Enkidu,Gilgamec]{“They play at a table of gold and silver, laden with honey and ghee.”} @q[Gilgamec,Enkidu]{“Did you see him who was set on fire?”} @q[Enkidu,Gilgamec]{“I did not see him. His smoke went up to the sky. His spirit does not live in the underworld.”}

@(2.20 = 20-28) @q[Gilgamec,Enkidu]{“Did you see him who lied to the gods while swearing an oath?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“He drinks …… which has been drunk …… the libation place at the entrance (?) to the nether world.”} @q[Gilgamec,Enkidu]{“Did you see the citizen of @wSN{Ŋirsu} who refused (?) water to his father and his mother?”} @q[Enkidu,Gilgamec]{“I saw him.”} @q[Gilgamec,Enkidu]{“How does he fare?”} @q[Enkidu,Gilgamec]{“In front of each of them are a thousand @wEN{Martu}, and his spirit can neither …… nor ……. The @wEN{Martu} at the libation place at the entrance (?) to the nether world …….”} @q[Gilgamec,Enkidu]{“Did you see the citizens of @wGN{Sumer} and @wGN{Akkad}?”} @q[Enkidu,Gilgamec]{“I saw them.”} @q[Gilgamec,Enkidu]{“How do they fare?”} @q[Enkidu,Gilgamec]{“They drink the water of the …… place, muddy water.”} @q[Gilgamec,Enkidu]{“Did you see where my father and my mother live?”} @q[Enkidu,Gilgamec]{“I saw them.”} @q[Gilgamec,Enkidu]{“How do they fare?”} @q[Enkidu,Gilgamec]{“Both of them drink the water of the …… place, muddy water.”}



@h Another version from Urim (UET 6 59)


@(3.A.1 = 1-9) @q[Gilgamec,Enkidu]{“Did you see him hit by a ship's board? How does he fare?”} @q[Enkidu,Gilgamec]{“@q{“Alas, my mother!”} the man cries to her, as he pulls out ……, he …… crossbeam …… crumbs.”} @q[Gilgamec,Enkidu]{“Did you see him who fell down from the roof? How does he fare?”} @q[Enkidu,Gilgamec]{“He twitches like an ox as the worms eat at him.”} @q[Gilgamec,Enkidu]{“Did you see him who was reached by the curse of his mother? How does he fare?”} @q[Enkidu,Gilgamec]{“He is deprived of an heir. His spirit roams (?) about.”} @q[Gilgamec,Enkidu]{“Did you see him who had no respect for the word of his father and his mother? How does he fare?”}

