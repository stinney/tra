@(5.B.29 = 29-51) @q[Gilgamec,Enkidu]{“Did you see him ……? How does he fare?”} @q[Enkidu,Gilgamec]{“He drinks water …….”} @q[Gilgamec,Enkidu]{“Did you see him ……? How does he fare?”} @q[Enkidu,Gilgamec]{“He …… as the worms eat at him.”} @q[Gilgamec,Enkidu]{“Did you see him who was eaten by a dog? How does he fare?”} @q[Enkidu,Gilgamec]{“He …… @q{“O my hands! O my legs! O ……!”}”} @q[Gilgamec,Enkidu]{“Did you see him hit (?) by the mast of a boat? How does he fare?”} @q[Enkidu,Gilgamec]{“@q{“Alas, my mother”} the man cries to her, …… wooden peg ……, he …… food, cross beam (?), crumbs …….”} @q[Gilgamec,Enkidu]{“Did you see the woman who never gave birth? How does she fare?”} @q[Enkidu,Gilgamec]{“Like a …… pot, she is thrown away violently, she …… nobody.”} @q[Gilgamec,Enkidu]{“Did you see the young man who never undressed his wife? How does he fare?”} @q[Enkidu,Gilgamec]{“You finish a reed mat and he weeps over the reed mat.”} @q[Gilgamec,Enkidu]{“Did you see the young woman who never undressed her husband? How does she fare?”} @q[Enkidu,Gilgamec]{“You finish a …… garment and she weeps over the …… garment.”}

@(5.B.52 = 52-68) @q[Gilgamec,Enkidu]{“Did you see him who …… extolled himself? How does he fare?”} @q[Enkidu,Gilgamec]{“He bows down (?) like an ox as the worms eat at him.”} @q[Gilgamec,Enkidu]{“Did you see him who fell down from the roof? How does he fare?”} @q[Enkidu,Gilgamec]{“His bones …… and his spirit …….”} @q[Gilgamec,Enkidu]{“Did you see ……? How does he fare?”} @q[Enkidu,Gilgamec]{“He …….”} @q[Gilgamec,Enkidu]{“Did you see the leprous man? How does he fare?”} @q[Enkidu,Gilgamec]{“His water is set apart, his food is set apart. He …… the spirits. He lives outside the city.”} @q[Gilgamec,Enkidu]{“Did you see my stillborn children who never received a name? How do they fare?”} @q[Enkidu,Gilgamec]{“They play at a table of gold and silver …….”} @q[Gilgamec,Enkidu]{“Didn't you see him who was set on fire?”} @q[Enkidu,Gilgamec]{“Why, my friend, did not you spare this question?”} @q[Gilgamec,Enkidu]{“I asked it, my friend!”} @q[Enkidu,Gilgamec]{“His spirit is …… from the nether world, it went up to the sky with the smoke (?).”}

@(5.B.69 = 69-71) His heart was smitten, his insides were ravaged. The king began to search for life. Now the lord once decided to set off for the mountain where the man lives. @noteref{These three lines create a transition to 1.8.1.5 Gilgameš and Ḫuwawa (Version A).}

