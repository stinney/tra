#lg G	kirugu


@(G.136 = 136-143) @q[Ningal,]{“On that day, when such a storm had pounded, when in the presence of the queen her city had been destroyed, on that day, when such a storm had been created, when they had pronounced the utter destruction of my city, when they had pronounced the utter destruction of @wSN{Urim}, when they had directed that its people be killed, on that day I did not abandon my city, I did not forsake my land.”}

@(G.144 = 144-150) @q{“Truly I shed my tears before @wDN{An}. Truly I myself made supplication to @wDN{Enlil}. @q[Ningal,An Enlil]{“Let not my city be destroyed,”} I implored them. @q[Ningal,An Enlil]{“Let not @wSN{Urim} be destroyed,”} I implored them. @q[Ningal,An Enlil]{“Let not its people perish,”} I implored them. But @wDN{An} did not change that word. @wDN{Enlil} did not soothe my heart with an @q[Enlil,]{“It is good -- so be it”}.”}

@(G.151 = 151-160) @q{“A second time, when the council had settled itself in the pre-eminent place, and the @wDN{Anuna} had seated themselves to ratify decisions, I prostrated (?) myself and stretched out my arms. Truly I shed my tears before @wDN{An}. Truly I myself made supplication to @wDN{Enlil}. @q[Ningal,An Enlil]{“Let not my city be destroyed,”} I implored them. @q[Ningal,An Enlil]{“Let not @wSN{Urim} be destroyed,”} I implored them. @q[Ningal,An Enlil]{“Let not its people perish,”} I implored them. But @wDN{An} did not change that word. @wDN{Enlil} did not soothe my heart with an @q[Enlil,]{“It is good -- so be it”}.”}

@(G.161 = 161-168) @q{“They gave instructions that my city should be utterly destroyed. They gave instructions that @wSN{Urim} should be utterly destroyed. They decreed its destiny that its people should be killed. In return for the speech (?) which I had given them, they both bound me together with my city and also bound my @wSN{Urim} together with me. @wDN{An} is not one to change his command, and @wDN{Enlil} does not alter what he has uttered.”}

