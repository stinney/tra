






@(1-3=c565.1) There were three friends, citizens of @wSN{Adab}, who fell into a dispute with each other, and sought justice. They deliberated the matter with many words, and went before the king.

@(4-13=c565.4) @q[three ox-drivers,king]{“Our king! We are ox-drivers. The ox belongs to one man, the cow belongs to one man, and the waggon belongs to one man. We became thirsty and had no water. We said to the owner of the ox, @q[two ox-drivers,owner of the ox]{“If you were to fetch some water, then we could drink!”}. And he said, @q[owner of the ox,two ox-driver]{“What if my ox is devoured by a lion? I will not leave my ox!”}. We said to the owner of the cow, @q[two ox-drivers,owner of the cow]{“If you were to fetch some water, then we could drink!”}. And he said, @q[owner of the cow,two ox-drivers]{“What if my cow went off into the desert? I will not leave my cow!”}. We said to the owner of the waggon, @q[two ox-drivers,owner of the waggon]{“If you were to fetch some water, then we could drink!”}. And he said, @q[owner of the waggon,two ox-drivers]{“What if the load were removed from my waggon? I will not leave my waggon!”}. @q[three ox-drivers,self]{“Come on, let's all go! Come on, and let's return together!”}”}

@(14-15=c565.14) @q{“First the ox, although tied with a leash (?), mounted the cow, and then she dropped her young, and the calf started to chew up (?) the waggon's load. Who does this calf belong to? Who can take the calf?”}

@(16-17=c565.16) The king did not give them an answer, but went to visit a cloistered lady. The king sought advice from the cloistered lady:


@(18-28=c565.18) @q[king,cloistered lady]{“Three young men came before me and said: @q[three ox-drivers,king]{“Our king, we are ox-drivers. The ox belongs to one man, the cow belongs to one man, and the waggon belongs to one man. We became thirsty and had no water. We said to the owner of the ox, @q[two ox-drivers,owner of the ox]{“If you were to draw some water, then we could drink!”}. And he said, @q[owner of the ox,two ox-drivers]{“What if my ox is devoured by a lion? I will not leave my ox!”}. We said to the owner of the cow, @q[two ox-drivers,owner of the cow]{“If you were to draw some water, then we could drink!”}. And he said, @q[owner of the cow,two ox-drivers]{“What if my cow went off into the desert? I will not leave my cow!”}. We said to the owner of the waggon, @q[two ox-drivers,owner of the waggon]{“If you were to draw some water, then we could drink!”}. And he said, @q[owner of the waggon,two ox-drivers]{“What if the load were removed from my waggon? I will not leave my waggon!”} he said. @q[three ox-drivers,self]{“Come on, let's all go! Come on, and let's return together!”}”}”}

@(29-30=c565.29) @q{“@q{“First the ox, although tied with a leash (?), mounted the cow, and then she dropped her young, and the calf started to chew up (?) the waggon's load. Who does this calf belong to? Who can take the calf?”}”}

