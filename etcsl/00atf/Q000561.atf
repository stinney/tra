#atf: use unicode
#atf: use math
#etcsl: text-id=c.3.1.21
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.3.1.21&display=Crit&charenc=gcirc#

1. lugal-ŋu₁₀-ra u₃-na-dug₄
#lem: lugal[king]; dug[speak]
#etcsl: line-id=1

2. maš₂ hur-saŋ-ŋa₂ a₂ sag₉-sag₉-ŋu₁₀
#lem: maš[goat]; hursaŋ[mountain]; a[arm]; sag[good]
#etcsl: line-id=2

3. anše-kur hur-saŋ-ŋa₂ umbin hu-ri₂-in{mušen}-na
#lem: sisi[horse]; hursaŋ[mountain]; umbin[finger]; hurin[eagle]
#etcsl: line-id=3

4. {ŋiš}ŋišnimbar ki sikil-e mu₂-a zu₂-lum {na₄}za-gin₃ la₂-ŋu₁₀-ur₂
#lem: ŋešnimbar[date-palm]; ki[place]; sikil[pure]; mu[grow]; zulum[the fruit of the date-palm]; zagin[lapis lazuli]; la[hang]
#etcsl: line-id=4

5. u₃-ne-de₃-tah
#lem: tah[add]
#etcsl: line-id=5

6. {m}a-ba-in-da-sa₂ ugula (1:erin₂:1) zu₂ keše₂
#lem: Abaindasa[1]PN; ugula[overseer]; erin[people]; zu[tooth]; kešed[bind]
#etcsl: line-id=6

:6v.1.1: (#note: 2 mss. have instead:#) aga-us₂
#lem: agaʾus[professional soldier]

7. šuduₓ(|KA.ŠU|){ud} lugal-la-na-ta šag₄ lugal-la-na dug₃-dug₃-ge-ra
#lem: šud[prayer]; lugal[king]; šag[heart]; lugal[king]; dug[good]
#etcsl: line-id=7

8. arad₂-zu na-ab-be₂-a
#lem: arad[slave]; e[speak]
#etcsl: line-id=8

9. kalag-ga-me-en (1:lugal-ŋu₁₀ ga-ab-us₂:1)
#lem: kalag[strong]; lugal[king]; us[accompany]
#etcsl: line-id=9

:9v.1.1: (#note: 1 ms. has instead:#) aga-us₂-zu he₂-me-en
#lem: agaʾus[professional soldier]; me[be]

10. (1:inim-ma-zu ra-gaba-zu he₂-me-en:1)
#lem: inim[word]; ragaba[rider]; me[be]
#etcsl: line-id=10

:10v.1.1: (#note: 1 ms. has instead:#) igi tuku igi-ni-še₃ ga-gub
#lem: igi[eye]; tuku[acquire]; igi[eye]; gub[stand]

11. {ŋiš}ma₂ gub-ba {ŋiš}ŋisal mu-un-sig₁₀-ge
#lem: ma[ship]; gub[stand]; ŋisal[rudder]; sig[put into]
#etcsl: line-id=11

12. (1:a gub-ba:1) a mu-un-da-ak-e
#lem: a[water]; gub[stand]; a[water]; ak[do]
#etcsl: line-id=12

:12v.1.1: (#note: 1 ms. has instead:#) a-a gub-ba
#lem: aya[father]; gub[stand]

@variants

@variants

#note: 2 mss. add 1 line:
12A. dumu gub#-ba še mu-un-sig₁₀-ge
#lem: dumu[child]; gub[stand]; še[barley]; sig[put into]
#etcsl: line-id=12A

