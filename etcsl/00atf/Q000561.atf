#note: 1 ms. adds instead the line:
12B. [...] X X mu-un-zalag-ge
#lem: X; X; X; zalag[bright]
#etcsl: line-id=12B

@endvariants
@endvariants
13. tum₉ gub-ba (1:še mu-un-da-la₂-e:1)
#lem: tumu[wind]; gub[stand]; še[barley]; la[hang]
#etcsl: line-id=13

:13v.1.1: (#note: 1 ms. has instead:#) IM mu-da-ak-e
#lem: X; ak[do]

14. dub-sar-me-en na-du₃-a ab-sar-re-en
#lem: dubsar[scribe]; narua[stele]; sar[write]
#etcsl: line-id=14

@variants

#note: 2 mss. add 1 line:
14A. inim ugnim-ma mu#-[...]
#lem: inim[word]; ugnim[army]; X
#etcsl: line-id=14A

@endvariants
15. inim pu-uh₂-ru-um-ma šub-ba ed₃-de₃!-bi mu-un-da-sig₁₀-ge
#lem: inim[word]; puhrum[assembly]; šub[fall]; ed[go up]; sig[put into]
#etcsl: line-id=15

@variants

#note: 1 ms. adds 1 line:
15A. inim sag₉-ge gaba-ri X [...]
#lem: inim[word]; sag[good]; gabari[equal]; X; X
#etcsl: line-id=15A

@endvariants
16. ŋiš-gin₇ {ŋiš}tir-ŋa₂ mu-un-du₃-nam mu-dur₇-re im-gam-e
#lem: ŋeš[tree]; tir[forest]; du[build]; mudur[dirt]; gurum[bend]
#etcsl: line-id=16

17. {ŋiš}gu-za-ŋa₂ lu₂ mu-un-da-la₂-a šu-ŋu₁₀ eš₂ im-ma-an-la₂
#lem: guza[chair]; lu[person]; la[hang]; šu[hand]; eš[rope]; la[hang]
#etcsl: line-id=17

18. iri-ŋa₂ tug₂! dan₆-na-a mu-ni-mur₁₀-ra tug₂-mu-dur₇-ra ba-an-mur₁₀
#lem: iri[city]; tug[textile]; dan[pure]; mur[dress]; tugmudura[mourning garment]; mur[dress]
#etcsl: line-id=18

19. lag-e a mi-ni-in-tu₅-a sahar igi-ŋa₂ ba-e-DU
#lem: lag[clod (of earth)]; a[water]; tu[cvve]; sahar[soil]; igi[eye]; X
#etcsl: line-id=19

20. ur-e ad₆ ib₂-gu₇ gaba-bi ib₂-zi-zi
#lem: ur[dog]; adda[corpse]; gu[eat]; gaba[breast]; zig[rise]
#etcsl: line-id=20

21. ušumgal-e saŋ ŋiš ib₂-ra-ra ka-ta ab-taka₄ i₃-ib₂-taka₄
#lem: ušumgal[great dragon]; saŋ[head]; ŋeš[tree]; rah[beat]; kag[mouth]; taka[set aside]; taka[set aside]
#etcsl: line-id=21

22. ŋiš-gi izi ib₂-gu₇ id₂ i₃-tuku-tuku
#lem: ŋešgi[thicket]; izi[fire]; gu[eat]; id[river]; tuku[acquire]
#etcsl: line-id=22

23. {d}utu i₃ un-gu₇ ga un-gu₇ {ŋiš}banšur ukur₃-ra-še₃ šu-ni ib₂-ši-tum₃
#lem: Utu[1]DN; i[oil]; gu[eat]; ga[milk]; gu[eat]; banšur[table]; ukur[poor]; šu[hand]; tum[bring]
#etcsl: line-id=23

@variants

#note: 1 ms. adds 2 lines:
23A. zi-ŋu₁₀ ba-e-i! šu-ŋu₁₀ ha-za-a-ab
#lem: zi[life]; e[bring out]; šu[hand]; haza[hold]
#etcsl: line-id=23A

23B. dumu nu-mu-un-su-me-en lu₂ en₃ tar-re la-ba-an-tuku
#lem: dumu[child]; numunkuš[widow]; lu[person]; en[cvne]; tar[cut]; tuku[acquire]
#etcsl: line-id=23B

@endvariants
24. ŋa₂-a me-na-am₃ šag₄ {d}šul-gi lugal-ŋa₂ ki-bi ha-ma-gi₄-gi₄
#lem: ŋaʾe[I]; mena[when?]; šag[heart]; Šulgir[1]RN; lugal[king]; ki[place]; gi[turn]
#etcsl: line-id=24

@variants

#note: 1 ms. adds 1 line:
24A. lugal-ŋu₁₀ en₃-ŋu₁₀ he₂-tar-re ki ama-ŋu₁₀-še₃ he₂-em-mi-ib-gi₄-gi₄
#lem: lugal[king]; en[cvne]; tar[cut]; ki[place]; ama[mother]; gi[turn]
#etcsl: line-id=24A

@endvariants





