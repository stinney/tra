16. nu-kug-gin₇ (1:mu-un-TI GAR-e nu-tar!-[re]:1)
#lem: kug[pure]; X; X; tar[cut]
#etcsl: line-id=B.23.8.16

:16v.1.1: (#note: 1 ms. has instead:#) mu-un-ni-šub en₃-na nu-tar#-re
#lem: šub[fall]; en[cvne]; tar[cut]

17. tug₂-gin₇ i₃-mu₄-mu₄
#lem: tug[textile]; mur[dress]
#etcsl: line-id=B.23.8.17

18. nam-tag dugud un-ŋar-ra
#lem: namtaga[sin]; dugud[heavy]; ŋar[put]
#etcsl: line-id=B.23.8.18

19. (1:a-ba mu-ni lu₂ dam lu₂-kam ba-nu₂!:1)
#lem: aba[who?]; mu[name]; lu[person]; dam[spouse]; lu[person]; nud[lie down]
#etcsl: line-id=B.23.8.19

:19v.1.1: (#note: 1 ms. has instead:#) a-ba-am₃ e-ne lu₂ dam lu₂-ka in-da-nu₂#-a
#lem: aba[who?]; ane[he]; lu[person]; dam[spouse]; lu[person]; nud[lie down]

@end proverb

@div proverb 23.9

