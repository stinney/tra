&Q000799 = Proverbs: collection 5
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.6.1.05
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.6.1.05&display=Crit&charenc=gcirc#

@div segment A

@div proverb 5.1

@variants

A.5.1.1. am-si ni₂-te#-a-ni maš₂#-[anše] {[d]}[šakkan₂-ka]
#lem: amsi[elephant]; ni[self]; mašanše[animals]; Šakkan[1]DN
#etcsl: line-id=A.5.1.1

A.5.1.2. niŋ₂ ŋe₂₆-gin₇-nam nu-ŋal₂ na-[ab-be₂-a]
#lem: niŋ[thing]; ŋaʾe[I]; ŋal[⟦be⟧ to be (there]; e[speak]
#etcsl: line-id=A.5.1.2

A.5.1.3. an-ti-ri₂-gu₇{mušen}-e mu-na#-[ni-ib-gi₄-gi₄]
#lem: altirigu[wren]; gi[turn]
#etcsl: line-id=A.5.1.3

A.5.1.4. u₃ ŋe₂₆-e igi-te-en-ŋu₁₀-še₃
#lem: u[and]; ŋaʾe[I]; igiten[fraction (math.)]
#etcsl: line-id=A.5.1.4

A.5.1.E. za-a-gin₇-nam al-dim₂-me-en-e-še#
#lem: zaʾe[you]; dim[create]
#etcsl: line-id=A.5.1.5

@variant

#note: instead of lines 1-5, 1 ms. has:
A. am-si ni₂-ta-na maš₂-anše {d}šakkan₂-ka {{%akk um-ma %akk pi-ru-um %akk i-na %akk ra-ma-ni-ša %akk i-na %akk bu-ul %akk ša-am-ka-an}}
#lem: amsi[elephant]; ni[self]; mašanše[animals]; Šakkan[1]DN; L; L; L; L; L; L; L
#etcsl: line-id=A.5.1.A

B. niŋ₂ ŋe₂₆-gen₆-na-am al-di-me-en nu-ŋal₂ na-ab-be₂-a {{%akk ša %akk ki-ma %akk ia-ti-ma %akk zu-u₂ %akk u₂-ul %akk i-ba-ši}}
#lem: niŋ[thing]; ŋaʾe[I]; dim[create]; ŋal[⟦be⟧ to be (there]; e[speak]; L; L; L; L; L; L
#etcsl: line-id=A.5.1.B

Š. al-ti-ri₂-gu mu-na-ni-ib-gi₄-gi₄ {{%akk si-pi-di-qa₂-ar %akk i-ip-pa-al}}
#lem: altirigu[wren]; gi[turn]; L; L
#etcsl: line-id=A.5.1.C

D. u₃ ŋe₂₆-e i-gi₄-ten-ŋu₁₀-uš {{%akk u₃ %akk a-na-ku %akk ki-ma %akk ka-a-ti}}
#lem: u[and]; ŋaʾe[I]; igiten[fraction (math.)]; L; L; L; L
#etcsl: line-id=A.5.1.D

E. za-a-gen₆-nam al-di-me-en-e-še {{%akk a-na %akk ma-na-ti-ia-ma %akk ze₂-a-ku}}
#lem: zaʾe[you]; dim[create]; L; L; L
#etcsl: line-id=A.5.1.E

@endvariants
@end proverb

@div proverb 5.2

A.5.2.6. (1:am-si-gin₇ ma₂ su-a ed₃-de₃-de₃ im-du-de₃-en:1)
