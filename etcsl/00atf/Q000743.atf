&Q000743 = A hymn to Utu (Utu B)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.4.32.2
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.4.32.2&display=Crit&charenc=gcirc#

1. [...] sig-še₃ ed₂-de₃ nim-še₃ igi bar-[re]-de₃
#lem: X; sig[weak]; e[leave]; nim[high]; igi[eye]; bar[place outside]
#etcsl: line-id=1

2. {d}utu a-zu gal# [a]-a saŋ gig₂-ga
#lem: Utu[1]DN; azu[doctor]; gal[big]; aya[father]; saŋ[head]; giggig[black]
#etcsl: line-id=2

3. sun₄ {na₄}za-gin₃# la₂ e₂-babbar-ra
#lem: sum[beard]; zagin[lapis lazuli]; la[hang]; Ebabbara[1]
#etcsl: line-id=3

4. {d}utu ur#-[saŋ] gal# lipiš unken-na
#lem: Utu[1]DN; ursaŋ[warrior]; gal[big]; lipiš[inner body]; unkin[assembly]
#etcsl: line-id=4

5. lugal gud-alim# kur#-[ra dub₃] ba₉-re₆
#lem: lugal[king]; alim[bison]; kur[mountain(s)]; dub[knee]; bad[open]
#etcsl: line-id=5

6. {d}utu gud-alim kur-ra dub₃ ba₉-re₆
#lem: Utu[1]DN; alim[bison]; kur[mountain(s)]; dub[knee]; bad[open]
#etcsl: line-id=6

7. šilam ban₃-da UŠ# nu-ed₃-de₃
#lem: šilam[cow]; banda[junior]; X; ed[go up]
#etcsl: line-id=7

8. u₃-ba-zu ban₃-da ŋiš-bur₂!# dab₅-ba
#lem: ubazu[an animal]; banda[junior]; ŋešpar[trap]; dab[seize]
#etcsl: line-id=8

9. {d}utu iri-da e₂-nun-an-na dumu {d}nin-gal-e tud-da
#lem: Utu[1]DN; iri[city]; Enunanak[1]TN; dumu[child]; Ningal[1]DN; utud[give birth (to)]
#etcsl: line-id=9

10. gud {ŋiš}erin a naŋ-a ha-[šu]-ur₂-ra# peš#-a
#lem: gud[bull]; eren[cedar]; a[water]; naŋ[drink]; hašur[tree]; peš[thick]
#etcsl: line-id=10

11. gi-rin šag₄ su₃-ra₂ e-ne dug₄-dug₄#
#lem: girim[flower]; šag[heart]; sud[distant]; ene[pleasure?]; dug[speak]
#etcsl: line-id=11

12. su₃-ra₂-aŋ₂ e₃-a su-lim-ma gun₃-am₃#
#lem: sudaŋ[precious metal or material (possibly amber)]; e[leave]; sulim[awesome radiance]; gunu[speckled]
#etcsl: line-id=12

13. ud-ba lugal-ŋu₁₀ ed₂-da-ni-ne
#lem: ud[sun]; lugal[king]; e[leave]
#etcsl: line-id=13

14. an mu-un#-da-dub₂#-dub₂ ki mu-un-da-sag₃#-[sag₃]
#lem: an[sky]; dub[tremble]; ki[place]; sag[strike]
#etcsl: line-id=14

15. KA mu-[un]-bal [e₂]-gal-la ed₂-da-ni-ta
#lem: X; bala[turn]; egal[palace]; e[leave]
#etcsl: line-id=15

16. an mu-un#-[...]
