#lem: Utu[1]DN; X; X; saŋ[head]; ŋal[⟦be⟧ to be (there]
#etcsl: line-id=26

27. en dumu {d}nin-gal-la KA DI# 50 šu-ni šu-mu-un-ŋal₂
#lem: en[lord]; dumu[child]; Ningal[1]DN; X; X; n; šu[hand]; ŋal[⟦be⟧ to be (there]
#etcsl: line-id=27

28. ud-gin₇ kur-ra gu₃ mu#-[ni]-ib-be₂
#lem: ud[storm]; kur[mountain(s)]; gu[voice]; e[speak]
#etcsl: line-id=28

29. kalam-ma saŋ [mi-ni]-in-il₂
#lem: kalam[the Land (of Sumer)]; saŋ[head]; il[raise]
#etcsl: line-id=29

30. hu-ri₂-in{mušen}-gin₇ kur# šuba₄ kur šuba₄{ba}
