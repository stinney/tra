#etcsl: line-id=16

17. {ŋiš}si-ŋar# [an-na-ke₄ ... ...] hu-[mu]-da-gi₄-gi₄#
#lem: siŋar[bolt]; an[sky]; X; X; gi[turn]
#etcsl: line-id=17

18. mul#-e! X X-da-ke₄ ur₄-ur₄-[...]
