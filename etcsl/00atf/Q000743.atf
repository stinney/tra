#lem: en[lord]; galanzu[wise]; ešbar[decision]; dumu[child]; Enlil[1]DN
#etcsl: line-id=24

25. {d}utu gal-zu mah dumu {d}nin#-[...]-la₂-ke₄
#lem: Utu[1]DN; galanzu[wise]; mah[great]; dumu[child]; u
#etcsl: line-id=25

