#etcsl: line-id=31

32. {e₂}tur₃-e i₃ ga he₂-en-da-ab-be₂
#lem: tur[animal stall]; i[oil]; ga[milk]; e[speak]
#etcsl: line-id=32

33. amaš#-e giri₁₇-zal-la he₂-en-da-ab-be₂
#lem: amaš[sheepfold]; kirizal[joy]; e[speak]
#etcsl: line-id=33

34. sipad# zid-dam ud-da-ni# he₂-su₃-ud
