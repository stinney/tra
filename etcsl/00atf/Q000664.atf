1. ab₂ gu₃ <dug₃>-ga amar gu₃ su₃-ra
#lem: ab[cow]; gu[voice]; dug[good]; amar[calf]; gu[voice]; sud[distant]
#etcsl: line-id=1

2. in-nin₉ {e₂}tur₃-ra niŋ₂-niŋin₂-na-me-en
#lem: innin[lady]; tur[animal stall]; niŋin[encircle]
#etcsl: line-id=2

3. {lu₂}ki-sikil nu-um-ši!-dun₅-na-am₃
#lem: kisikil[young woman]; dun[rock]
#etcsl: line-id=3

4. {d}inana {dug}šakir₃-e gu₃ he₂-em-me
#lem: Inanak[1]DN; šakir[churn]; gu[voice]; e[speak]
#etcsl: line-id=4

5. {dug}šakir₃ nitalam₂-zu# gu₃ he₂-em-me
#lem: šakir[churn]; ŋidlam[(equal ranking) spouse]; gu[voice]; e[speak]
#etcsl: line-id=5

6. {dug}šakir₃ {d}dumu-zid-da# gu₃ he₂-em-me
#lem: šakir[churn]; Dumuzid[1]DN; gu[voice]; e[speak]
#etcsl: line-id=6

7. {d}inana {dug}šakir₃-e gu₃# he₂-em-me
#lem: Inanak[1]DN; šakir[churn]; gu[voice]; e[speak]
#etcsl: line-id=7

8. {dug}šakir₃ {d}dumu-zid-[...] gu₃ he₂-em-me
#lem: šakir[churn]; Dumuzid[1]DN; gu[voice]; e[speak]
#etcsl: line-id=8

9. dun₅-ru {dug}šakir₃-ra ša#-mu-ra-an-du₁₂-am₃
#lem: dun[rock]; šakir[churn]; du[play (a musical instrument)]
#etcsl: line-id=9

10. {d}inana ur₅-re ša#-mu-u₈-hul₂-le#
#lem: Inanak[1]DN; ur[that]; hul[rejoice]
#etcsl: line-id=10

11. {dug}šakir₃ kug-ge gu₃ X ša-mu-ra!(NA)-[ab-be₂]
#lem: šakir[churn]; kug[pure]; gu[voice]; X; dug[speak]
#etcsl: line-id=11

12. {d}nin-e₂-gal ur₅-re ša#-mu-u₈-hul₂-[le]
#lem: Ninegalak[1]DN; ur[that]; hul[rejoice]
#etcsl: line-id=12

13. sipad zid lu₂ i-lu dug₃-ga-[ke₄]
#lem: sipad[shepherd]; zid[right]; lu[person]; ilu[lament]; dug[good]
#etcsl: line-id=13

14. mur ša₄-am₃ i-lu ša-mu-ra-an-ib#-[be₂]
#lem: mur[noise]; ša[cvve]; ilu[lament]; e[speak]
#etcsl: line-id=14

15. in-nin i-lu# niŋ₂ ku₇-ku₇#-[da]
#lem: innin[lady]; ilu[lament]; niŋ[thing]; kud[sweet]
#etcsl: line-id=15

16. {d}inana šag₄-zu# he₂-em-hul₂#-[le]
#lem: Inanak[1]DN; šag[heart]; hul[rejoice]
#etcsl: line-id=16

17. in-nin {e₂}tur₃-ra kur₉-[ra]-zu-ne#
