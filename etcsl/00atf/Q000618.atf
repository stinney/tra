&Q000618 = A šir-šag-ḫula to Damgalnuna (Damgalnuna A)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.4.03.1
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.4.03.1&display=Crit&charenc=gcirc#

@div segment A

$ (unknown no. of lines missing)
1. nun# gal {d}en-ki [...] an ki NE [...] mi₂ mu-ri₂-in-[dug₄]
#lem: nun[prince]; gal[big]; Enkik[1]DN; X; an[sky]; ki[place]; X; X; mi[cvne]; dug[speak]
#etcsl: line-id=A.1

2. e₂-gi₄-a %e {d}am-an-ki %s nam zid-de₃-eš tar-re
#lem: egia[bride]; Amanki[]DN; nam[fate]; zid[right]; tar[cut]
#etcsl: line-id=A.2

3. sumun₂ gal ulutim₂-bi dirig-ga niŋ₂-ul!-e-eš rib-ba
#lem: sumun[wild cow]; gal[big]; uludin[form]; dirig[make more than]; niŋul[an everlasting thing]; rib[surpassing]
#etcsl: line-id=A.3

4. nitalam-zu en gal {d}nu-dim₂-mud zag kalam-ma šu du₇
#lem: ŋidlam[(equal ranking) spouse]; en[lord]; gal[big]; Nudimmud[1]DN; zag[side]; kalam[the Land (of Sumer)]; šu[hand]; du[perfect]
#etcsl: line-id=A.4

5. en igi-ŋal₂-la an lugal šum₂-mu ad gi₄-gi₄ gal-zu
#lem: en[lord]; igiŋal[wise]; An[1]DN; lugal[king]; šum[give]; ad[voice]; gi[turn]; galanzu[wise]
#etcsl: line-id=A.5

6. en gal-an-zu dug₄-ga-ni saŋ-ba du kug-zu niŋ₂-nam-ma-kam
#lem: en[lord]; galanzu[wise]; dug[speak]; saŋ[head]; ŋen[go]; kugzu[wise]; niŋnam[anything]
#etcsl: line-id=A.6

7. mas-su mah šag₄ {d}en-lil₂-la₂-ka sig₁₀-ge₅ me-bi sag₂ [nu]-di
#lem: massu[leader]; mah[great]; šag[heart]; Enlil[1]DN; sig[put into]; me[Being]; sag[scatter]; di[speak]
#etcsl: line-id=A.7

8. ŋeštug₂# daŋal mu dug₃-ga sa₄#-a eš-bar-e šum₂-[...]
#lem: ŋeštug[ear]; daŋal[wide]; mu[name]; dug[good]; še[call by name]; ešbar[decision]; šum[give]
#etcsl: line-id=A.8

9. [u₃]-tud-da zu X [...] šag₄ X [...]
#lem: utud[give birth (to)]; zu[know]; X; X; šag[heart]; X; X
#etcsl: line-id=A.9

$ (unknown no. of lines missing)
@end segment

@div segment B

1. an lugal# [...]
#lem: an[sky]; lugal[king]; X
#etcsl: line-id=B.1

2. u₃-sumun₂ zid# [...]
#lem: sumun[wild cow]; zid[right]; X
#etcsl: line-id=B.2

3. zi nam-til₃# [...]
#lem: zi[life]; namtil[life]; X
#etcsl: line-id=B.3

4. lu₂-ulu₃-bi [...]
#lem: lulu[man]; X
#etcsl: line-id=B.4

5. ne-saŋ ŋar-ra [...]
#lem: nesaŋ[first-fruit offering]; ŋar[put]; X
#etcsl: line-id=B.5

6. ur₅ sag₉-ge šag₄ [...]
#lem: ur[liver]; sag[good]; šag[heart]; X
#etcsl: line-id=B.6

7. nam-til₃ zi sud# [...]
#lem: namtil[life]; zi[life]; sud[distant]; X
#etcsl: line-id=B.7

8. e₂ kaš de₂-a A [...] i₃ {ŋiš}erin-na# [...]
#lem: e[house]; kaš[beer]; de[pour]; X; X; i[oil]; eren[cedar]; X
#etcsl: line-id=B.8

$ (unknown no. of lines missing)
@end segment

@div segment C

1. {dug}šakir₃ [...]
#lem: šakir[churn]; X
#etcsl: line-id=C.1

2. nun gal {d}en-[ki ...] X [...]
#lem: nun[prince]; gal[big]; Enkik[1]DN; X; X; X
#etcsl: line-id=C.2

3. e₂# [...]
#lem: e[house]; X
#etcsl: line-id=C.3

$ (unknown no. of lines missing)
