@div segment D

1. abzu# me-bi X [...]
#lem: abzu[(cosmic) underground water]; me[Being]; X; X
#etcsl: line-id=D.1

2. X sag₉-ga lu₂# [...]
#lem: X; sag[good]; lu[person]; X
#etcsl: line-id=D.2

3. saŋ il₂ nam-nin-a za₃-mi₂-zu X
#lem: saŋ[head]; il[raise]; namnin[ladyship]; zamin[praise]; X
#etcsl: line-id=D.3

4. eridug{ki} kur he₂-ŋal₂-la-zu dam-bi nu-til-e
#lem: Eridug[1]SN; kur[mountain(s)]; heŋal[plenty]; dam[spouse]; til[complete]
#etcsl: line-id=D.4

5. diŋir gal#-gal-e-ne u₃-tud-bi he₂-a diŋir-bi he₂-em
#lem: diŋir[deity]; gal[big]; utud[give birth (to)]; me[be]; diŋir[deity]; me[be]
#etcsl: line-id=D.5

@div trailer 

6. šir₃-šag₄-hul₂-la {d}dam-gal-nun#-[na-kam]
#lem: širšaghulak[subscript]; Damgalnunak[1]DN
#etcsl: line-id=D.6

