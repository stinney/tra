#etcsl: line-id=18

19. nitah lu₂ he₂-me#-[en] lu₂# he₂-me#-[en]
#lem: nita[male]; lu[person]; me[be]; lu[person]; me[be]
#etcsl: line-id=19

20. he₂-me-en dumu diŋir-za he₂-[me-en]
