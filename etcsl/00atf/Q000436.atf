1. me#-zu NE# [...]
#lem: me[Being]; X; X
#etcsl: line-id=1

2. a-a {d}nanna X X [...]
#lem: aya[father]; Nanna[1]DN; X; X; X
#etcsl: line-id=2

3. uŋ₃-ŋa₂ mi-ni-pad₃ AN [...]
#lem: uŋ[people]; pad[find]; X; X
#etcsl: line-id=3

4. šul {d}suen |KI.LUGAL.GUB|-zu kug [...]
#lem: šul[youth]; Suen[1]DN; KI.LUGAL.DU[cultic place]; kug[purify]; X
#etcsl: line-id=4

5. an aga zid men saŋ-ŋa₂-zu za-e [...]
#lem: An[1]DN; aga[tiara]; zid[right]; men[tiara]; saŋ[head]; zaʾe[you]; X
#etcsl: line-id=5

6. ki barag gal mah dur₂ ŋar-ra-zu zi [...]
#lem: ki[place]; barag[sanctum]; gal[big]; mah[great]; dur[buttocks]; ŋar[put]; zi[life]; X
#etcsl: line-id=6

7. ka kug ba-a-zu u₁₈-ru gal me pa [...]
#lem: kag[mouth]; kug[purify]; bad[open]; urun[exalted]; gal[big]; me[Being]; pa[branch]; X
#etcsl: line-id=7

8. aga nam-lugal-la men kug suh₁₀-gir₁₁ [...]
#lem: aga[tiara]; namlugal[kingship]; men[tiara]; kug[purify]; suhgir[diadem]; X
#etcsl: line-id=8

9. {ŋiš}gu-za me ur₄-ur₄ barag saŋ il₂ X [...]
#lem: guza[chair]; me[Being]; ur[gather]; barag[sanctum]; saŋ[head]; il[raise]; X; X
#etcsl: line-id=9

10. peš₁₀-ŋal₂ nam barag-ga numun zid# [...]
#lem: pešŋal[mighty?]; nam[fate]; barag[sanctum]; numun[seed]; zid[right]; X
#etcsl: line-id=10

11. {d}i-bi₂-{d}suen-ŋu₁₀ an kug-ta nam X [...]
#lem: Ibbisuen[1]RN; An[1]DN; kug[pure]; nam[fate]; X; X
#etcsl: line-id=11

12. en me kug-ku₃-ug me sikil šu-luh zalag nam# [...]
#lem: en[lord]; me[Being]; kug[pure]; me[Being]; sikil[purify]; šuluh[ritual cleansing]; zalag[bright]; nam[fate]; X
#etcsl: line-id=12

13. si mul-mul su₃-ra₂-aŋ₂ an-na šul# {[d]}[suen ...]
#lem: si[horn]; mul[shine]; sudaŋ[precious metal or material (possibly amber)]; an[sky]; šul[youth]; Suen[1]DN; X
#etcsl: line-id=13

14. ud te-eš-e gal idim-ma hi-li-bi ki [...]
#lem: ud[storm]; teš[voice]; gal[big]; idim[spring]; hili[attractiveness]; ki[place]; X
#etcsl: line-id=14

15. nibru{ki} a₂ tal₂-tal₂ {d}nanna šag₄ kug [...]
#lem: Nibru[1]SN; a[arm]; tal[broad]; Nanna[1]DN; šag[heart]; kug[purify]; X
#etcsl: line-id=15

16. nun zi-le an ki šu₂-a-ba iti₆ X [...]
#lem: nun[prince]; zil[good]; an[sky]; ki[place]; šuš[cover]; itud[moon]; X; X
#etcsl: line-id=16

17. gud# pa e₃ {d}en-lil₂-da mah dib HI X [...]
#lem: gud[bull]; pa[branch]; e[leave]; Enlil[1]DN; mah[great]; dib[pass]; X; X; X
