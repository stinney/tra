:8v.1.2: (#note: 1 other ms. has instead:#) šid nu-da₁₃-da₁₃-dam#
#lem: šid[recite]; taka[set aside]

9. {m}ur-sag₉-ga arad-zu na-ab-be₂-a
#lem: Ursaga[1]PN; arad[slave]; e[speak]
#etcsl: line-id=9

10. lugal-ŋu₁₀ bar-ŋa₂ en₃ (1:bi₂-in-tar:1) dumu urim₂{ki}-ma-me-en
#lem: lugal[king]; bar[outside]; en[cvne]; tar[cut]; dumu[child]; Urim[1]SN
#etcsl: line-id=10

:10v.1.1: (#note: 2 mss. have instead:#) li-bi₂-in-tar
