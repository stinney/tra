1. lugal (1:gud:1) igi gun₃ sun₄ {na₄}za-gin₃ la₂-ŋu₁₀-ur₂ {{%akk a-na %akk šar-ri %akk ša %akk ki# %akk al#-pi# %akk ši-it-ha-ri# %akk qi₂#-bi-ma#}}
#lem: lugal[king]; gud[bull]; igi[eye]; gunu[speckled]; sum[beard]; zagin[lapis lazuli]; la[hang]; L; L; L; L; L; L; L
#etcsl: line-id=1

:1v.1.1: (#note: 1 ms. has instead:#) am
#lem: am[wild bull]
:1v.1.2: (#note: 1 other ms. has instead:#) alim#
#lem: alim[bison]

2. u₃-na-a-dug₄
#lem: dug[speak]
#etcsl: line-id=2

3. alan kug-sig₁₇ ud dug₃-ga tud-da {{%akk ṣa-lamₓ(LUM) %akk hu-ra#-ṣi %akk i-nu-mi %akk ṭa-bu %akk UD.DA}}
#lem: alan[image]; kugsig[gold]; ud[sun]; dug[good]; utud[give birth (to)]; L; L; L; L; L
#etcsl: line-id=3

4. ab₂-za-za amaš kug-ga buluŋ₃-ŋa₂ šag₄ (1:kug {d}inana-ta pad₃-da:1) {{%akk wa-tu}}
#lem: abzaza[zebu]; amaš[sheepfold]; kug[pure]; buluŋ[grow]; šag[heart]; kug[purify]; Inanak[1]DN; pad[find]; L
#etcsl: line-id=4

:4v.1.1: (#note: 1 ms. has instead:#) kug {d}inana [...] {[d]}suen-na#
#lem: kug[purify]; Inanak[1]DN; X; Suen[1]DN

5. en nir-ŋal₂ {d}inana-ŋu₁₀-ur₂ u₃-na-de₃-tah
#lem: en[lord]; nirŋal[authoritative]; Inanak[1]DN; tah[add]
#etcsl: line-id=5

6. za-e dim₂-ma-zu dumu an-na-me-en {{%akk wa-X %akk [...] %akk X-ra-ni}}
#lem: zaʾe[you]; dim[create]; dumu[child]; An[1]DN; L; L; L
#etcsl: line-id=6

7. dug₄-ga-zu inim diŋir-ra-gin₇ (1:hur nu-gi₄-gi₄-dam:1) {{%akk hu-ur %akk la %akk ta-ar}}
#lem: dug[speak]; inim[word]; diŋir[deity]; hur[ever (again)]; gi[turn]; L; L; L
#etcsl: line-id=7

:7v.1.1: (#note: 1 ms. has instead:#) kur#-kur nu-gi₄#-[...]
#lem: kur[mountain(s)]; gi[turn]

8. inim-zu im an-ta šeŋ₃-ŋe₂₆-gin₇ (1:šid nu-tuku-tuku-dam:1) {{%akk X# %akk BI.NA}}
#lem: inim[word]; im[rain]; an[sky]; šeŋ[rain]; šid[recite]; tuku[acquire]; L; L
#etcsl: line-id=8

:8v.1.1: (#note: 1 ms. has instead:#) šid# nu-du₃-du₃-dam#
