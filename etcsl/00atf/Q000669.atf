#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.4.12.2
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.4.12.2&display=Crit&charenc=gcirc#

@div segment A

1. [...] X X ZU igi kar₂ me DA X X X ur₄-ur₄
#lem: X; X; X; X; igi[eye]; kar[blow]; me[Being]; X; X; X; X; ur[gather]
#etcsl: line-id=A.1

2. [...] X X ušum zag dib an ki-a mu mah-a sa₄-a
#lem: X; X; X; ušum[snake]; zag[side]; dib[pass]; an[sky]; ki[place]; mu[name]; mah[great]; še[call by name]
#etcsl: line-id=A.2

3. [...] X saŋ an gal ri-a dub₃ kug-ga peš-e
#lem: X; X; saŋ[head]; An[1]DN; gal[big]; ri[impose]; dub[knee]; kug[pure]; peš[thick]
#etcsl: line-id=A.3

4. [...] X sig₁₀-ga ulutim₂ X X si-a-ni X u₃-tud-da {d}uraš-a
#lem: X; X; sig[put into]; uludin[form]; X; X; si[fill]; X; utud[give birth (to)]; Uraš[1]DN
#etcsl: line-id=A.4

5. X sag₉ MUŠ₃ X ul-la u₆ di-de₃ ba-ab-du₇
#lem: X; sag[goodness]; X; X; ul[swell]; u[admiration]; di[speak]; du[perfect]
#etcsl: line-id=A.5

6. mi₂ dug₄-ga kur gal {d}en-lil₂-le nam dug₃-ge-eš tar-ra
#lem: mi[cvne]; dug[speak]; kur[mountain(s)]; gal[big]; Enlil[1]DN; nam[fate]; dug[good]; tar[cut]
#etcsl: line-id=A.6

7. KA TAR# sag₉ gurun šu tag X la-la-bi X-ge nu-gid₂-da
#lem: X; X; sag[goodness]; gurun[fruit]; šu[hand]; tag[touch]; X; lala[plenty]; X; gid[long]
#etcsl: line-id=A.7

8. [saŋ]-kug#-ŋal₂ diŋir gal-gal-e-ne šag₄ dab₅-dab₅-bi X [...]
#lem: saŋguŋal[proud]; diŋir[deity]; gal[big]; šag[heart]; dab[seize]; X; X
#etcsl: line-id=A.8

9. [... ...] X-bi sikil šu-luh dadag a-ra₂-ni [...]
#lem: X; X; X; sikil[purify]; šuluh[ritual cleansing]; dadag[bright]; ara[way]; X
#etcsl: line-id=A.9

10. [... ...] dug₄-ga-ni u₃-en₃ nu-ša₄ umuš ŋalga [...]
#lem: X; X; dug[speak]; uʾen[explanation]; ša[cvve]; umuš[consideration]; ŋalga[(fore)thought]; X
#etcsl: line-id=A.10

11. [...] su₃#-ra₂ mas-su X HI-HI [...]
#lem: X; sud[distant]; massu[leader]; X; X; X
#etcsl: line-id=A.11

$ at least 26 lines missing
@end segment

