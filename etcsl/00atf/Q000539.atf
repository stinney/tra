27. nu-kar₂-kar₂-de₃ aga-us₂ lugal-ŋa₂-ke₄ {ŋiš}banšur-ŋu₁₀ in-bal-a-še₃
#lem: kar[blow]; agaʾus[professional soldier]; lugal[king]; banšur[table]; bala[turn]
#etcsl: line-id=27

28. ni₂ ba-da-te su ba-da-zig₃
#lem: ni[fear]; teŋ[approach]; su[flesh]; zig[rise]
#etcsl: line-id=28

29. itid ezen-{d}nin-a-zu ud (1:15-kam-ma-ta#:1)
#lem: itud[moon]; Ezenninazu[1]MN; ud[sun]; n
#etcsl: line-id=29

