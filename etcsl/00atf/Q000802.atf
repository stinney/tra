#etcsl: line-id=A.9.a3.4

@end proverb

@div proverb 9.a4

5. a₂-tuku lugal ki-in-du-ka
#lem: atuku[powerful]; lugal[king]; kindu[earth]
#etcsl: line-id=A.9.a4.5

#note: cf. 6.1.10.5, 6.1.22: l. 190, 6.2.3: UET 6/3 80 l. 18

@end proverb

@div proverb 9.a5

6. usu ka lu₂-ta# am₃-ku₄-ku₄
#lem: usu[strength]; kag[mouth]; lu[person]; kur[enter]
#etcsl: line-id=A.9.a5.6

#note: cf. 6.1.10.6

@end proverb

@div proverb 9.a6

