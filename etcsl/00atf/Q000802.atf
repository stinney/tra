@div segment A

@div proverb 9.a1

1. nir-ŋal₂-e a-na bi₂-in-dug₄ nu-sag₉
#lem: nirŋal[authoritative]; ana[what?]; dug[speak]; sag[good]
#etcsl: line-id=A.9.a1.1

#note: cf. 6.1.10.1, 6.2.5: IM 43438 Seg. A l. 1

@end proverb

@div proverb 9.a2

2. nir-ŋal₂-e a-na bi₂-in-dug₄ nu-zid
#lem: nirŋal[authoritative]; ana[what?]; dug[speak]; zid[right]
#etcsl: line-id=A.9.a2.2

#note: cf. 6.1.10.2

@end proverb

@div proverb 9.a3

3. nir-ŋal₂ kug-zu-am₃ ukur₃ šu dim₄-ma-am₃
#lem: nirŋal[authoritative]; kugzu[wise]; ukur[poor]; šu[hand]; dim[check]
#etcsl: line-id=A.9.a3.3

#note: cf. 6.1.10.3-4, 6.2.2: MDP 27 216, 6.2.5: IM 43438 Seg. A l. 2

4. šu ŋar ŋal₂-la aratta{ki}-ka
