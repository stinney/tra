#lem: šuniŋin[total]; n; endu[song]; lugal[king]
#etcsl: line-id=33

34. lugal en gal-di an-na
#lem: lugal[king]; en[lord]; galdi[exalted]; an[sky]
#etcsl: line-id=34

35. saŋ-me-en kug
#lem: saŋmen[crown]; kug[purify]
