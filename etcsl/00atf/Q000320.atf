#lem: ursaŋ[warrior]; šul[youth]; zid[right]; utud[give birth (to)]
#etcsl: line-id=26

27. nin hi-li sud
#lem: nin[lady]; hili[attractiveness]; sud[distant]
#etcsl: line-id=27

28. aŋrig zid unken-na
#lem: agrig[steward]; zid[right]; unkin[assembly]
#etcsl: line-id=28

29. ušum huš an-na#
#lem: ušum[snake]; huš[reddish]; an[sky]
#etcsl: line-id=29

30. lugal-me šag₄-ta ur-saŋ-me-en
#lem: lugal[king]; šag[heart]; ursaŋ[warrior]
#etcsl: line-id=30

