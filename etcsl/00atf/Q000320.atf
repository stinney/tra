&Q000320 = Ur III catalogue at Yale (Y1)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.0.1.2
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.0.1.2&display=Crit&charenc=gcirc#

1. diŋir šembi₂-zid-da dar!-a
#lem: diŋir[deity]; šembizida[kohl]; dar[split]
#etcsl: line-id=1

2. {d}en-lil₂-la₂ dug₄#-ga-ni nu-kur₂
#lem: Enlil[1]DN; dug[speak]; kur[different]
#etcsl: line-id=2

3. lugal# an kug-ga me-te-bi
#lem: lugal[king]; an[sky]; kug[pure]; mete[appropriate thing]
#etcsl: line-id=3

4. lugal {d}en-lil₂-ra gub-ba
#lem: lugal[king]; Enlil[1]DN; gub[stand]
#etcsl: line-id=4

5. en gud ban₃-da
#lem: en[lord]; gud[bull]; banda[junior]
#etcsl: line-id=5

6. še-er-zid en-da gal
#lem: šerzid[radiance]; en[lord]; gal[big]
#etcsl: line-id=6

7. munus zid mi₂ dug₄-ga
#lem: munus[woman]; zid[right]; mi[cvne]; dug[speak]
#etcsl: line-id=7

8. en su-li₂-im
#lem: en[lord]; sulim[awesome radiance]
#etcsl: line-id=8

9. ur-saŋ en huš gal
#lem: ursaŋ[warrior]; en[lord]; huš[reddish]; gal[big]
#etcsl: line-id=9

10. ur-saŋ en me ša-ra tum₂-ma
#lem: ursaŋ[warrior]; en[lord]; me[Being]; šar[numerous]V/i; tum[suitable]
#etcsl: line-id=10

11. lugal an#-[šag₄]-ta# hi-[li] guru₃#
#lem: lugal[king]; anšag[the interior of heaven]; hili[attractiveness]; gur[lift]
#etcsl: line-id=11

12. nin me-e he₂-du₇
#lem: nin[lady]; me[Being]; hedu[ornament]
#etcsl: line-id=12

13. en inim nun zu
#lem: en[lord]; inim[word]; nun[prince]; zu[know]
#etcsl: line-id=13

14. {d}šul-gi hi-li sud
#lem: Šulgir[1]RN; hili[attractiveness]; sud[distant]
#etcsl: line-id=14

15. {d}šul-gi diŋir zid
#lem: Šulgir[1]RN; diŋir[deity]; zid[right]
#etcsl: line-id=15

16. en gal-zu an-na
#lem: en[lord]; galanzu[wise]; an[sky]
#etcsl: line-id=16

17. lugal-ŋu₁₀ hi-li guru₃
#lem: lugal[king]; hili[attractiveness]; gur[lift]
#etcsl: line-id=17

#note: Ur-Namma E, 2.4.1.5, line 25 and Ur-Namma F, 2.4.1.6, line 25

18. lugal inim sag₉
#lem: lugal[king]; inim[word]; sag[goodness]
#etcsl: line-id=18

19. ur-saŋ šag₄ kug-ta
#lem: ursaŋ[warrior]; šag[heart]; kug[pure]
#etcsl: line-id=19

20. lugal a-ma-ru
#lem: lugal[king]; amaru[flood]
#etcsl: line-id=20

21. lugal me-lem₄ huš
#lem: lugal[king]; melim[frightening splendor]; huš[reddish]
#etcsl: line-id=21

22. ur-saŋ ni₂ gal guru₃
#lem: ursaŋ[warrior]; ni[fear]; gal[big]; gur[lift]
#etcsl: line-id=22

23. en an ki-a
#lem: en[lord]; an[sky]; ki[place]
#etcsl: line-id=23

