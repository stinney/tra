#lem: ama[mother]; dug[speak]; ni[self]; zeŋ[give]V/t
#etcsl: line-id=16

17. ad-da-ŋu₁₀-ur₂ %e aŋ₂ %s ba-ba mu-un-ba
#lem: adda[father]; aŋ[thing]N; ba[allot]; ba[allot]
#etcsl: line-id=17

18. ur₅-za!(SA₆) ki ur₅ sag₉-ge-bi mu-zu
