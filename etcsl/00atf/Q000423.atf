#lem: dab[seize]; ni[self]; men[go]V/i
#etcsl: line-id=5

6. %e mu-ti-in %s ga-ba-e-da-kar ki %e mu-nud-da-še₃
#lem: mutin[male]; kar[flee]; ki[place]; munud[bed]N
