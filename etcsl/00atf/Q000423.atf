#etcsl: line-id=2

3. gi-ru šag₄-ŋa₂ %e mu-lu %s ki-ig-ga aŋ₂#-[ŋu₁₀]
#lem: giru[an affectionate epithet]; šag[heart]; mulu[person]N; ki[place]; aŋ[measure]
#etcsl: line-id=3

