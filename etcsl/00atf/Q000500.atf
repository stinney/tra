@end sa-jara

@div uru E

11. urim₂{ki} iri ul kur nam-nun-na iri me gal-gal-la-za
#lem: Urim[1]SN; iri[city]; ul[distant time]; kur[mountain(s)]; namnun[magnificence]; iri[city]; me[Being]; gal[big]
#etcsl: line-id=B.E.11

12. e₂-kiš#-nu-ŋal₂ ud nu-dib-be₂ e₂ nu-ša-ra-ge-za
#lem: Ekišnuŋal[1]TN; ud[sun]; dib[pass]; e[house]; šarag[dry out]
#etcsl: line-id=B.E.12

13. gu-un-gu-nu-um šag₄-ge pad₃-da-zu nam-til₃ ud su₃-ra₂ ha-ba-ni-ib-su₃-ud-de₃
#lem: Gungunum[1]RN; šag[heart]; pad[find]; namtil[life]; ud[sun]; sud[distant]; sud[distant]
#etcsl: line-id=B.E.13

