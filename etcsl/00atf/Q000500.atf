@div segment A

@div barsud A

$ 1 line missing
2. [...] diŋir-re-e-ne ud [...]
#lem: X; diŋir[deity]; ud[sun]; X
#etcsl: line-id=A.A.2

3. [...] X gal sig₇-ga še-er-[zid ...] X
#lem: X; X; gal[big]; sissig[green-yellow]; šerzid[radiance]; X; X
#etcsl: line-id=A.A.3

@div trailer 

4. bar-sud-am₃
#lem: barsud[musical notation]
#etcsl: line-id=A.A.4

@end trailer

@end barsud

@div cagbatuku B

5. X [...] X-ŋal₂-bi nam-nun-na ŋiri₃# [...] X
#lem: X; X; ŋal[⟦be⟧ to be (there]; namnun[magnificence]; ŋiri[foot]; X; X
#etcsl: line-id=A.B.5

6. lugal palil# {[d]}a-nun-na-ke₄-ne nun ka-aš bar zid-da
#lem: lugal[king]; palil[first and foremost]; Anunak[1]DN; nun[prince]; kaš[decision]; bar[place outside]; zid[right]
#etcsl: line-id=A.B.6

7. en {d}dil-im₂-babbar an-e {d}en-lil₂-le an-e ši-ma-ab-du₇-un
#lem: en[lord]; Dilimbabbar[1]DN; An[1]DN; Enlil[1]DN; an[sky]; du[perfect]
#etcsl: line-id=A.B.7

8. ki aŋ₂ lugal-la# aga zid-da gun₃-gun₃-nu
#lem: ki[place]; aŋ[measure]; lugal[king]; aga[tiara]; zid[right]; gunu[speckled]
#etcsl: line-id=A.B.8

9. un₃#-na e₃ an-bar₇#-gana₂ ŋi₆ u₃-na ud zalag-gin₇ mu-un-e₃
#lem: un[high]; e[leave]; anbarkar[mid-day]; ŋi[night]; ŋiʾunak[night]; ud[sun]; zalag[bright]; e[leave]
#etcsl: line-id=A.B.9

10. [šul] {d}suen en dumu X kur gal-la {d}nin-lil₂-e tud-da
#lem: šul[youth]; Suen[1]DN; en[lord]; dumu[child]; X; kur[mountain(s)]; gal[big]; Ninlil[1]DN; utud[give birth (to)]
#etcsl: line-id=A.B.10

11. {[d]}[en]-ki {d}nin-ki pa-bil₂-ga-ni nam dug₃-ge-eš tar-re
#lem: Enkik[1]DN; Ninki[1 Ninki-goddess]; pabilga[kinship term]; nam[fate]; dug[good]; tar[cut]
#etcsl: line-id=A.B.11

12. [...] NI ŋiš X-bi mu-na-an-šum₂ en zid an-na-ke₄
#lem: X; X; ŋeš[tree]; X; šum[give]; en[lord]; zid[right]; an[sky]
#etcsl: line-id=A.B.12

#note: Sumerian gloss: ce-er-zid

@div trailer 

13. šag₄-ba-tuku-am₃
#lem: šagbatuku[liturgical rubric]
#etcsl: line-id=A.B.13

@end trailer

@end cagbatuku

@div unknown C

