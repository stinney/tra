#lem: X; iri[city]; ki[place]; gi[turn]
#etcsl: line-id=B.D.3

4. [... ...] X nun lugal [...] X he₂-a gaba gi₄ na-an-tuku-tuku
#lem: X; X; X; nun[prince]; lugal[king]; X; X; me[be]; gaba[breast]; gi[turn]; tuku[acquire]
#etcsl: line-id=B.D.4

5. [ki-en]-gi ki-uri sag₂# dug₄-ga ki-bi ha-ra-ab-gi₄-gi₄#
#lem: Kengir[1]; Akkad[1 Akkad]; sag[scatter]; dug[speak]; ki[place]; gi[turn]
#etcsl: line-id=B.D.5

6. [... ...] niŋ₂-du₇#-e pa bi₂#-i₃-e₃-a gu₂ an-še₃ he₂-zig₃
#lem: X; X; niŋdu[that which is appropriate]; pa[branch]; e[leave]; gu[neck]; an[sky]; zig[rise]
#etcsl: line-id=B.D.6

7. nam#-til₃ niŋ₂ dug₃ hu-mu-na#-da-sud zi-ni he₂-a-u₃-tud
#lem: namtil[life]; niŋ[thing]; dug[good]; sud[distant]; zi[life]; utud[give birth (to)]
#etcsl: line-id=B.D.7

8. šu#-nir kug-sig₁₇-ni gal-le-eš rib-ba me-dim₂-bi a-re₂-eš-še₃
#lem: šunir[emblem]; kugsig[gold]; gal[big]; rib[surpassing]; medim[limbs]; ar[celebrate]
#etcsl: line-id=B.D.8

9. ne#-saŋ a-a {d}en-lil₂-la₂-še₃ muš₂ nu-tum₂-mu ma-ra-an-X ud-da-ni ha-ra-su₃-ud
#lem: nesaŋ[first-fruit offering]; aya[father]; Enlil[1]DN; muš[face]; tum[bring]; X; ud[sun]; sud[distant]
#etcsl: line-id=B.D.9

@div trailer 

10. sa-ŋar-ra-am₃
#lem: saŋara[musical notation]
#etcsl: line-id=B.D.10

