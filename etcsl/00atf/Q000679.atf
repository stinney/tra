1. en giri₁₇-zal an-na [...] X-da-e he₂-du₇
#lem: en[lord]; kirizal[joy]; an[sky]; X; X; hedu[ornament]
#etcsl: line-id=1

2. {d}nanna si-un₃-na muš₃ me-lem₄ sud-sud
#lem: Nanna[1]DN; siʾuna[zenith]; muš[face]; melim[frightening splendor]; sud[distant]
#etcsl: line-id=2

3. lugal ud še-er-zid men urim₂{ki}-ma
#lem: lugal[king]; ud[sun]; šerzid[radiance]; men[tiara]; Urim[1]SN
#etcsl: line-id=3

4. {d}nanna ud še-er-zid men urim₂{ki}-ma
#lem: Nanna[1]DN; ud[sun]; šerzid[radiance]; men[tiara]; Urim[1]SN
#etcsl: line-id=4

5. piriŋ gal an kug-ga dumu-saŋ {d}en-lil₂-la₂
#lem: piriŋ[lion]; gal[big]; An[1]DN; kug[pure]; dumusaŋ[first-born]; Enlil[1]DN
#etcsl: line-id=5

6. a alim ki aŋ₂ diŋir-re-e-ne
#lem: a[water]; alim[bison]; ki[place]; aŋ[measure]; diŋir[deity]
#etcsl: line-id=6

7. ne# gal kalam-ma ni₂ ri-a
#lem: ne[strength]; gal[big]; kalam[the Land (of Sumer)]; ni[fear]; ri[impose]
#etcsl: line-id=7

8. [aga] zid# ŋidru mul-mul kur un₃-na gun₃!-a
#lem: aga[tiara]; zid[right]; ŋidru[scepter]; mul[shine]; kur[mountain(s)]; un[high]; gunu[speckled]
#etcsl: line-id=8

9. [... ...] {[d]}en#-lil₂-la₂ me nun-e si-a
#lem: X; X; Enlil[1]DN; me[Being]; nun[prince]; si[fill]
#etcsl: line-id=9

10. [...] X UL nibru{ki} šag₄-ga
#lem: X; X; X; Nibru[1]SN; šag[heart]
#etcsl: line-id=10

