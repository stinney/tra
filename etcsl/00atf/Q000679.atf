#etcsl: line-id=15

16. [...] X
#lem: X; X
#etcsl: line-id=16

17. [...] X
#lem: X; X
#etcsl: line-id=17

18. [...] su₃#-ra₂
#lem: X; sud[distant]
#etcsl: line-id=18

19. [...] X u₃-na du₇-a
#lem: X; X; una[wild]; du[push]
#etcsl: line-id=19

20. [...] X a₂ nu-kuš₂-u₃-de₃
#lem: X; X; a[arm]; kušu[tired]
#etcsl: line-id=20

21. [...] X an-na uraš-a mu-un-TU
#lem: X; X; an[sky]; uraš[earth]; X
#etcsl: line-id=21

22. [...] X niŋin₂-na-bi a₂ nun aŋ₂-e
#lem: X; X; niŋin[encircle]; a[arm]; nun[prince]; aŋ[measure]
#etcsl: line-id=22

23. AN DUR gud-gin₇ e₂ suhuš gub-bu-gin₇
#lem: X; X; gud[bull]; e[house]; suhuš[foundation]; gub[stand]
#etcsl: line-id=23

24. id₂ nun tur-ni igi kar₂-kar₂-de₃
#lem: id[river]; nun[prince]; tur[small]; igi[eye]; kar[blow]
#etcsl: line-id=24

25. piriŋ lu₂-erim₂-e inim kur₂ di-de₃
#lem: piriŋ[lion]; luʾerim[evildoer]; inim[word]; kur[alienate]; di[speak]
#etcsl: line-id=25

26. ki ku₁₀-ku₁₀ an-usan₆(|GU₂×KAK|) sud-sud-da
#lem: ki[place]; kukkug[dark]; usan[evening]; sud[distant]
#etcsl: line-id=26

27. šul {d}suen iti₆ niŋ₂ giri₁₇-zal uŋ₃-e u₆ mu-e
#lem: šul[youth]; Suen[1]DN; itud[moon]; niŋ[thing]; kirizal[joy]; uŋ[people]; u[admiration]; e[speak]
#etcsl: line-id=27

28. u₈-e sila₄-bi mi₂ dug₃! im-me
#lem: u[sheep]; sila[lamb]; mi[cvne]; dug[good]; dug[speak]
#etcsl: line-id=28

29. ud₅-de₃ maš₂-bi mi₂ i-ri im-me
#lem: uzud[(female) goat]; maš[goat]; mi[cvne]; ar[celebrate]; dug[speak]
#etcsl: line-id=29

30. šul-e nitalam-ni e-ne su₃-ud mu-un-da-e
#lem: šul[youth]; ŋidlam[(equal ranking) spouse]; ene[pleasure?]; sud[distant]; dug[speak]
#etcsl: line-id=30

31. {d}suen-e {d}nin-gal sag₉-ga-da šag₄ mu-da-ab-kuš₂-u₃
#lem: Suen[1]DN; Ningal[1]DN; sag[good]; šag[heart]; kušu[tired]
#etcsl: line-id=31

32. za₃-mi₂ dug₄-ga šul {d}suen-na# a-a {d}nanna-[kam]
#lem: zamin[praise]; dug[speak]; šul[youth]; Suen[1]DN; aya[father]; Nanna[1]DN
#etcsl: line-id=32

@div trailer 

33. u₂-lu-lu-ma-ma {d}nanna-kam#
#lem: ululumama[lament]; Nanna[1]DN
