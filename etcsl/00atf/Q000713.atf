#etcsl: line-id=A.5

A.6. e₂ {d}en-lil₂-la₂-ta e₃-ni
#lem: e[house]; Enlil[1]DN; e[leave]
#etcsl: line-id=A.6

A.7. eridug{ki} <ki> dug₃-ga am₃-ma-da-an-ku₄-ku₄
#lem: Eridug[1]SN; ki[place]; dug[good]; kur[enter]
#etcsl: line-id=A.7

A.8. eš₃-e abzu#-a dur₂ ba-ni-in-ŋar
#lem: eš[shrine]; Eʾabzu[1]; dur[buttocks]; ŋar[put]
#etcsl: line-id=A.8

A.9. a-a-ni {d}en-ki-ke₄ dub₃-ba nam-mi-in-tuš
#lem: aya[father]; Enkik[1]DN; dub[knee]; tuš[sit (down)]
#etcsl: line-id=A.9

A.10. {[d]}[nin]-isin₂{si}-na-ra mi₂ zid na-mu-un-e
#lem: Ninisinak[1]DN; mi[cvne]; zid[right]; e[speak]
#etcsl: line-id=A.10

A.11. X X X unu₂# šuba hi-li ba-an-te
#lem: X; X; X; unu[adornment]; šuba[precious stone]; hili[attractiveness]; teŋ[approach]
#etcsl: line-id=A.11

A.12. {d}nin-isin₂{si}-na-ra gu₂-na he₂-eb-du₃
#lem: Ninisinak[1]DN; gu[neck]; du[build]
#etcsl: line-id=A.12

A.13. gada babbar-ra hi-li im-ma-an-[te]
#lem: gada[flax]; babbar[white]; hili[attractiveness]; teŋ[approach]
#etcsl: line-id=A.13

A.14. dumu an kug-ga-ra bar-ra he-em-mi-in-dul#
#lem: dumu[child]; An[1]DN; kug[pure]; bar[outside]; dul[cover]
#etcsl: line-id=A.14

A.15. en {d}nu-dim₂-mud-e nam-[e]-eš mu#-[ni-in-tar]
#lem: en[lord]; Nudimmud[1]DN; nam[fate]; tar[cut]
#etcsl: line-id=A.15

