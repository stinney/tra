#etcsl: line-id=9

10. alim igi gun₃ šen-na-me-en
#lem: alim[bison]; igi[eye]; gunu[speckled]; šen[pure]
#etcsl: line-id=10

11. sun₄ {na₄}za-gin₃ e₃-a ŋir₂ keše₂-keše₂-du₃!-me-en
#lem: sum[beard]; zagin[lapis lazuli]; e[leave]; ŋir[flash]; kešed[bind]
#etcsl: line-id=11

