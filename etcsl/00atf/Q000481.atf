#etcsl: line-id=4

5. nam-šul-la gu₂ gal peš-a-me-en
#lem: namšul[manhood]; gu[neck]; gal[big]; peš[thick]
#etcsl: line-id=5

6. piriŋ (1:zag dib:1) gaba-ri nu-tuku-me-en
#lem: piriŋ[lion]; zag[side]; dib[pass]; gabari[equal]; tuku[acquire]
#etcsl: line-id=6

:6v.1.1: (#note: 3 mss. have instead:#) zag til
#lem: zag[side]; til[make complete]

7. ušumgal ka du₈-a ni₂ gal erin₂-na-me-en
#lem: ušumgal[great dragon]; kag[mouth]; du[spread]; ni[fear]; gal[big]; erin[people]
#etcsl: line-id=7

8. anzud{mušen} kur-šag₄-ga igi ŋal₂-me-en
#lem: Anzud[1]DN; kuršag[center of the mountains]; igi[eye]; ŋal[⟦be⟧ to be (there]
#etcsl: line-id=8

