1. lugal mi₂ dug₄-ga šag₄-ta numun zid-me-en
#lem: lugal[king]; mi[cvne]; dug[speak]; šag[heart]; numun[seed]; zid[right]
#etcsl: line-id=1

#note: Cited in OB catalogue from Nibru, at Philadelphia, 0.2.01, line 2; OB catalogue from Urim (U2), 0.2.04, line 5; OB catalogue at Andrews University, 0.2.11, line 8; OB catalogue at Yale, 0.2.12, Seg. A, line 2

2. {d}li-pi₂-it-eš₄-tar₂ dumu {d}en-lil₂-la₂-me-en
#lem: Lipiteštar[1]RN; dumu[child]; Enlil[1]DN
#etcsl: line-id=2

