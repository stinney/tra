&Q000672 = A balbale to Nanna (Nanna C)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.4.13.03
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.4.13.03&display=Crit&charenc=gcirc#

@div segment A

@div unknown A

1. e₂ {d}utu e₃-a# ki-en-gi-ra#
#lem: e[house]; Utu[1]DN; e[leave]; Kengir[1]
#etcsl: line-id=A.A.1

$ ({d}utu is a supralinear correction by the scribe from an original UD-ta)
2. e₂-kiš#-[nu]-ŋal₂ šu-luh dadag-ga-am₃
#lem: Ekišnuŋal[1]TN; šuluh[ritual cleansing]; dadag[bright]
#etcsl: line-id=A.A.2

3. e₂ {d}nanna# nam-mah-za ga-ri#-dug₄
#lem: e[house]; Nanna[1]DN; nammah[greatness]; dug[speak]
#etcsl: line-id=A.A.3

4. eš₃#{ma} urim₂{ki} mu-zu pa ga-an-e₃
#lem: eš[shrine]; Urim[1]SN; mu[name]; pa[branch]; e[leave]
#etcsl: line-id=A.A.4

5. hur#-saŋ sikil šag₄ kug-ta e₃-a
#lem: hursaŋ[mountain]; sikil[purify]; šag[heart]; kug[pure]; e[leave]
#etcsl: line-id=A.A.5

6. urim₂{ki} igi-ŋal₂ {{%akk ta-ši-im-tum}} an uraš-a
#lem: Urim[1]SN; igiŋal[wise]; L; An[1]DN; Uraš[1]DN
#etcsl: line-id=A.A.6

7. e₂-temen-ni₂-guru₃-a tum₂-ma
#lem: Etemenniguru[1]TN; tum[suitable]
#etcsl: line-id=A.A.7

8. an-da nam-lugal {{%akk šar!-[...] %akk X}} mu-un-da-e-ba
#lem: An[1]DN; namlugal[kingship]; L; L; ba[allot]
#etcsl: line-id=A.A.8

9. nam-mah-zu kur-kur-re ba-X [...] X
#lem: nammah[greatness]; kur[mountain(s)]; X; X; X
#etcsl: line-id=A.A.9

10. su₃-ra₂-še₃ mu-zu pa ga-an-[e₃]
#lem: sud[distant]; mu[name]; pa[branch]; e[leave]
#etcsl: line-id=A.A.10

11. šu-luh nam-en-na-ke₄ si bi₂-sa₂-a#
#lem: šuluh[ritual cleansing]; namen[the office of en-priest]; si[horn]; sa[equal]
#etcsl: line-id=A.A.11

12. urim₂{ki}-ma dur₂ ki ba-ni-[X-ŋar]
#lem: Urim[1]SN; dur[buttocks]; ki[place]; ŋar[put]
#etcsl: line-id=A.A.12

13. mu-zu dug₃-ga-am₃ nun-e mu-un#-X [...]
#lem: mu[name]; dug[good]; nun[prince]; X; X
#etcsl: line-id=A.A.13

14. inim kug-zu an-ra ša-mu-sag₉# X
#lem: inim[word]; kug[pure]; An[1]DN; sag[good]; X
#etcsl: line-id=A.A.14

15. en-he₂-du₇-an-na-ŋu₁₀ an-na he₂-dirig#
#lem: Enheduana[1]PN; An[1]DN; dirig[make more than]
#etcsl: line-id=A.A.15

16. šu-luh ŋi₆-par₄-ra SI [...]
