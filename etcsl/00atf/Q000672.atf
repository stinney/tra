@end segment

@div segment B

@div jicgijal B

1. [...] lu₂# šu-luh-zu mu-un-zu-a
#lem: X; lu[person]; šuluh[ritual cleansing]; zu[know]
#etcsl: line-id=B.B.1

2. [...]-e# hu-mu-un-ak-e
#lem: X; ak[do]
#etcsl: line-id=B.B.2

3. [...]-zu# unu! sikil-la ša-ra-an-du₃
#lem: X; unu[dwelling]; sikil[pure]; du[build]
#etcsl: line-id=B.B.3

4. [... ...] nu₂#-a {{%akk šu-un-nu-um}} nu-un-ši-ku₄-ku₄
#lem: X; X; nud[lie down]; L; kur[enter]
#etcsl: line-id=B.B.4

5. še#-zu |GA₂×GI| sikil-la ma-ra-ar₃-ar₃-e {{%akk iṭ-ṭe-e-en-kum}}
#lem: še[barley]; ŋagia[cloister]; sikil[pure]; ara[grind]; L
#etcsl: line-id=B.B.5

6. ar₃-ar₃-ra-zu {{%akk E₂ %akk ṭe₆-X-nu}} unu-na la-ba-e-nu₂ {{%akk u₂-ul %akk uš-ta-a-an}}
#lem: ara[grind]; L; L; unu[dwelling]; nud[lie down]; L; L
#etcsl: line-id=B.B.6

7. niŋ₂-ar₃-ra-zu {{%akk mu-un-da-ka}} a nu-tag-ge
#lem: niŋara[groats]; L; a[water]; tag[touch]
#etcsl: line-id=B.B.7

8. munu₄-zu niŋ₂ šu bal nu-ak-dam
#lem: munu[malt]; niŋ[thing]; šu[hand]; bala[turn]; ak[do]
#etcsl: line-id=B.B.8

9. e₂-gal {d}suen-na lu₂ a-na-zu mu-un-zu
#lem: egal[palace]; Suen[1]DN; lu[person]; ana[what?]; zu[know]
#etcsl: line-id=B.B.9

10. al-la₂-e {{%akk i-na %akk e-ri-iš-tim}} gudug-e-ne-ka
#lem: la[hang]; L; L; gudug[priest]
#etcsl: line-id=B.B.10

11. {gi}ma-sa₂-ab ku₄-ku₄-dam asil₃-la₂ di-dam
#lem: masab[basket]; kur[enter]; asilala[joy]; di[speak]
#etcsl: line-id=B.B.11

12. e₂ dug₃-ge-da e₂ ŋa₂-ŋa₂-dam {{%akk šu-X-X-a-am}}
#lem: e[house]; dug[good]; e[house]; ŋar[put]; L
#etcsl: line-id=B.B.12

13. ki šu-luh kug-ga si sa₂-e-dam
#lem: ki[place]; šuluh[ritual cleansing]; kug[pure]; si[horn]; sa[equal]
#etcsl: line-id=B.B.13

14. {d#}nin-gal en-he₂-du₇-an-na-ŋu₁₀
#lem: Ningal[1]DN; Enheduana[1]PN
#etcsl: line-id=B.B.14

15. [...]-zu ki-bi hu-mu-na-gi₄-gi₄
#lem: X; ki[place]; gi[turn]
#etcsl: line-id=B.B.15

16. [...] {d}nanna mi₂ ga-e-dug₄
#lem: X; Nanna[1]DN; mi[cvne]; dug[speak]
#etcsl: line-id=B.B.16

17. [...] {d}suen mu-zu pa ga!-an-e₃
#lem: X; Suen[1]DN; mu[name]; pa[branch]; e[leave]
#etcsl: line-id=B.B.17

@div trailer 

18. [ŋiš]-gi₄#-ŋal₂-bi-im
#lem: ŋešgiŋal[musical refrain]
#etcsl: line-id=B.B.18

@end trailer

@end jicgijal

@div trailer 

19. [bal]-bal#-e {d}nanna-kam
#lem: balbale[literary subscript]; Nanna[1]DN
#etcsl: line-id=B.B.19

@end trailer

