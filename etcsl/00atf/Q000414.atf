&Q000414 = A dedication of a statue (Šulgi V)
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.4.2.22
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.4.2.22&display=Crit&charenc=gcirc#

1. {d}en-lil₂ ud e₃ ŠE₃ X dug₄-[ga-ni nu-kur₂-ra]
#lem: Enlil[1]DN; ud[sun]; e[leave]; X; X; dug[speak]; kur[different]
#etcsl: line-id=1

2. u₁₈!(MIR)-ru gal {d}a-nun-ke₄-ne [...]
#lem: urun[exalted]; gal[big]; Anunak[1]DN; X
#etcsl: line-id=2

3. {d}šul-gi ušum ni₂ guru₃# [...]
#lem: Šulgir[1]RN; ušum[snake]; ni[fear]; gur[lift]; X
#etcsl: line-id=3

4. lugal šu dug₄-ga-ni-ir IGI X X [... bar]
#lem: lugal[king]; šu[hand]; dug[speak]; X; X; X; X; bar[place outside]
#etcsl: line-id=4

5. ne gal-gal X [... šum₂]
#lem: ne[strength]; gal[big]; X; X; šum[give]
#etcsl: line-id=5

6. za-pa-ŋa₂-ni an ki [...]-bi-a ŋa₂-[ar-ŋa₂-ra]
#lem: zipaŋ[voice]; an[sky]; ki[place]; X; ŋar[put]
#etcsl: line-id=6

7. e₂-kur gal:muš idim-ma me X [...]
#lem: Ekur[1]TN; mušgal[serpent]; idim[spring]; me[Being]; X; X
#etcsl: line-id=7

8. dur-an-ki giri₁₇-zal-a me ul ba-bad nam#-[he₂]-ŋal₂#
#lem: Durankik[1]TN; kirizal[joy]; me[Being]; ul[distant time]; bad[open]; namheŋal[abundance]
#etcsl: line-id=8

9. šeg₁₂ nun ki ŋar-ra-ba {ŋiš}isimu₂{sar}-bi ud sud-sud-u₅
#lem: šeg[brick]; nun[prince]; ki[place]; ŋar[put]; isimu[stalk]; ud[sun]; sud[distant]
#etcsl: line-id=9

10. {d}šul-gi bal nam-he₂ ba-tud-da šag₄-ta gal mu-tar
#lem: Šulgir[1]RN; bala[turn]; namhe[abundance]; utud[give birth (to)]; šag[heart]; gal[big]; tar[cut]
#etcsl: line-id=10

11. uŋ₃ gu₃ teš₂-a sig₁₀-i₃
#lem: uŋ[people]; gu[voice]; teš[unity]; sig[put into]
#etcsl: line-id=11

12. su₃-ud-bi lugal šar₂-ra-ba-ke₄
#lem: sud[distant]; lugal[king]; šar[numerous]V/i
#etcsl: line-id=12

13. dub₃-tuku ud mar-uru₅ zag-še-ni nu-til-e
#lem: dubtuku[runner]; ud[storm]; marru[stormwind]; zagše[shoulder]; til[complete]
#etcsl: line-id=13

14. kaš₄ a₂-dam-a₂-dam-ta e₃-a
#lem: kaš[run]; adam[habitation]; e[leave]
#etcsl: line-id=14

15. hu-luh-e kaš₄-kaš₄-e huš-ZA-am₃#
#lem: huluh[frightened]; kaš[run]; huš[reddish]
#etcsl: line-id=15

16. uŋ₃-ta igi saŋ₅-ŋa₂ u₃-su-bi saŋ X [...]
#lem: uŋ[people]; igi[eye]; saŋ[choose]; usu[strength]; saŋ[head]; X; X
#etcsl: line-id=16

17. a₂ an-ba₉-ra₂-a bar-ra-ni-še₃ [...]
#lem: a[arm]; bad[open]; bar[outside]; X
#etcsl: line-id=17

18. {d}šul-gi niŋ₂ kaš₄ HU an-ur₂-ta ŋa₂-ŋa₂-ŋa₂-dam# [...]
#lem: Šulgir[1]RN; niŋ[thing]; kaš[run]; X; anur[horizon]; ŋar[put]; X
#etcsl: line-id=18

19. nam a-nun-ŋal₂-la-ne₂-eš a₂-na [...] NI# |ŠU.KAD₄|-|ŠU.KAD₄|-e
#lem: nam[fate]; anunŋal[strong]; a[arm]; X; X; X
#etcsl: line-id=19

20. nu-kuš₂-u₅ kaskal-e NE X DI-DI
#lem: kušu[tired]; kaskal[way]; X; X; X
#etcsl: line-id=20

21. saŋ gig₂-ga!(I)-a lugal na-me saŋ nu-sig₁₀ di [gal]-še₃ na-an-ŋar
#lem: saŋ[head]; giggig[black]; lugal[king]; name[any]; saŋ[head]; sig[put into]; did[lawsuit]; gal[big]; ŋar[put]
#etcsl: line-id=21

22. ud giri₁₇-zal-a-aš e₃-a dungu šeŋₓ(|IM.A|)-ka ŋar-ra
#lem: ud[sun]; kirizal[joy]; e[leave]; dungu[cloud]; šeŋ[rain]; ŋar[put]
#etcsl: line-id=22

23. nibru{ki} ki-ur₃-ta na-kaš₄
#lem: Nibru[1]SN; Kiʾur[1]; kaš[run]
#etcsl: line-id=23

24. eš₃ urim₂{ki} e₂-temen-ni₂-guru₃-še₃
#lem: eš[shrine]; Urim[1]SN; Etemenniguru[1]TN
#etcsl: line-id=24

25. {d}nanna unu₂ kiŋ₂-nim bur nun sug₂-ga-ni sa₂ UL nam-mi-in-dug₄
#lem: Nanna[1]DN; unu[dwelling]; kiŋnim[morning meal]; bur[(stone) bowl]; nun[prince]; sug[stand]; sa[equal]; X; dug[speak]
#etcsl: line-id=25

26. ud ne-[...]-a nam#-he nam im-mi-in-tar
#lem: ud[sun]; nen[this]; namhe[abundance]; nam[fate]; tar[cut]
#etcsl: line-id=26

27. {tum₉}GAN₂-|HI×NUN|-ME-U {tum₉#}dal-ha-mu šu ba-ra-am₃
#lem: GAN₂.HI×NUN.ME.U[violent south wind]; dalhamun[dust storm]; šu[hand]; bar[place outside]
#etcsl: line-id=27

28. {d}utu-e sig#-ge-eš₂# nam-ši-X
#lem: Utu[1]DN; sig[weak]; X
#etcsl: line-id=28

29. a-ne e₂-kur za-gin₃-še₃ na-gur
#lem: ane[he]; Ekur[1]TN; zagin[lapis lazuli]; gur[turn]
#etcsl: line-id=29

30. ud til₃-la-še₃ ur-saŋ-e-ne-e
#lem: ud[sun]; til[live (of a single person)]; ursaŋ[warrior]
#etcsl: line-id=30

31. {d}šul-gi-ra nam#-mah gal-gal-la-ni a-re-eš₂ pad₃-de₃-de₃
#lem: Šulgir[1]RN; nammah[greatness]; gal[big]; ar[celebrate]; pad[find]
#etcsl: line-id=31

32. X alan ud su₃-ra₂ mu da-ri₂-ka-na
#lem: X; alan[image]; ud[sun]; sud[distant]; mu[name]; dari[eternal]
#etcsl: line-id=32

33. mul-an-ne₂-eš₂ bi₂-in-gun₃
#lem: mulan[heavenly star]; gunu[speckled]
#etcsl: line-id=33

34. a-a {d}en-lil₂ mah-di nu-kur₂-ra#
#lem: aya[father]; Enlil[1]DN; mahdi[exalted]; kur[different]
#etcsl: line-id=34

35. igi dug₃ niŋ₂ giri₁₇-zal si-a-ni-še₃ nam-nun-na mi-ni-in-gub
#lem: igi[eye]; dug[good]; niŋ[thing]; kirizal[joy]; si[fill]; namnun[magnificence]; gub[stand]
#etcsl: line-id=35






