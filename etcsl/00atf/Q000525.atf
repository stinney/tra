#lem: diŋir[deity]; gub[stand]; lammar[(female) tutelary deity]; abzu[(cosmic) underground water]; lu[person]; iŋar[oracular utterance]; sag[good]; me[be]; X; X; X; ud[sun]; dari[eternal]
