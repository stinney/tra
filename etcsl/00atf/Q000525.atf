#lem: Utu[1]DN; did[lawsuit]; gin[confirm]; dab[seize]
#etcsl: line-id=16

17. X X X šar₂-ra niŋ₂-gen₆ mu sa₄ X X X X [...]
#lem: X; X; X; šar[numerous]V/i; niŋgina[truth]; mu[name]; še[call by name]; X; X; X; X; X
#etcsl: line-id=17

18. sa-am-su-i-lu-na lugal inim sag₉-sag₉-ge {d}utu-kam#-[me]-en#
#lem: Samsuʾiluna[01]; lugal[king]; inim[word]; sag[good]; Utu[1]DN
#etcsl: line-id=18

19. lugal-e-ne saŋ-kal-bi# he₂-me-en
#lem: lugal[king]; saŋkal[foremost]; me[be]
#etcsl: line-id=19

20. kur gu₂-erim₂-ŋal₂-la-zu ud huš-gin₇# du₇-zu-[ne]
#lem: kur[mountain(s)]; guʾerimŋal[hostile]; ud[storm]; huš[reddish]; du[push]
#etcsl: line-id=20

21. lugal gu₂ an-še₃ he₂-ni-zig₃
#lem: lugal[king]; gu[neck]; an[sky]; zig[rise]
#etcsl: line-id=21

22. sa-am-su-i-lu-na gu₂ an-še₃ he-ni-zig₃
#lem: Samsuʾiluna[01]; gu[neck]; an[sky]; zig[rise]
#etcsl: line-id=22

23. babilim₂{ki} iri me {d}suen-na-ka nam-gal-zu# ud-gin₇ pa he₂-ni-ib₂-e₃
#lem: Babilim[1]; iri[city]; me[Being]; Suen[1]DN; namgal[greatness]; ud[sun]; pa[branch]; e[leave]
#etcsl: line-id=23

