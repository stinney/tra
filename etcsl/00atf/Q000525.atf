#lem: Asari[1]DN; ensik[ruler]; gal[big]; abzu[(cosmic) underground water]; kur[mountain(s)]; kilib[total]; na[cvne]; deg[gather up]; X; nirŋal[authoritative]; Eridug[1]SN
#etcsl: line-id=31

32. diŋir X-ra-na kilib₃-ŋal₂ X [...]-e-ne-ke₄ mu dug₃-ga he₂-bi₂-ib₂-sa₄ a₂ nun gal-zu he₂-a
#lem: diŋir[deity]; X; kilibŋal[assembly]; X; X; mu[name]; dug[good]; še[call by name]; a[arm]; nun[prince]; gal[big]; me[be]
#etcsl: line-id=32

