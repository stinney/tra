#lem: sisi[horse]; harran[route]; kun[tail]; sud[distant]
#etcsl: line-id=17

18. maš₂-tarah-gin₇ kaš₄-kaš₄-e X X X [...]
#lem: mašdurah[young wild goat?]; kaš[run]; X; X; X; X
#etcsl: line-id=18

19. du₁₀-ub šu bar-ra nu-kuš₂-u₃ [...]
#lem: dub[knee]; šu[hand]; bar[place outside]; kušu[tired]; X
#etcsl: line-id=19

20. dumu niŋ₂ tum₂-tum₂ {d}en-lil₂-la₂-ka
#lem: dumu[child]; niŋ[thing]; tum[carry]; Enlil[1]DN
#etcsl: line-id=20

21. niŋ₂ šag₄ hul₂-hul₂ {d}nin-lil₂-la₂-ka
#lem: niŋ[thing]; šag[heart]; hul[rejoice]; Ninlil[1]DN
#etcsl: line-id=21

22. lugal-e eš₃ za-gin₃-na-še₃ muš₃ la-ba-ra-tum₂-mu
#lem: lugal[king]; eš[shrine]; zagin[lapis lazuli]; muš[face]; tum[bring]
#etcsl: line-id=22

23. ud-ba {d}iš-me-{d}da-gan {urud}alan mir-re-e kaš₄-kaš₄-e hu-luh-ha-na
#lem: ud[sun]; Išmedagan[1]RN; alan[image]; mir[north wind]; kaš[run]; huluh[frightened]
#etcsl: line-id=23

24. e₂-ni₂-guru₃ barag kal-kal-la#-na
#lem: Eniguru[1]TN; barag[sanctum]; kal[rare]
#etcsl: line-id=24

25. mu-ni-in-gub še-er-zid-de₃-eš bi₂-in-gun₃
#lem: gub[stand]; šerzid[radiance]; gunu[speckled]
#etcsl: line-id=25

26. nun gal zag an-na en dug₄-ga nu-kam₃-me-da
#lem: nun[prince]; gal[big]; zag[side]; an[sky]; en[lord]; dug[speak]; kam[alter]
#etcsl: line-id=26

27. saŋ-ki zalag igi zid il₂-la-na <<ŠE₃>>
#lem: saŋki[forehead]; zalag[bright]; igi[eye]; zid[right]; il[raise]
#etcsl: line-id=27

28. he₂-en-ši-ni-ŋal₂ sipad zid tud-da-ni-še₃
#lem: ŋal[⟦be⟧ to be (there]; sipad[shepherd]; zid[right]; utud[give birth (to)]
#etcsl: line-id=28

29. lugal a₂ niŋ₂-hul dim₂-ma ib₂-ši-aŋ₂-e-a
#lem: lugal[king]; a[arm]; niŋhulu[evil]; dim[create]; aŋ[measure]
#etcsl: line-id=29

30. mu-sar-ra-ba šu bi₂-ib₂-ra-a mu-ni bi₂-ib₂-sar-a
#lem: musara[inscription]; šu[hand]; rah[beat]; mu[name]; sar[write]
#etcsl: line-id=30

31. aš₂ bal-a-ba-ke₄-eš lu₂-kur₂ šu ba-an-zi-zi-i-a
#lem: aš[curse]; bala[turn]; lukur[stranger]; šu[hand]; zig[rise]
#etcsl: line-id=31

32. lu₂-ba {d}en-lil₂ lugal-ŋu₁₀ {d}nin-lil₂ nin-ŋu₁₀ nam ha-ba-an-da#-[ku₅-ru-ne]
#lem: lu[person]; Enlil[1]DN; lugal[king]; Ninlil[1]DN; nin[lady]; nam[fate]; kud[cut]
#etcsl: line-id=32

33. {d}en-ki {d}iškur {d}ezina₂ {d}šakkan₂ en he₂-ŋal₂-la-ke₄#-[ne]
#lem: Enkik[1]DN; Iškur[1]DN; Ezina[1]DN; Šakkan[1]DN; en[lord]; heŋal[plenty]
#etcsl: line-id=33

34. he₂-ŋal₂ an ki-a a-ba-da-an-gi₄-eš hul#-bi ha-ba-[...]
#lem: heŋal[plenty]; an[sky]; ki[place]; gi[turn]; hulu[bad]; X
#etcsl: line-id=34






