&Q000639 = A tigi to Inana (Dumuzid-Inana H)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.4.08.08
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.4.08.08&display=Crit&charenc=gcirc#

@div segment A

@div sa-gida A

1. %e ga-ša-an-ŋen %s ša-ga-ba-ta ud zal-la-ŋu₁₀-ne {{%akk iš-tu %akk am-ša-li %akk i-na %akk šum-ṣu₂-li-ya}}
#lem: gašan[lady]N; šaduga[yesterday?]; ud[sun]; zal[pass time]; L; L; L; L
#etcsl: line-id=A.A.1

2. %e ga-ša-an-an-na-ŋen %s ša-ga-ba-ta ud zal-la-ŋu₁₀-ne
#lem: Gašanana[]DN; šaduga[yesterday?]; ud[sun]; zal[pass time]
#etcsl: line-id=A.A.2

3. ud zal-la-ŋu₁₀-ne e-ne %e di-da-ŋu₁₀-ne
#lem: ud[sun]; zal[pass time]; ene[pleasure?]; de[go]
#etcsl: line-id=A.A.3

4. ud zal ŋi₆ sa₂-a-še₃ en₃-du dug₄-ga-ŋu₁₀-ne {{%akk i-na %akk šum-ṣu₂-lim %akk u₃ %akk šum-ši#-im#}}
#lem: ud[sun]; zal[pass time]; ŋi[night]; sa[equal]; endu[song]; dug[speak]; L; L; L; L
#etcsl: line-id=A.A.4

5. gaba mu-un-ri gaba mu-un-ri {{%akk im-hur-an-ni}}
#lem: gaba[breast]; ri[impose]; gaba[breast]; ri[impose]; L
#etcsl: line-id=A.A.5

6. %e u₃-mu-un %s gu₅-li an-na gaba mu-un-ri
#lem: umun[lord]N; guli[friend]; An[1]DN; gaba[breast]; ri[impose]
#etcsl: line-id=A.A.6

7. %e u₃-mu-un-e %s šu-ni-a šu im-ma-an-du₃ {{%akk ih-ṣi₂-in-an-ni}}
#lem: umun[lord]N; šu[hand]; šu[hand]; du[build]; L
#etcsl: line-id=A.A.7

8. {d}ušumgal-an-na gu₂-ŋa₂-a gu₂-da ba-an-la₂ {{%akk ki-ša-di %akk i-di-ir}}
#lem: Ušumgalana[1]DN; gu[neck]; gu[neck]; la[hang]; L; L
#etcsl: line-id=A.A.8

9. me-a-am šu ba-mu-u₈ e₂-me-še₃  %e  da-ŋen  %s 
#lem: meʾam[term of endearment]; šu[hand]; ba[allot]; e[house]; ŋen[go]
#etcsl: line-id=A.A.9

10. gu₅-li  %e  {d}mu-ul-lil₂-la₂  %s  šu ba-mu-u₈ e₂-me#-še₃  %e  da-ŋen  %s 
#lem: guli[friend]; Mullil[1]DN; šu[hand]; ba[allot]; e[house]; ŋen[go]
#etcsl: line-id=A.A.10

11. ama-ŋu₁₀# lul-la-še₃ %e ta %s mu-na-ab-gub-be₂-en {{%akk mi-nam %akk az-za-as-si₂}}
#lem: ama[mother]; lul[false]; ta[what?]QP; gub[stand]; L; L
#etcsl: line-id=A.A.11

12. ama-ŋu₁₀#  %e  {d}ga-ša-an-gal-e  %s  lul-la-še₃ %e ta %s mu-na-ab-gub-be₂-en
#lem: ama[mother]; Gašangal[1]DN; lul[false]; ta[what?]QP; gub[stand]
#etcsl: line-id=A.A.12

13. ŋe₂₆-e ga-ri-ib-zu-zu ŋe₂₆-e ga-ri-ib-zu-zu {{%akk lu-uq-bi-ki}}
#lem: ŋaʾe[I]; zu[know]; ŋaʾe[I]; zu[know]; L
#etcsl: line-id=A.A.13

14. {d}inana lul-la munus-e-ne ŋe₂₆-e ga-ri-ib-zu-zu
#lem: Inanak[1]DN; lul[false]; munus[woman]; ŋaʾe[I]; zu[know]
#etcsl: line-id=A.A.14

15. ma-la-ŋu₁₀ sila daŋal-la e-ne %e mu-di-ni-ib-ma-ma %s {{%akk i-na %akk re-bi-tim %akk im-me-li-il}}
#lem: malag[female neighbor]; sila[street]; daŋal[wide]; ene[pleasure?]; mar[place]V/t; L; L; L
#etcsl: line-id=A.A.15

16. ub₃ sag₃!-sag₃ e-ne di-da hub₂ mu-di-ni-in-gub {{%akk i-na %akk up-pi %akk lu-pu-tim %akk i-na %akk me-lu-ul-tim %akk i-ra-[ap]-pu-ud}}
#lem: ub[drum]; sag[strike]; ene[pleasure?]; di[speak]; hub[foot]; gub[stand]; L; L; L; L; L; L
#etcsl: line-id=A.A.16

17. i-lu-ni %e ze₂-ba-am₃ %s ad mu-ši-ib-ša₄ {{%akk qu₂-be₂-e-ša# %akk ṭa-bu-tim %akk i-na-as-sa₃-as}}
#lem: ilu[lament]; zeb[good]V/i; ad[voice]; ša[cvve]; L; L; L
#etcsl: line-id=A.A.17

18. hul₂-hul₂-e %e ze₂-ba-am₃ %s ud mu-di-ni-ib-zal-e {{%akk it-ti-ša %akk uš-te-be₂-er-re}}
#lem: hul[rejoice]; zeb[good]V/i; ud[sun]; zal[pass time]; L; L
#etcsl: line-id=A.A.18

19. ama ugu-zu-ur₂ lul-la-še₃ za-e gub-bu-na-da
#lem: ama[mother]; ugu[bear]; lul[false]; zaʾe[you]; gub[stand]
#etcsl: line-id=A.A.19

20. me-en-de₃ iti₆-še₃ e-ne su₃-ud ga!-da-e {{%akk i-na %akk ri-ša-tim %akk i %akk nim-me-li-il#}}
#lem: menden[we]; itud[moon]; ene[pleasure?]; sud[distant]; dug[speak]; L; L; L; L
#etcsl: line-id=A.A.20

21. ki-nu₂ kug he-nun-na suh ga-mu-ra-du₈# {{%akk mu-uš-ṭa-ti-ki %akk lu-pa-ṭi-ir}}
#lem: kinud[sleeping quarter]; kug[purify]; henun[plenty]; suh[crown]; du[spread]; L; L
#etcsl: line-id=A.A.21

22. ud dug₃ nam-he₂-a hul₂-la hu-mu-u₃-di-ni-ib#-[zal-e] {{%akk li-ip-pu-uh₂}}
#lem: ud[sun]; dug[good]; namhe[abundance]; hul[rejoice]; zal[pass time]; L
#etcsl: line-id=A.A.22

@div trailer 

