#etcsl: line-id=55

56. |DU.DU|-e ba-ab-du₇-u₃
#lem: X; du[perfect]
#etcsl: line-id=56

57. barag mah-ha saŋ il₂-la-a ba-ab-du₇-me-en₃
#lem: barag[sanctum]; mah[great]; saŋ[head]; il[raise]; du[perfect]
#etcsl: line-id=57

58. {ŋiš}gu-za za-gin₃-na dur₂ ŋar-ra-a ba-ab-du₇-u₃
#lem: guza[chair]; zagin[lapis lazuli]; dur[buttocks]; ŋar[put]; du[perfect]
#etcsl: line-id=58

59. saŋ-zu men gun₃-a ba-ab-du₇-u₃
#lem: saŋ[head]; men[tiara]; gunu[speckled]; du[perfect]
#etcsl: line-id=59

60. bar-zu-še₃ {tug₂}zulumhi sud-de₃ ba-ab-du₇-u₃
#lem: bar[outside]; zulumhi[fleece]; sud[distant]; du[perfect]
#etcsl: line-id=60

61. tug₂ nam-lugal-la₂-ka šag₄ la₂-a ba-ab-du₇-u₃
#lem: tug[textile]; namlugal[kingship]; šag[heart]; la[hang]; du[perfect]
#etcsl: line-id=61

