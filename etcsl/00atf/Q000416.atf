&Q000416 = A praise poem of Šulgi (Šulgi X)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.4.2.24
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.4.2.24&display=Crit&charenc=gcirc#

1. lugal# ma₂ na-mu-u₅
#lem: lugal[king]; ma[ship]; u[ride]
#etcsl: line-id=1

2. [ki unug]{[ki]}-ge# me nam-nun-na-še₃
#lem: ki[place]; Unug[1]SN; me[Being]; namnun[magnificence]
#etcsl: line-id=2

3. [ki-en]-gi ki-uri u₆ mu-e
#lem: Kengir[1]; Akkad[1 Akkad]; u[admiration]; e[speak]
#etcsl: line-id=3

4. kar! kul-ab₄{ki}-ba-ke₄ ma₂ na-ga-am₃-mi-in-us₂
#lem: kar[harbor]; Kulaba[1]SN; ma[ship]; us[accompany]
#etcsl: line-id=4

5. am gal hur-saŋ-ŋa₂ a₂ il₂-il₂-la-da
#lem: am[wild bull]; gal[big]; hursaŋ[mountain]; a[arm]; il[raise]
#etcsl: line-id=5

6. udu en zid-de₃ šu-a la₂-a-da
#lem: udu[sheep]; en[priest]; zid[right]; šu[hand]; la[hang]
#etcsl: line-id=6

7. maš₂ su₄ maš₂ za la₂ gaba-a tab-ba-da
#lem: maš[goat]; su[red]; maš[goat]; sum[beard]; la[hang]; gaba[breast]; tab[double]
#etcsl: line-id=7

8. {d}inana-ra eš₃ e₂-an-na-ka mu-na-da-an-ku₄-ku₄-u₃
#lem: Inanak[1]DN; eš[shrine]; Eanak[1]TN; kur[enter]
#etcsl: line-id=8

9. sipad zid šul-gi-re šag₄ ki aŋ₂ tug₂-ba₁₃ tug₂ mu-mur₁₀
#lem: sipad[shepherd]; zid[right]; Šulgir[1]RN; šag[heart]; ki[place]; aŋ[measure]; ba[garment]; tug[textile]; mur[dress]
#etcsl: line-id=9

10. hi-li men-še₃ saŋ-ŋa₂ mi-ni-ŋal₂
#lem: hili[attractiveness]; men[tiara]; saŋ[head]; ŋal[⟦be⟧ to be (there]
#etcsl: line-id=10

11. {d}inana-ke₄ u₆ mu-ni-dug₄
#lem: Inanak[1]DN; u[admiration]; dug[speak]
#etcsl: line-id=11

12. ni₂-te-ni-še₃ šir₃ ba-ši-ni-ra
#lem: ni[self]; šir[sing]; rah[beat]
#etcsl: line-id=12

13. en₃-du-še₃! im-e
#lem: endu[song]; e[speak]
#etcsl: line-id=13

14. lugal-ra %e u₃-mu-un-ra
#lem: lugal[king]; umun[lord]N
#etcsl: line-id=14

15. a mu-na-tu₁₇-a-gin₇
#lem: a[water]; tu[cvve]
#etcsl: line-id=15

16. %e su-ba %e du₅-mu-zid-ra %s a mu-na-tu₁₇-a-gin₇
#lem: subad[shepherd]N; Dumuzid[1]DN; a[water]; tu[cvve]
#etcsl: line-id=16

17. im da-ŋu₁₀ šu tag-ge₄ dug₄-ga-gin₇
#lem: im[clay]; dag[side]; šu[hand]; tag[touch]; dug[speak]
#etcsl: line-id=17

18. %e u₃ %s šembulugₓ(|ŠIM×UH₃|)-ga ka-ŋu₁₀ gun₅-gun₅-na-gin₇
#lem: u[oil]N; bulug[a resin]; kag[mouth]; gunu[speckled]
#etcsl: line-id=18

19. šembi₂-zid i₃-bi₂-ŋa₂ %e mi-ni-mar-mar-ra-gin₇
#lem: šembizida[kohl]; igi[eye]; mar[place]V/t
#etcsl: line-id=19

20. šu %e na-aŋ₂-sag₉-ga-na-ka
#lem: šu[hand]; naŋsag[pleasure]
#etcsl: line-id=20

21. ib₂-ib₂-ŋu₁₀ mi-ni-dim₂-dim₂-ma₃-gin₇
#lem: ib[hips]; dim[create]
#etcsl: line-id=21

22. %e u₃-mu-un %s i₃-nu₂ kug {d}inana{na}-še₃
#lem: umun[lord]N; nud[lie down]; kug[purify]; Inanak[1]DN
#etcsl: line-id=22

23. %e su-ba %e du₅-mu-zid-de₃
#lem: subad[shepherd]N; Dumuzid[1]DN
#etcsl: line-id=23

24. ur₂-ra ga i₃-du₈-a-na-gin₇
#lem: ur[root]; ga[milk]; du[spread]
#etcsl: line-id=24

25. X IM a₂ gi-rin-ŋa₂ GI₄ in-tenₓ(GUR₈)-tenₓ(GUR₈)-na-gin₇
#lem: X; X; a[arm]; girim[flower]; X; ten[extinguish]
#etcsl: line-id=25

26. [...] X saŋ kaš! saŋ-gin₇
#lem: X; X; saŋ[head]; kaš[beer]; saŋ[head]
#etcsl: line-id=26

27. %e mu-uš %s mu-tag-ga-gin₇
#lem: meš[penis]N; tag[touch]
#etcsl: line-id=27

28. siki-ur₂-ŋu₁₀ ŋa₂-an-suh₃#-[suh₃-a-gin₇]
#lem: sikiʾur[pubic hair]; suh[confuse]
#etcsl: line-id=28

29. siki-pa-ŋu₁₀ a-ne in-da-an-dug₄-ga-gin₇
#lem: sikipa[head hair]; ene[pleasure?]; dug[speak]
#etcsl: line-id=29

30. gal₄ kug-ŋa₂ šu %e bi₂-in-ma-ra-gin₇
#lem: gala[female genitals]; kug[pure]; šu[hand]; mar[place]V/t
#etcsl: line-id=30

31. šag₄ %e ze₂-ba-ŋa₂ %s u₃ [...] X-bi i₃-X-nu₂#-a-gin₇
#lem: šag[heart]; zeb[good]V/i; u[sleep]; X; X; nud[lie down]
#etcsl: line-id=31

32. ma₂ MI-ni-gin₇ mu-X-[...]-AN#-gin₇
#lem: ma[ship]; X; X
#etcsl: line-id=32

33. ma₂ sal-la-ni-gin₇ mu-un-til-til-la-gin₇
#lem: ma[ship]; sal[thin]; til[complete]
#etcsl: line-id=33

34. ki-nu₂-a mi₂ ŋa₂-ni-dug₄-ga-a-gin₇
#lem: kinud[sleeping quarter]; mi[cvne]; dug[speak]
#etcsl: line-id=34

35. %e u₃-mu-un-ra %s mi₂  %e  da-an-dug₄  %s 
#lem: umun[lord]N; mi[cvne]; dug[speak]
#etcsl: line-id=35

36. %e na-aŋ₂ ze₂-eb₂ %s du₁₀-mu-ni-ib₂-tar{ar}
#lem: naŋ[fate]N; zeb[good]V/i; tar[cut]
#etcsl: line-id=36

37. sipad zid šul-gi-ra mi₂  %e  da-an-dug₄  %s 
#lem: sipad[shepherd]; zid[right]; Šulgir[1]RN; mi[cvne]; dug[speak]
#etcsl: line-id=37

38. %e na-aŋ₂ ze₂-eb₂ %s du₁₀-mu-ni-ib₂-tar{ar}
#lem: naŋ[fate]N; zeb[good]V/i; tar[cut]
#etcsl: line-id=38

39. a₂-gar₃-ra-na mi₂-eš₂  %e  da-an-dug₄  %s 
#lem: X; mi[cvne]; dug[speak]
#etcsl: line-id=39

40. %e na-aŋ₂-sipad %s kur-kur-ra
#lem: naŋsipad[shepherdship]; kur[mountain(s)]
#etcsl: line-id=40

41. %e na-aŋ₂-še₃ %s du₁₀-mu-ni-ib₂-tar{ar}
#lem: naŋ[fate]N; tar[cut]
#etcsl: line-id=41

42. nin su₃-ra₂-aŋ₂ an-na
#lem: nin[lady]; sudaŋ[precious metal or material (possibly amber)]; an[sky]
#etcsl: line-id=42

43. hi-li saŋ gig₂-ga
#lem: hili[attractiveness]; saŋ[head]; giggig[black]
#etcsl: line-id=43

44. munus šul-la ama-ni-ra dirig-ga
#lem: munus[woman]; šul[youth]; ama[mother]; dirig[make more than]
#etcsl: line-id=44

45. a-a-ni me ba-a
#lem: aya[father]; me[Being]; ba[allot]
#etcsl: line-id=45

46. {d}inana dumu {d}suen-na-ke₄
#lem: Inanak[1]DN; dumu[child]; Suen[1]DN
#etcsl: line-id=46

47. šul-gi dumu {d}nin-sumun₂-ka-ra
#lem: Šulgir[1]RN; dumu[child]; Ninsumunak[1]DN
#etcsl: line-id=47

48. nam mu-ni-ib₂-tar-re
#lem: nam[fate]; tar[cut]
#etcsl: line-id=48

49. me₃-a igi-še₃ ŋen-zu ŋe₂₆-me-en₃
#lem: me[battle]; igi[eye]; ŋen[go]; ŋaʾe[I]
#etcsl: line-id=49

50. šen-šen-na kuš₇-gin₇ tukul la₂-zu-me-en₃
#lem: šen[battle]; kuš[high official]; tukul[weapon]; la[hang]
#etcsl: line-id=50

51. unken-na ka-mud-ŋal₂-zu-me-en₃
#lem: unkin[assembly]; kamudŋal[advocate]
#etcsl: line-id=51

52. har-ra-an-na zi-šag₄-ŋal₂-zu ŋe₂₆-me-en
#lem: harran[route]; zišagŋal[encouragement]; ŋaʾe[I]
#etcsl: line-id=52

53. sipad šag₄-ge pad₃-da X kug-ga-me-en₃
#lem: sipad[shepherd]; šag[heart]; pad[find]; X; kug[pure]
#etcsl: line-id=53

54. lugal u₂-a zid e₂-an-na-me-en₃
#lem: lugal[king]; ua[provisioner]; zid[right]; Eanak[1]TN
#etcsl: line-id=54

55. šuba₃ iri₁₂-gal an-na-me-en₃
