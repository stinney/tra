#etcsl: line-id=1.16

1.17. lu₂ dili gu₇-u₃-gin₇ igi tur mu-un-gid₂-i-eš
#lem: lu[person]; dili[single]; gu[eat]; igi[eye]; tur[small]; gid[long]
#etcsl: line-id=1.17

1.18. ama ugu-ŋu₁₀ ud-sakar (1:ubur-ra-bi:1)
#lem: ama[mother]; ugu[skull]; udsakar[crescent moon]; ubur[breast]
#etcsl: line-id=1.18

:18v.1.1: (#note: 1 ms. has instead:#) ubur-a-gin₇
#lem: ubur[breast]

1.19. dug₃-ge-eš ga-ŋu₁₀ gu₇-ŋu₁₀ ka-ŋu₁₀-ta ba-an-kar
#lem: dug[good]; ga[milk]; gu[eat]; kag[mouth]; kar[flee]
#etcsl: line-id=1.19

1.20. a-a-ŋu₁₀ šag₄ ur₂-bi-ta guru₃-gur₃-ru-a ki-ta ba-an-ŋar-re-en
#lem: aya[father]; šag[heart]; ur[root]; gur[lift]; ki[place]; ŋar[put]
#etcsl: line-id=1.20

1.21. nin arhuš-a-ŋu₁₀ e₂-bi ba-kal igi nu-mu-un-ši-bar-re
#lem: nin[lady]; arhuš[compassion]; e[house]; kal[rare]; igi[eye]; bar[place outside]
#etcsl: line-id=1.21

1.22. ŋiš hul gurun nu-il₂-la-gin₇ lu₂ na-ma-ši-hul₂-le
#lem: ŋeš[tree]; hulu[bad]; gurun[fruit]; il[raise]; lu[person]; hul[rejoice]
#etcsl: line-id=1.22

1.23. |GIŠ.BIL₂|-|GIŠ.BIL₂|-me-en {ŋiš}isimu₂{sar} nu-tuku-me-en HAR-re nam-ba-tum₂-un
#lem: GIŠ.NE@s[fresh fruit]; isimu[stalk]; tuku[acquire]; X; tum[bring]

#etcsl: line-id=1.23

1.24. lugal-ŋu₁₀ en₃-ŋu₁₀ he₂-tar-re ki-ur₃-ŋu₁₀-še₃ he₂-em-mi-ib-gi₄-gi₄-in
#lem: lugal[king]; en[cvne]; tar[cut]; kiʾur[foundation]; gi[turn]
#etcsl: line-id=1.24

