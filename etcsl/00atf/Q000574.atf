@div version 1 (Version A (from Nibru))

1.1. lugal zalag-ga-ni iti₆-gin₇ kur-kur-ra pa e₃-a
#lem: lugal[king]; zalag[bright]; itud[moon]; kur[mountain(s)]; pa[branch]; e[leave]
#etcsl: line-id=1.1

1.2. u₃-na-dug₄
#lem: dug[speak]
#etcsl: line-id=1.2

1.3. lugal {d}utu-gin₇ di si sa₂ kud-kud-de₃# eš-bar {d}ištaran-gin₇ si sa₂-sa₂-e-ra
#lem: lugal[king]; Utu[1]DN; did[lawsuit]; si[horn]; sa[equal]; kud[cut]; ešbar[decision]; Ištaran[1]DN; si[horn]; sa[equal]
#etcsl: line-id=1.3

1.4. lugal šudu₃-de₃ ŋiš tuku-ŋu₁₀-ur₂ u₃-na-de₃-tah
#lem: lugal[king]; šud[prayer]; ŋeš[tree]; tuku[acquire]; tah[add]
#etcsl: line-id=1.4

1.5. (1:{m}lugal-nesaŋ-e:1) dumu nibru{ki} arad₂-zu na-ab-be₂-a
#lem: Lugalnesaŋe[1]PN; dumu[child]; Nibru[1]SN; arad[slave]; e[speak]
#etcsl: line-id=1.5

:5v.1.1: (#note: 3 mss. have instead:#) {m}lugal-šu₂
#lem: Lugalšu[1]PN

1.6. udu-gin₇ ka u₂ gu₇-ŋu₁₀ mu-e-pad₃ naŋa dub₂-ba i-ni-bad
#lem: udu[sheep]; kag[mouth]; u[plant(s)]; gu[eat]; pad[find]; naŋa[potash]; dub[tremble]; bad[open]
#etcsl: line-id=1.6

1.7. gud {ŋiš}šudul₄-a nu-ub-ha-za la₂-gin₇ edin-na ba-ab-ŋen-ne-en
#lem: gud[bull]; šudul[yoke]; haza[hold]; la[hang]; eden[back]; ŋen[go]
#etcsl: line-id=1.7

1.8. ab₂ amar-bi nu-ub-da-la₂-a-gin₇ gu₃ arhuš-a im-me
#lem: ab[cow]; amar[calf]; la[hang]; gu[voice]; arhuš[compassion]; dug[speak]
#etcsl: line-id=1.8

1.9. u₈ sila₄-bi e₂-ubur-ra dab₅-ba-gin₇ šu-ni ba-ab-dab₅-be₂
#lem: u[sheep]; sila[lamb]; eʾuburak[animal pen]; dab[seize]; šu[hand]; dab[seize]
#etcsl: line-id=1.9

1.10. mušen-gin₇ gud₃-ŋa₂ lu₂ šu ba-ni-in-ti
#lem: mušen[bird]; gud[nest]; lu[person]; šu[hand]; teŋ[approach]
#etcsl: line-id=1.10

#note: 1 ms. omits lines 10-12

1.11. {ŋiš}ma₂ kar gen₆-na-a li-bi₂-ib-taka₄-a-gin₇ tum₉-e ba-ab-dirig-ge
#lem: ma[ship]; kar[harbor]; gin[confirm]; taka[set aside]; tumu[wind]; dirig[make more than]
#etcsl: line-id=1.11

1.12. i-si-iš sila nibru{ki}-ka mu-gu₇-e-en
#lem: isiš[tears]; sila[street]; Nibru[1]SN; gu[eat]
#etcsl: line-id=1.12

