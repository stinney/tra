29. lugal-ŋu₁₀ kul-aba₄{ki#}-še₃ na-ŋen#
#lem: lugal[king]; Kulaba[1]SN; ŋen[go]
#etcsl: line-id=29

30. {d}nin-iri₁₂-gal-ke₄# hul₂-la-a
#lem: Ninirigalak[1]DN; hul[rejoice]
#etcsl: line-id=30

31. {d}šul-gi-re [kul]-aba₄{ki}-še₃ na-ŋen
#lem: Šulgir[1]RN; Kulaba[1]SN; ŋen[go]
#etcsl: line-id=31

32. {d}nin-iri₁₂-gal-[ke₄] hul₂-la-a
#lem: Ninirigalak[1]DN; hul[rejoice]
#etcsl: line-id=32

33. lugal-ŋu₁₀# [ki] zabalam₂#{ki}-še₃ na-ŋen
#lem: lugal[king]; ki[place]; Zabalam[1]SN; ŋen[go]
#etcsl: line-id=33

34. [...] {[d]}inana-ke₄ hul₂-la-a
#lem: X; Inanak[1]DN; hul[rejoice]
#etcsl: line-id=34

35. {[d]}šul#-gi-re ki zabalam₂#{ki}-še₃ na-ŋen
#lem: Šulgir[1]RN; ki[place]; Zabalam[1]SN; ŋen[go]
