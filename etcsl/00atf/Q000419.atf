&Q000419 = A song of Šulgi
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.4.2.a
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.4.2.a&display=Crit&charenc=gcirc#

1. X šag₄#-ta kug-ga X [...] e₃#
#lem: X; šag[heart]; kug[pure]; X; X; e[leave]
#etcsl: line-id=1

2. [...] X kalam-ma [...] ki hul₂ [...]
#lem: X; X; kalam[the Land (of Sumer)]; X; ki[place]; hul[rejoice]; X
#etcsl: line-id=2

3. [...] X X X X X X [...] X KI X X
#lem: X; X; X; X; X; X; X; X; X; X; X; X
#etcsl: line-id=3

4. [...] X dug₄-ga [...] X NA X X
#lem: X; X; dug[speak]; X; X; X; X; X
#etcsl: line-id=4

5. [lugal]-ŋu₁₀ eridug{ki}-še₃ na-ŋen
#lem: lugal[king]; Eridug[1]SN; ŋen[go]
#etcsl: line-id=5

6. nun# [gal] a-a {d}en-ki hul₂-la-a#
#lem: nun[prince]; gal[big]; aya[father]; Enkik[1]DN; hul[rejoice]
#etcsl: line-id=6

7. {d}šul-gi#-re eridug{[ki]}-še₃ na-[ŋen]
#lem: Šulgir[1]RN; Eridug[1]SN; ŋen[go]
#etcsl: line-id=7

8. nun gal [a]-a {[d]}en#-ki hul₂-la-a#
#lem: nun[prince]; gal[big]; aya[father]; Enkik[1]DN; hul[rejoice]
#etcsl: line-id=8

9. lugal-ŋu₁₀# nibru#{ki}-še₃ na-ŋen#
#lem: lugal[king]; Nibru[1]SN; ŋen[go]
#etcsl: line-id=9

10. kur gal a-a# {[d]}[en]-lil₂ hul₂-la-a
#lem: kur[mountain(s)]; gal[big]; aya[father]; Enlil[1]DN; hul[rejoice]
#etcsl: line-id=10

11. {d}šul-gi-re# nibru#{ki}-še₃ na-ŋen
#lem: Šulgir[1]RN; Nibru[1]SN; ŋen[go]
#etcsl: line-id=11

12. kur gal a-a {d}en-lil₂ hul₂-la-a
#lem: kur[mountain(s)]; gal[big]; aya[father]; Enlil[1]DN; hul[rejoice]
#etcsl: line-id=12

13. lugal-ŋu₁₀ e₂-šu-[me]-ša₄#-še₃ na-ŋen
#lem: lugal[king]; Ešumeša[1]TN; ŋen[go]
#etcsl: line-id=13

14. en {d}nin-[urta]-ke₄ hul₂-la-a
#lem: en[lord]; Ninurtak[1]DN; hul[rejoice]
#etcsl: line-id=14

15. {d}šul-gi-re# e₂-šu-me-ša₄#-še₃ na-ŋen
#lem: Šulgir[1]RN; Ešumeša[1]TN; ŋen[go]
#etcsl: line-id=15

16. en# {d}nin-urta#-ke₄ hul₂-la-NI#
#lem: en[lord]; Ninurtak[1]DN; hul[rejoice]
#etcsl: line-id=16

17. lugal-ŋu₁₀ keš₃#{ki}-še₃# [na-ŋen]
#lem: lugal[king]; Keš[1]SN; ŋen[go]
#etcsl: line-id=17

18. {d}nin-sumun₂-zid#-gal-an-na# [hul₂-la-a]
#lem: Ninsumunzidgalanak[1]DN; hul[rejoice]
#etcsl: line-id=18

19. {d}šul#-[gi]-re# keš₃{ki#}-[še₃ na-ŋen]
#lem: Šulgir[1]RN; Keš[1]SN; ŋen[go]
#etcsl: line-id=19

20. {d}[nin]-sumun₂#-zid-gal-an-na# [hul₂-la-a]
#lem: Ninsumunzidgalanak[1]DN; hul[rejoice]
#etcsl: line-id=20

21. lugal-ŋu₁₀# urim₂-še₃ na-[ŋen]
#lem: lugal[king]; Urim[1]SN; ŋen[go]
#etcsl: line-id=21

22. en {d}[dil]-im₂#-babbar hul₂#-[la-a]
#lem: en[lord]; Dilimbabbar[1]DN; hul[rejoice]
#etcsl: line-id=22

# sjt collate im₂ here and in 24: original text had im₄

23. {d}šul-gi-re# [urim₂]{[ki]}-[še₃ na-ŋen]
#lem: Šulgir[1]RN; Urim[1]SN; ŋen[go]
#etcsl: line-id=23

24. en {d}dil-im₂#-[babbar hul₂-la-a]
#lem: en[lord]; Dilimbabbar[1]DN; hul[rejoice]
#etcsl: line-id=24

25. lugal#-ŋu₁₀ e₂-babbar₂#-še₃ na-ŋen#
#lem: lugal[king]; Ebabbara[1]; ŋen[go]
#etcsl: line-id=25

26. sun₄ [za-gin₃] BA X hul₂-la#-[a]
#lem: sum[beard]; zagin[lapis lazuli]; X; X; hul[rejoice]
#etcsl: line-id=26

27. {d}šul#-gi-re e₂-babbar₂-še₃ na-ŋen#
#lem: Šulgir[1]RN; Ebabbara[1]; ŋen[go]
