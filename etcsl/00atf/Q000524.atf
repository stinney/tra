#lem: gab[left (hand)]; Samsuʾiluna[01]; gub[stand]
#etcsl: line-id=22

23. sila₃ ga kug-sig₁₇ e-ne im-da-e-ne
#lem: sila[unit of capacity]; ga[milk]; kugsig[gold]; ene[pleasure?]; dug[speak]
#etcsl: line-id=23

24. en₃-du %e aŋ₂ %s KA-mu₇-a mu-un-ku₇-ku₇-de₃-ne
#lem: endu[song]; aŋ[thing]N; mu[incantation]; kud[sweet]
#etcsl: line-id=24

25. bal-a-re gu₂-re mu-un-ti-ti-ne
#lem: balare[other side]; gure[that side]; te[pierce]
#etcsl: line-id=25

26. me-en-de₃-en %e ga-ša-an-an-na %s {d}lamma sag₉-ga-me
#lem: menden[we]; Gašanana[1]DN; lammar[(female) tutelary deity]; sag[good]
#etcsl: line-id=26

27. ildum₂ il₂-la sa-am-su-i-lu-na me-en-de₃-en
#lem: ildum[band]; il[raise]; Samsuʾiluna[01]; menden[we]
#etcsl: line-id=27

28. me-en-ze₂-en bal-a-re zi-in-BU-ka-ke₄
#lem: menzen[you (plural)]; balare[other side]; X
#etcsl: line-id=28

29. %e [i]-zi-iŋ₃ aŋ₂ %s KA-mu₇-a la-ba-an-du₇ pi-li-pi-li  %e  da-mu-ra-ab-šid  %s 
#lem: izeŋ[festival]N; aŋ[thing]N; mu[incantation]; du[perfect]; pilipili[cultic performer]; šid[count]
#etcsl: line-id=29

30. šag₄ la₂-la₂ alan nu-un-ki-zil₂-zil₂-i %e nu-ma-al
#lem: šag[heart]; la[hang]; alan[image]; zil[good]; mal[be]V/i
#etcsl: line-id=30

