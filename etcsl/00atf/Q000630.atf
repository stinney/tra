#lem: ud[sun]; zalag[bright]; e[leave]; meʾe[I]
#etcsl: line-id=A.7

8. ka me₃-ka gub-ba-[ŋu₁₀-ne]
#lem: kag[mouth]; me[battle]; gub[stand]
#etcsl: line-id=A.8

9. maš₂-saŋ kur-kur-ra %e me-e %s ši-in-ga#-[ŋen-na]
#lem: mašsaŋ[leader]; kur[mountain(s)]; meʾe[I]IP; me[be]
#etcsl: line-id=A.9

10. murub₂ me₃-ka gub-ba-[ŋu₁₀-ne]
