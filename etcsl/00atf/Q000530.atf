&Q000530 = A prayer for Samsu-iluna (Samsu-iluna G)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.8.3.7
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.8.3.7&display=Crit&charenc=gcirc#

1. {d}en-<ki> {d}a-sa-lim u₃ diŋir-dumu eridug{ki}-ga! {{%akk e₂-a %akk {d}marduk %akk u₃ %akk {d}a-sa-lu-ha}}
#lem: Enkik[1]DN; Asalim[1]DN; u[and]; diŋirdumu[divine son]; Eridug[1]SN; L; L; L; L
#etcsl: line-id=1

2. diŋir gal-gal-e-ne šu-du-um mu-un-na-an-ša#
#lem: diŋir[deity]; gal[big]; šud[prayer]; ša[cvve]
#etcsl: line-id=2

3. {ŋiš}gu-za kug-sig₁₇ nam-lugal saŋ il₅-la {{%akk i-na %akk GU.ZA %akk KUG.SIG₁₇ %akk ša %akk ša-ar-ru-ti-i-ka %akk ša %akk re-ša-ša %akk i-li-a}}
#lem: guza[chair]; kugsig[gold]; namlugal[kingship]; saŋ[head]; il[raise]; L; L; L; L; L; L; L; L
#etcsl: line-id=3

4. šag₄-bi! an!-na nam-ur-saŋ-ŋa₂-ak-ka-ni mah-bi su-uš-a {{%akk a-na %akk i-di %akk qar-ra-du-ti-ka %akk ṣi-ri-iš %akk lu-u₂ %akk wa-aš-ba-a-ti %akk sa-am-su-i-lu-na %akk LUGAL %akk ši-in-nu-u₂}}
#lem: šag[heart]; a[arm]; namursaŋ[heroism]; mah[great]; tuš[sit (down)]; L; L; L; L; L; L; L; L; L
#etcsl: line-id=4

5. lugal urim₂{ki}-ma lugal larsam{ki}-ma
#lem: lugal[king]; Urim[1]SN; lugal[king]; Larsam[1]SN
#etcsl: line-id=5

6. lugal ki-en₆-ŋi₆ ŋi₆-u₂-ri-ke₄
#lem: lugal[king]; Kengir[1]; Akkad[1 Akkad]
#etcsl: line-id=6






