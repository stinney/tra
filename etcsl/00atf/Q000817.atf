#etcsl: line-id=25.5.18

25.5.19. [...] X [...]
#lem: X; X; X
#etcsl: line-id=25.5.19

25.5.20. [...] X [...]
#lem: X; X; X
#etcsl: line-id=25.5.20

@end proverb

@div proverb 25.6

25.6.21. [iri]{[ki]} [nam-uš₂ ŋal₂]-la#-še₃
