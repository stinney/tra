25.7.24. lu₂-lul-la mu-un-gul
#lem: lulul[liar]; gul[destroy]
#etcsl: line-id=25.7.24

@end proverb

@div proverb 25.8

25.8.25. e₂-gal# ki-ma-an-ze-er# ma-an-ze₂-ra#
