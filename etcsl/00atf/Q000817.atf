#etcsl: line-id=25.8.25

#note: = Alster 1997 25.7; cf. 6.1.02.156, 6.1.02.161, 6.1.03.165, 6.1.14.23

25.8.26. e₂!-še₃! ga-ŋen-na ŋiri₃-zu# en-nu-uŋ₃ ak-ab
#lem: e[house]; ŋen[go]; ŋiri[foot]; ennuŋ[watch]; ak[do]
#etcsl: line-id=25.8.26

@end proverb

