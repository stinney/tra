25.12.32. ib₂-ta-e₃ nu-silig-ge
#lem: e[leave]; silig[cease]
#etcsl: line-id=25.12.32

25.12.33. niŋ₂-gur₁₁ lugal-la-ke₄
#lem: niŋgur[property]; lugal[king]
#etcsl: line-id=25.12.33

25.12.34. igi-zu na-an-il₂-en
#lem: igi[eye]; il[raise]
#etcsl: line-id=25.12.34

@end proverb

@div proverb 25.13

25.13.35. lu₂ ma₂ dirig-ga lu₂ ma₂ gaba in-ru-gu₂
#lem: lu[person]; ma[ship]; dirig[make more than]; lu[person]; ma[ship]; gaba[breast]; rugu[withstand]
#etcsl: line-id=25.13.35

#note: cf. 6.1.03.170, 6.1.26.a10, 6.2.5: BM 57994 Seg. A ll. 1-3

25.13.36. niŋ₂ kab₂! di-de₃ niŋ₂-gig {d}suen-na-kam
#lem: niŋ[thing]; kab[test]; di[speak]; niŋgig[evil]; Suen[1]DN
#etcsl: line-id=25.13.36

