@div proverb 25.1

25.1.1. ud šu₂-uš-ru im nu-šeŋ₃-ŋe₂₆
#lem: ud[sun]; šuš[cover]; im[rain]; šeŋ[rain]
#etcsl: line-id=25.1.1

#note: cf. 6.1.03.149, 6.1.14.6, 6.1.15.b5, 6.1.16.c5, 6.1.22: ll. 172-175

25.1.2. im al-šeŋ₃-ŋe₂₆ {kuš}gur₂₁-ra nu-du₈-e
#lem: im[rain]; šeŋ[rain]; guru[shield]; du[spread]
#etcsl: line-id=25.1.2

25.1.3. {id₂}idigna a-u₅-ba ŋal₂-la a-gar₃-ra nu-si-sa₂
#lem: Idigna[1 Tigris]; aʾu[high water]; ŋal[⟦be⟧ to be (there]; agar[meadow]; sisa[straighten]
#etcsl: line-id=25.1.3

25.1.4. peš₁₀ im al-šeŋ₃-ŋe₂₆ bar-rim₄-ma im nu-ba!(ZU)-e
#lem: piš[bank]; im[rain]; šeŋ[rain]; barim[dry land]; im[rain]; ba[allot]
#etcsl: line-id=25.1.4

@end proverb

@div proverb 25.2

25.2.5. en-e ku₆ an-gu₇ ga-raš{sar} mu-un-gu₇
#lem: en[priest]; kud[fish]; gu[eat]; garaš[leek]; gu[eat]
#etcsl: line-id=25.2.5

25.2.6. za₃-hi-li-a{sar} mu-un-da-an-gig
#lem: zahili[plant]; gig[sick]
#etcsl: line-id=25.2.6

#note: cf. 6.1.15.b7

@end proverb

@div proverb 25.3

25.3.7. en-e unug{ki}-ga nam ba-e-kud-de₃
#lem: en[lord]; Unug[1]SN; nam[fate]; kud[cut]
#etcsl: line-id=25.3.7

#note: cf. 6.1.03.59

25.3.8. e-ne-ra nin e₂-an-na-ke₄ nam mu-un-na-kud-de₃
#lem: ane[he]; nin[lady]; Eanak[1]TN; nam[fate]; kud[cut]
#etcsl: line-id=25.3.8

@end proverb

@div proverb 25.4

25.4.9. na-an-ni libir-ra mu-un-kal-la
#lem: Nanni[1]RN; libir[old]; kal[rare]
#etcsl: line-id=25.4.9

#note: cf. 6.1.03.31, 6.1.09.b1, 6.1.11.18, 6.1.15.b8, 6.2.1: Ni 4469 Seg. A ll. 9-12

25.4.10. e₂ {d}en-lil₂-la₂ i-du₃ nu-til₃
#lem: e[house]; Enlil[1]DN; du[build]; til[complete]
#etcsl: line-id=25.4.10

25.4.11. bad₃ nibru{ki} i-du₃ TUG₂ NU MI im-mi-in-DU
#lem: bad[wall]; Nibru[1]SN; du[build]; X; X; X; X
#etcsl: line-id=25.4.11

25.4.12. e₂-an-na i-du₃ mu-un-šub im-ma-an-DU
#lem: Eanak[1]TN; du[build]; šub[fall]; X
#etcsl: line-id=25.4.12

25.4.13. si-mu-ru{ki} i₃-dab₅ gu₂-bi nu-mu-un-da-gid₂-X
#lem: Simurrum[1]SN; dab[seize]; gu[neck]; gid[long]
#etcsl: line-id=25.4.13

25.4.14. nam-lugal-la kalag-ga nu-mu-un-na-an-šum₂
#lem: namlugal[kingship]; kalag[strong]; šum[give]
#etcsl: line-id=25.4.14

25.4.15. ur₅ na-an-ni šag₄ sig-ga kur-še₃ la-ba-an-de₆
#lem: ur[that]; Nanni[1]RN; šag[heart]; sig[weak]; kur[mountain(s)]; de[carry]
#etcsl: line-id=25.4.15

@end proverb

@div proverb 25.5

