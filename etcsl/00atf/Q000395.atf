&Q000395 = A praise poem of Šulgi (Šulgi A)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.4.2.01
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.4.2.01&display=Crit&charenc=gcirc#

1. lugal-me-en šag₄-ta ur-saŋ-me-en
#lem: lugal[king]; šag[heart]; ursaŋ[warrior]
#etcsl: line-id=1

#note: Cited in Ur III catalogue at Yale, 0.1.2, line 30; OB catalogue from Nibru, at Philadelphia, 0.2.01, line 1; OB catalogue from Urim (U2), 0.2.04, line 4; OB catalogue at Andrews University, 0.2.11, line 7; OB catalogue at Yale, 0.2.12, Seg. A, line 1

2. {d}šul-gi-me-en ba-tu-ud-de₃-en-na-ta nitah kalag-ga-me-en
#lem: Šulgir[1]RN; utud[give birth (to)]; nita[male]; kalag[strong]
#etcsl: line-id=2

3. piriŋ igi huš ušumgal-e tud-da-me-en
#lem: piriŋ[lion]; igi[eye]; huš[reddish]; ušumgal[great dragon]; utud[give birth (to)]
#etcsl: line-id=3

4. lugal an ub-da 4-ba-me-en
#lem: lugal[king]; an[sky]; ub[corner]; n
#etcsl: line-id=4

5. na-gada sipad saŋ gig₂-ga-me-en
#lem: nagada[herdsman]; sipad[shepherd]; saŋ[head]; giggig[black]
#etcsl: line-id=5

6. nir-ŋal₂ diŋir kur-kur-ra-me-en
#lem: nirŋal[authoritative]; diŋir[deity]; kur[mountain(s)]
#etcsl: line-id=6

7. dumu u₃-tud-da {d}nin-sumun₂-kam-me-en
#lem: dumu[child]; utud[give birth (to)]; Ninsumunak[1]DN
#etcsl: line-id=7

8. šag₄-ge pad₃-da an kug-ga-me-en
#lem: šag[heart]; pad[find]; An[1]DN; kug[pure]
#etcsl: line-id=8

9. lu₂ nam tar-ra {d}en-lil₂-la₂-me-en
#lem: lu[person]; nam[fate]; tar[cut]; Enlil[1]DN
#etcsl: line-id=9

10. {d}šul-gi ki aŋ₂ {d}nin-lil₂-la₂-me-en
#lem: Šulgir[1]RN; ki[place]; aŋ[measure]; Ninlil[1]DN
#etcsl: line-id=10

11. mi₂ zid dug₄-ga {d}nin-tur₅-ra-me-en
#lem: mi[cvne]; zid[right]; dug[speak]; Nintur[1]DN
#etcsl: line-id=11

12. ŋeštug₂ šum₂-ma {d}en-ki-kam-me-en
#lem: ŋeštug[ear]; šum[give]; Enkik[1]DN
#etcsl: line-id=12

13. lugal kalag-ga {d}nanna-a-me-en
#lem: lugal[king]; kalag[strong]; Nanna[1]DN
#etcsl: line-id=13

14. piriŋ ka du₈-a {d}utu-u₃-me-en
#lem: piriŋ[lion]; kag[mouth]; du[spread]; Utu[1]DN
#etcsl: line-id=14

15. {d}šul-gi hi-li-a pad₃-da {d}inana-me-en
#lem: Šulgir[1]RN; hili[attractiveness]; pad[find]; Inanak[1]DN
#etcsl: line-id=15

16. anše-ŋir₂-nun-na kaskal-e du₇-u₃-me-en
#lem: anšeŋirnun[an equid]; kaskal[way]; du[perfect]
#etcsl: line-id=16

17. anše-kur-ra har-ra-an-na kun sud-sud-me-en
#lem: sisi[horse]; harran[route]; kun[tail]; sud[distant]
#etcsl: line-id=17

18. (1:dur₃ {d}šakkan₂-na kaš₄-e kiŋ₂-ŋa₂-me-en:1)
