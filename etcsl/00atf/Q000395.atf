#lem: inim[word]; niŋerim[evil]; dug[speak]; hulu[bad]; gig[sick]
#etcsl: line-id=25

26. {d}šul-gi-me-en lugal kalag-ga saŋ-bi-še₃ e₃-a-me-en
#lem: Šulgir[1]RN; lugal[king]; kalag[strong]; saŋ[head]; e[leave]
#etcsl: line-id=26

