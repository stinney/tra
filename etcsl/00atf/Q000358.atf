28. ŋen-na {d}utu an-na ga-ba-ni-[re₇]-en-de₃-en#
#lem: ŋen[go]; Utu[1]DN; an[sky]; ere[go (perfect plural stem of ŋen⟦to go⟧)]
#etcsl: line-id=28

29. lu₂ ba-nu₂-a lu₂ ba-nu₂-a u₃-sa₂# ku-ku#-nam
#lem: lu[person]; nud[lie down]; lu[person]; nud[lie down]; usag[sleep]; ku[place]
#etcsl: line-id=29

30. ur-saŋ dumu {d}nin-gal lu₂ ba!-nu₂-a u₃-sa₂ ku-ku-nam
#lem: ursaŋ[warrior]; dumu[child]; Ningal[1]DN; lu[person]; nud[lie down]; usag[sleep]; ku[place]
#etcsl: line-id=30

