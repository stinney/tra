&Q000711 = A hymn to Ninisina (Ninisina D)
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.4.22.4
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.4.22.4&display=Crit&charenc=gcirc#

@div segment A

A.1. nin me mah dib saŋ il₂ ni₂ guru₃ dumu ki aŋ₂ an gal-la
#lem: nin[lady]; me[Being]; mah[great]; dib[pass]; saŋ[head]; il[raise]; ni[fear]; gur[lift]; dumu[child]; ki[place]; aŋ[measure]; An[1]DN; gal[big]
#etcsl: line-id=A.1

A.2. {d}nin-isin₂{si}-na {d}uraš-e tud-da šag₄ gal nam gal DU
#lem: Ninisinak[1]DN; Uraš[1]DN; utud[give birth (to)]; šag[heart]; gal[big]; nam[fate]; gal[big]; X
#etcsl: line-id=A.2

A.3. [ad] gi₄#-gi₄ gal-di a-a ugu-na aŋrig zid e₂-kur-ra
#lem: ad[voice]; gi[turn]; galdi[exalted]; aya[father]; ugu[bear]; agrig[steward]; zid[right]; Ekur[1]TN
#etcsl: line-id=A.3

A.4. [...] eš₂# sig₇-ga barag kug-ge he₂-du₇# X
#lem: X; eš[rope]; sissig[green-yellow]; barag[sanctum]; kug[pure]; hedu[ornament]; X
#etcsl: line-id=A.4

A.5. arhuš₂ tuku X X saŋ gig₂-ga kug {d}nin-isin₂{si}-na niŋ₂-nam-ma-ni pa e₃ [...]
#lem: arhuš[compassion]; tuku[acquire]; X; X; saŋ[head]; giggig[black]; kug[purify]; Ninisinak[1]DN; niŋnam[anything]; pa[branch]; e[leave]; X
#etcsl: line-id=A.5

A.6. nin tug₂ babbar₂ tug₂-ba₁₃ [...] X-ŋu₁₀
#lem: nin[lady]; tug[textile]; babbar[white]; ba[garment]; X; X
#etcsl: line-id=A.6

A.7. nam-gur₄ dirig dug₄-ge [dib]-ba-zu a-ra₂ mah-bi ša-an-i-i
#lem: namgur[thickness]; dirig[make more than]; dug[speak]; dib[pass]; ara[way]; mah[great]; e[bring out]
#etcsl: line-id=A.7

A.8. a-a ugu-zu X X an kug X X me-me dirig-ga za-ar ma-ra-an-ri
#lem: aya[father]; ugu[bear]; X; X; An[1]DN; kug[purify]; X; X; me[Being]; dirig[make more than]; zaʾe[you]; ri[impose]
#etcsl: line-id=A.8

A.9. nin šag₄ šu niŋin₂ X [...] lu₂ X X gi₄ lu₂ dub-ba zi-zi-i šag₄-ta mu-e-de₆
#lem: nin[lady]; šag[heart]; šu[hand]; niŋin[encircle]; X; X; lu[person]; X; X; gi[turn]; lu[person]; dub[heap up]; zig[rise]; šag[heart]; de[carry]
#etcsl: line-id=A.9

A.10. nam-a-zu# lu₂ til₃-le lu₂ X X [...]
#lem: namazu[the craft of the physician]; lu[person]; til[live (of a single person)]; lu[person]; X; X; X
#etcsl: line-id=A.10

A.11. nin tu₆ dug₄-ga-[ni]-ta lu₂ [...] sag₉ [... ...] X X šum₂-mu
#lem: nin[lady]; tu[incantation]; dug[speak]; lu[person]; X; sag[goodness]; X; X; X; X; šum[give]
#etcsl: line-id=A.11

A.12. simₓ(GIG)-simₓ(GIG)-ma su lu₂-ulu₃ he₂-[...] mu₇-mu₇-ga-ni ed₃-de₃
#lem: sim[carbuncle]; su[flesh]; lulu[man]; X; mu[incantation]; ed[go up]
#etcsl: line-id=A.12

A.13. bulug niŋ₂ zi-pa-aŋ₂-[ŋa₂]-na su-a-[na ...]
#lem: bulug[needle]; niŋ[thing]; zipaŋ[breath]; su[flesh]; X
#etcsl: line-id=A.13

A.14. nin u₂ nam-til₃-la X X ab-ba X [...]
#lem: nin[lady]; u[plant(s)]; namtil[life]; X; X; abba[father]; X; X
#etcsl: line-id=A.14

A.15. lu₂ ug₅-ge lu₂ [...]-ba
#lem: lu[person]; ug[kill]; lu[person]; X
#etcsl: line-id=A.15

A.16. {d}nin-til₃-mud X X X lu₂ X [... ...] luh UD dadag-ga
#lem: Nintilmud[1]DN; X; X; X; lu[person]; X; X; X; luh[clean]; X; dadag[bright]
#etcsl: line-id=A.16

A.17. šu zid diŋir-ra-na-še₃ šu X X X [...]
#lem: šu[hand]; zid[right]; diŋir[deity]; šu[hand]; X; X; X; X
#etcsl: line-id=A.17

A.18. [...] X [...] X [...] X [...]
#lem: X; X; X; X; X; X; X
#etcsl: line-id=A.18

$ (approx. 40 lines missing)
@end segment

