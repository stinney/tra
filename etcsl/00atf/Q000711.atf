#lem: luʾerim[evildoer]; X; X
#etcsl: line-id=B.4

B.5. {d}nin-isin₂{si}-na AN X [...] AN [...]
#lem: Ninisinak[1]DN; X; X; X; X; X
#etcsl: line-id=B.5

B.6. e₂-gal-mah barag babbar₂ [...] GAN [...]
#lem: Egalmah[1]TN; barag[sanctum]; babbar[white]; X; X; X
#etcsl: line-id=B.6

B.7. 2-na-ne-ne X [...] X LA₂ [...]
#lem: n; X; X; X; X; X
#etcsl: line-id=B.7

B.8. lugal mu# pad₃ [...]
#lem: lugal[king]; mu[name]; pad[find]; X
#etcsl: line-id=B.8

B.9. {d}nin-isin₂#{[si]}-[na ...]
#lem: Ninisinak[1]DN; X
#etcsl: line-id=B.9

B.10. šag₄-ge guru₇# [...] X RU [...] nu-še-ga
#lem: šag[heart]; guru[grain heap]; X; X; X; X; šeg[agree]
#etcsl: line-id=B.10

B.11. KA nu-ŋar [...] X LA za-ar hu-[...]-X-te-še₃
#lem: X; ŋar[put]; X; X; X; zaʾe[you]; teŋ[approach]
#etcsl: line-id=B.11

B.12. i₃-si-in#{[ki]} X nidba kadra-bi [...] gal-bi
#lem: Isin[1]SN; X; nindaba[(food) offering]; kadra[greeting gift]; X; gal[big]
#etcsl: line-id=B.12

B.13. [...] gu₂-za hu-mu-ra-an-X [...] us₂
#lem: X; gu[neck]; X; X; us[accompany]
#etcsl: line-id=B.13

B.14. [...] nibru{ki}-še₃ za-e kur₉-X-X-ni-ib
#lem: X; Nibru[1]SN; zaʾe[you]; kur[enter]
#etcsl: line-id=B.14

B.15. [...] zid-de₃-eš X X [...]-me-en
#lem: X; zid[right]; X; X; X
#etcsl: line-id=B.15

B.16. [... diŋir]-re-e-ne-ke₄ [...] TE A MU
#lem: X; diŋir[deity]; X; X; X; X
#etcsl: line-id=B.16

B.17. [...] ki [...]-a-ba
#lem: X; ki[place]; X
#etcsl: line-id=B.17

B.18. [...] MU X za-a-am₃
#lem: X; X; X; zaʾe[you]
#etcsl: line-id=B.18

B.19. [...] su-bi
#lem: X; su[flesh]
#etcsl: line-id=B.19

B.20. [...] kar₂ [...]-me-en
#lem: X; kar[blow]; X
#etcsl: line-id=B.20

B.21. {[d]}[nin-isin₂]{si}-na dumu mah an-na [... ...]
#lem: Ninisinak[1]DN; dumu[child]; mah[great]; An[1]DN; X; X
#etcsl: line-id=B.21

B.22. za₃-mi₂-zu dug₃-ga-am₃
#lem: zamin[praise]; dug[good]
#etcsl: line-id=B.22

@end segment






