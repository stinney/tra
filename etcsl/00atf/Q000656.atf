10. ki  %e  {d}mu-ul-lil₂-da  %s  X KU IM DI-en
#lem: ki[place]; Mullil[1]DN; X; X; X; X
#etcsl: line-id=B.10

11. a-a-ŋu₁₀ {d}suen-e šag₄-ge bi₂-in-pad₃-de₃-en
#lem: aya[father]; Suen[1]DN; šag[heart]; pad[find]
#etcsl: line-id=B.11

12. %e ša₃-ab-ŋa₂ %s bi₂-in-pad₃-de₃-en %e me-e %s %e mu-lu %s ša₃-ba-ŋen
#lem: šab[heart]N; pad[find]; meʾe[I]IP; mulu[person]N; šag[heart]
#etcsl: line-id=B.12

13. aga zid men kug saŋ-za %e ma-ra-ni-ma-al
#lem: aga[tiara]; zid[right]; men[tiara]; kug[purify]; saŋ[head]; mal[be]V/i
#etcsl: line-id=B.13

14. %e dim₃-me-er %s gal-gal-e-ne %e i-bi₂-bi %s ša-mu-un-gub-en
#lem: dimmer[deity]N; gal[big]; ibi[eye]N; gub[stand]
#etcsl: line-id=B.14

15. {d}a-nun-na-ke₄-ne %e mu-lu %s dalla bi₂-in-e₃-a
#lem: Anunak[1]DN; mulu[person]N; dalla[(to be) bright]; e[leave]
#etcsl: line-id=B.15

16. %e mu-ud-na-ŋu₁₀ %s gu₂-da ŋa₂-la₂-e-en-de₃-en
#lem: mudna[spouse]N; gu[neck]; la[hang]
#etcsl: line-id=B.16

17. %e mu-nu₂ %s gi-rin-ŋa₂-da %s ga-ba-e-nu₂-en-de₃-en
#lem: munud[bed]N; girim[flower]; nud[lie down]
#etcsl: line-id=B.17

18. {d}ama-ušum-ŋu₁₀ gu₂-da ŋa₂-la₂-e#-[en-de₃-en]
#lem: Amaušum[1]DN; gu[neck]; la[hang]
#etcsl: line-id=B.18

19. %e mu-nud-<<da>> %s gi-rin-ŋa₂-da ga-ba-X-[nu₂-en-de₃-en]
