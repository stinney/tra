#etcsl: line-id=1.B.14

1.B.15. [...] GAR₃ X X UM
#lem: X; X; X; X; X
#etcsl: line-id=1.B.15

1.B.16. [...] X GA-ar
#lem: X; X; X
#etcsl: line-id=1.B.16

1.B.17. [...] X
#lem: X; X
#etcsl: line-id=1.B.17

