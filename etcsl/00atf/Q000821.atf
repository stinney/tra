#etcsl: line-id=1.A.2

1.A.3. šu-ni [...]
#lem: šu[hand]; X
#etcsl: line-id=1.A.3

1.A.4. ki sug₆-ga [...]
#lem: ki[place]; sug[replace]; X
#etcsl: line-id=1.A.4

1.A.5. |MUNUS+X| MU X [...]
#lem: X; X; X; X
#etcsl: line-id=1.A.5

1.A.6. ŋiri₃ niŋ₂-ŋiri₃# [...]
#lem: ŋiri[foot]; niŋŋiri[go-between's fee]; X
#etcsl: line-id=1.A.6

1.A.7. ur-mah [...]
#lem: urmah[lion]; X
#etcsl: line-id=1.A.7

1.A.8. X IGI X [...]
#lem: X; X; X; X
#etcsl: line-id=1.A.8

1.A.9. nu-um-mi-[...]
#lem: X
#etcsl: line-id=1.A.9

1.A.10. dam [...]
#lem: dam[spouse]; X
#etcsl: line-id=1.A.10

1.A.11. X IM# [...]
#lem: X; X; X
#etcsl: line-id=1.A.11

$ (unknown no. of lines missing)
@end segment

@div segment B

1.B.1. X X X X X [...]
#lem: X; X; X; X; X; X
#etcsl: line-id=1.B.1

1.B.2. al-tar-zu gub-[...]
#lem: altar[construction work]; gub[stand]
#etcsl: line-id=1.B.2

1.B.3. e₂ dirig-ga a-šag₄-ga KA [...]
