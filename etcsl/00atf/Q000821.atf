#lem: X; X; du[build]
#etcsl: line-id=1.B.11

1.B.12. e₃ KU GI GAR₃# X X X DU# X X
#lem: e[leave]; X; X; X; X; X; X; X; X; X
#etcsl: line-id=1.B.12

1.B.13. KIŊ₂ DA dam-gara₃# im-us₂
#lem: X; X; damgar[merchant]; us[accompany]
#etcsl: line-id=1.B.13

1.B.14. a e₂-gal-la am₃-e₃ X X
