#lem: en[lord]; ŋeštug[ear]; mah[great]; šu[hand]; du[perfect]; sa[advice]; gal[big]; pad[find]
#etcsl: line-id=A.1

A.2. {d}ha-ia₃ dub gal-gal ha-ha-za ŋeštug₂-ŋeštug₂-ga peš-peš
#lem: Haia[1]DN; dub[tablet]; gal[big]; haza[hold]; ŋeštug[ear]; peš[thick]
#etcsl: line-id=A.2

A.3. šid-du₃ hal-an-kug igi zag til galam-ma-ke₄ e₂-GEŠTUG₂-{d}NISABA-ke₄
#lem: šid[count]; Halankug[1]TN; igi[eye]; zag[side]; til[make complete]; galam[skilful]; E₂.GEŠTUG₂.NISABA.k[1]TN
#etcsl: line-id=A.3

A.4. pisaŋ-dub-ba e₂-gal an ki-a kiŋ₂ kilib-ba šid-šid
#lem: bisaŋdubak[archivist]; egal[palace]; an[sky]; ki[place]; kiŋ[work]; kilib[total]; šid[count]
#etcsl: line-id=A.4

A.5. gi kug-ga šu ŋal₂-le im nam-tar gal-gal mul-mul
#lem: gi[reed]; kug[pure]; šu[hand]; ŋal[⟦be⟧ to be (there]; im[clay]; namtar[fate]; gal[big]; mul[shine]
#etcsl: line-id=A.5

A.6. gal-an-zu inim ŋeštug₂ degₓ(RI)-ge ud-bi-še₃ an kug-ga-ra
#lem: galanzu[wise]; inim[word]; ŋeštug[ear]; deg[gather up]; ud[sun]; An[1]DN; kug[pure]
#etcsl: line-id=A.6

A.7. kišib-ŋal₂ a-a {d}en-lil₂-la₂-ke₄ lu₂ tam-ma e₃ erim₃ e₂-kur-ra
#lem: kišibŋal[seal bearer]; aya[father]; Enlil[1]DN; lu[person]; tam[clean]; e[leave]; erim[storeroom]; Ekur[1]TN
#etcsl: line-id=A.7

A.8. he₂-du₇ eš₃-e abzu-a siki bar-ra la₂-la₂ en {d}nu-dim₂-mud-ra
