&Q000531 = A hymn to Enlil for Samsu-iluna (Samsu-iluna H)
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.8.3.8
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.8.3.8&display=Crit&charenc=gcirc#

1. zi#-na ni-da-ba SI GA X
#lem: zi[life]; nindaba[(food) offering]; X; X; X
#etcsl: line-id=1

2. e₂-kur-še₃ nam-kur₉-u₂
#lem: Ekur[1]TN; kur[enter]
#etcsl: line-id=2

3. e₂-kur-re e₂ {d}en-lil₂-ta
#lem: Ekur[1]TN; e[house]; Enlil[1]DN
#etcsl: line-id=3

4. sa-am-su-i-<lu>-na lugal kalag-ga ni X [...] uŋ₃ ša-ra an-du-ul# {{%akk ša %akk na-am-ri-ru-šu %akk ki-iš-ša-at %akk ni-ši# %akk ka-at-mu}}
#lem: Samsuʾiluna[01]; lugal[king]; kalag[strong]; ni[fear]; X; X; uŋ[people]; šar[numerous]V/i; dul[cover]; L; L; L; L; L
#etcsl: line-id=4

5. U₂ MA AG DU X {d}en#-lil₂# ME AD X {{%akk mu#-uṣ-ṣi₂# %akk [...] %akk [...] %akk ni %akk [...]}}
#lem: X; X; X; X; X; Enlil[1]DN; X; X; X; L; L; L; L; L
#etcsl: line-id=5

6. [...] X X [...]
#lem: X; X; X; X
#etcsl: line-id=6

7. [...] X X [...]
#lem: X; X; X; X
#etcsl: line-id=7

8. [...] X X [...]
#lem: X; X; X; X
#etcsl: line-id=8

9. X MI IR X [...] {{%akk i-na %akk šu-ṣi %akk [...]}}
#lem: X; X; X; X; X; L; L; L
#etcsl: line-id=9

10. kur₂-kur₂ AN RU GU X [...]
#lem: kur[mountain(s)]; X; X; X; X; X
#etcsl: line-id=10

11. ŋar-zu kaš ŋa₂-ŋa₂ X [...] {{%akk ka %akk at %akk te %akk em %akk e %akk mu %akk X %akk [...] %akk ša %akk ŠU.NIGIN %akk ma-at %akk a-a-bi %akk i %akk X %akk [...] %akk na-as₂-pa-at-ta-am %akk i-ša-ka#-[nu]}}
#lem: galanzu[wise]; kaš[decision]; ŋar[put]; X; X; L; L; L; L; L; L; L; L; L; L; L; L; L; L; L; L; L
#etcsl: line-id=11

12. sa-am-su-i-lu-na mu-u₂-a sa₃ nir-ŋal₂# kalam-an-ni {{%akk [sa]-am-su-i-lu-na %akk ŠUL %akk dam-qu %akk e-te-el-lum %akk ša %akk ma-ti-šu}}
#lem: Samsuʾiluna[01]; muʾuʾa[youth]; sag[good]; nirŋal[authoritative]; kalam[the Land (of Sumer)]; L; L; L; L; L; L
#etcsl: line-id=12

13. [sa]-am-su-i-lu-na za₃-am-zu dug₃-ga
#lem: Samsuʾiluna[01]; zamin[praise]; dug[good]
#etcsl: line-id=13






