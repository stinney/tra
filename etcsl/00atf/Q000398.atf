#lem: namursaŋ[heroism]; pa[branch]; e[leave]
#etcsl: line-id=16

17. nam-kalag-ga-zu [mi₂ dug₃ he₂]-e
#lem: namkalag[strength]; mi[cvne]; dug[good]; e[speak]
#etcsl: line-id=17

