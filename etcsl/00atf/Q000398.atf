1. lugal-ŋu₁₀ gud# [gal] a₂ gu₂-nu muš-huš [igi] piriŋ-ŋa₂
#lem: lugal[king]; gud[bull]; gal[big]; a[arm]; gunu[speckled]; mušhuš[monster]; igi[eye]; piriŋ[lion]
#etcsl: line-id=1

2. sipad šul-gi gud gal a₂ gu₂-nu muš-huš igi piriŋ-ŋa₂
#lem: sipad[shepherd]; Šulgir[1]RN; gud[bull]; gal[big]; a[arm]; gunu[speckled]; mušhuš[monster]; igi[eye]; piriŋ[lion]
#etcsl: line-id=2

3. amar tur₃ he₂-ŋal₂-la tud-da gu₂ mar-mar-re di-de₃
#lem: amar[calf]; tur[animal stall]; heŋal[plenty]; utud[give birth (to)]; gu[neck]; mer[cvve]; di[speak]
#etcsl: line-id=3

4. kalag-ga nam-ur-saŋ-ŋa₂ tum₂-ma he₂-du₇ kalam-ma-na
#lem: kalag[strong]; namursaŋ[heroism]; tum[suitable]; hedu[ornament]; kalam[the Land (of Sumer)]
#etcsl: line-id=4

5. nitah zid {d}utu-u₃ niŋ₂-si-sa₂ saŋ-e-eš₂ rig₇-ga
#lem: nita[male]; zid[right]; Utu[1]DN; niŋsisa[justice]; saŋ[head]; rig[donate]
#etcsl: line-id=5

6. nemur₂(|PIRIG.TUR|) ban₃-da ga zid gu₇-a gud a₂ gur₈ piriŋ gal-še₃ tud-da
#lem: nemur[leopard]; banda[junior]; ga[milk]; zid[right]; gu[eat]; gud[bull]; a[arm]; gurum[bend]; piriŋ[lion]; gal[big]; utud[give birth (to)]
#etcsl: line-id=6

7. sun₄ za-gin₃ gaba kug-ga u₆ di
#lem: sum[beard]; zagin[lapis lazuli]; gaba[breast]; kug[pure]; u[admiration]; di[speak]
#etcsl: line-id=7

8. lugal saŋ-men-na hi-li-bi
#lem: lugal[king]; saŋmen[crown]; hili[attractiveness]
#etcsl: line-id=8

9. šul-gi aga zid-da he₂-du₇-bi
#lem: Šulgir[1]RN; aga[tiara]; zid[right]; hedu[ornament]
#etcsl: line-id=9

10. suh-gir₁₁ nam-diŋir-ra tum₂-tum₂
#lem: suhgir[diadem]; namdiŋir[divinity]; tum[carry]
#etcsl: line-id=10

11. lu₂ an-ne₂ mu dug₃-ga sa₄-a
#lem: lu[person]; An[1]DN; mu[name]; dug[good]; še[call by name]
#etcsl: line-id=11

12. sipad zid a₂ šum₂-ma {d}en-lil₂-la₂
#lem: sipad[shepherd]; zid[right]; a[arm]; šum[give]; Enlil[1]DN
#etcsl: line-id=12

13. šul-gi {d}nin-lil₂-la₂ ki aŋ₂ šag₄-ga-na
#lem: Šulgir[1]RN; Ninlil[1]DN; ki[place]; aŋ[measure]; šag[heart]
#etcsl: line-id=13

