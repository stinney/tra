#lem: nin[lady]; me[Being]; nun[prince]; ud[sun]; dalla[(to be) bright]; e[leave]; hili[attractiveness]; zid[right]; ul[distant time]; pad[find]
#etcsl: line-id=A.1

2. {d}na-na-a me-te e₂-an-ka in-nin-ra tum₂-ma
#lem: Nanaya[1]DN; mete[appropriate thing]; Eanak[1]TN; innin[lady]; tum[suitable]
#etcsl: line-id=A.2

3. gal-zu nu-u₈-gig-ge nin kur-kur-ra zid-de₃-eš-še₃ pad₃-da
#lem: galanzu[wise]; nugig[priestess]; nin[lady]; kur[mountain(s)]; zid[right]; pad[find]
#etcsl: line-id=A.3

4. {d}na-na-a kalam e₂-an-ka igi-ŋal₂ šum₂-mu ba-e-zu
#lem: Nanaya[1]DN; kalam[the Land (of Sumer)]; Eanak[1]TN; igiŋal[wise]; šum[give]; zu[know]
#etcsl: line-id=A.4

