#lem: X; X; X; nun[prince]; Šusuen[1]RN; nir[lordly]; ŋal[⟦be⟧ to be (there]
#etcsl: line-id=G.53

54. [...] gu₂-da mu-ni-in-la₂-la₂#
#lem: X; gu[neck]; la[hang]
#etcsl: line-id=G.54

55. [...] X [... ...] kur-kur niŋ₂-daŋal-ba#
#lem: X; X; X; X; kur[mountain(s)]; niŋdaŋala[vastness]
#etcsl: line-id=G.55

56. ŋidru# ud# su₃-ra₂ X X [... ...]
#lem: ŋidru[scepter]; ud[sun]; sud[distant]; X; X; X; X
#etcsl: line-id=G.56

57. uŋ₃ ki-bal-a X [...] BI X
#lem: uŋ[people]; kibala[rebel land]; X; X; X; X
#etcsl: line-id=G.57

58. kilib₃-ba-bi HI [...] |DU.DU|-e
#lem: kilib[total]; X; X; X
#etcsl: line-id=G.58

59. dumu nun zi-le {d}[en-lil₂]-la₂#-še₃
#lem: dumu[child]; nun[prince]; zil[good]; Enlil[1]DN
#etcsl: line-id=G.59

60. {d}šu-{d}suen šu-ni-a [...] mi#-in-si
#lem: Šusuen[1]RN; šu[hand]; X; si[fill]
#etcsl: line-id=G.60

61. lugal-ŋu₁₀ EZEN X-la
#lem: lugal[king]; X; X
#etcsl: line-id=G.61

62. {d}šu-{d}suen giri₁₇-zal X [...] X-ka
#lem: Šusuen[1]RN; kirizal[joy]; X; X; X
#etcsl: line-id=G.62

