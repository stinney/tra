#etcsl: line-id=24.8.12

#note: cf. 6.1.19.c7, 6.1.21.c1, 6.1.23.18

24.8.13. dam dim₄-ma lu₂#-[kam] dumu-nitah# ŋissu lu₂#-[kam]
#lem: dam[spouse]; dim[check]; lu[person]; dumunita[son]; ŋissu[shade]; lu[person]
#etcsl: line-id=24.8.13

24.8.14. dumu-munus saŋ šu ŋar lu₂-kam e₂-gi₄-a gal₅-la₂ lu₂#-[kam]
#lem: dumumunus[daughter]; saŋ[head]; šu[hand]; ŋar[put]; lu[person]; egia[bride]; galla[policeman]; lu[person]
#etcsl: line-id=24.8.14

@end proverb

