#etcsl: line-id=A.18

A.19. šul nun-še₃ il₂-la <{d}i-bi-{d}suen-ŋu₁₀>
#lem: šul[youth]; nun[prince]; il[raise]; Ibbisuen[1]RN
#etcsl: line-id=A.19

A.20. bal su₃-ud nam-he₂-a im-ma-ni-in-pad₃-da
#lem: bala[turn]; sud[distant]; namhe[abundance]; pad[find]
#etcsl: line-id=A.20

A.21. ki nim-ma kur-zag-še₃ gal-bi mu-ni-ib-e₃
