&Q000434 = An adab to Suen for Ibbi-Suen (Ibbi-Suen C)
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.4.5.3
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.4.5.3&display=Crit&charenc=gcirc#

@div sa-gida A

A.1. [...] an ki su₃-ra₂-aŋ₂ bi₂-mu₂-mu₂
#lem: X; an[sky]; ki[place]; sudaŋ[precious metal or material (possibly amber)]; mu[grow]
#etcsl: line-id=A.1

A.2. [... ...] X nun zid ib-ta-e₃-a
#lem: X; X; X; nun[prince]; zid[right]; e[leave]
#etcsl: line-id=A.2

A.3. {[d]}suen# kur gal-e en nun-še₃ tud-da
#lem: Suen[1]DN; kur[mountain(s)]; gal[big]; en[lord]; nun[prince]; utud[give birth (to)]
#etcsl: line-id=A.3

A.4. [...] X X SAR-a X AN DA DI
#lem: X; X; X; X; X; X; X; X
#etcsl: line-id=A.4

A.5. [gaba]-ŋal₂ an ki-<a> lugal-bi na-nam
#lem: gabaŋal[forceful]; an[sky]; ki[place]; lugal[king]; me[be]
#etcsl: line-id=A.5

A.6. en# {d}dil-im₂-babbar su₃-ra₂-aŋ₂ bi₂-mu₂-mu₂
#lem: en[lord]; Dilimbabbar[1]DN; sudaŋ[precious metal or material (possibly amber)]; mu[grow]
#etcsl: line-id=A.6

A.7. {d}suen <su₃-ra₂-aŋ₂ bi₂-mu₂-mu₂>
#lem: Suen[1]DN; sudaŋ[precious metal or material (possibly amber)]; mu[grow]
#etcsl: line-id=A.7

A.8. {d}X <su₃-ra₂-aŋ₂ bi₂-mu₂-mu₂>
#lem: X[1]DN; sudaŋ[precious metal or material (possibly amber)]; mu[grow]
#etcsl: line-id=A.8

A.9. diŋir ud-da <su₃-ra₂-aŋ₂ bi₂-mu₂-mu₂>
#lem: diŋir[deity]; ud[sun]; sudaŋ[precious metal or material (possibly amber)]; mu[grow]
#etcsl: line-id=A.9

A.10. gaba-ŋal₂ an ki-a lugal-bi na#-[nam]
#lem: gabaŋal[forceful]; an[sky]; ki[place]; lugal[king]; me[be]
#etcsl: line-id=A.10

A.11. an sikil-la mu-un-X ki-še₃ pa [am₃]-e₃#
#lem: an[sky]; sikil[pure]; X; ki[place]; pa[branch]; e[leave]
#etcsl: line-id=A.11

A.12. eš-bar an-na-kam sa₂ gal mu-un-ŋa₂-ŋa₂
#lem: ešbar[decision]; An[1]DN; sa[advice]; gal[big]; ŋar[put]
#etcsl: line-id=A.12

A.13. temen si sa₂-a me šar₂ mi-ni-in-ed₂-e
#lem: temen[foundation]; si[horn]; sa[equal]; me[Being]; šar[numerous]V/i; e[leave]
#etcsl: line-id=A.13

A.14. šul nun-še₃ il₂-la {d}i-bi-{d}suen-ŋu₁₀
#lem: šul[youth]; nun[prince]; il[raise]; Ibbisuen[1]RN
#etcsl: line-id=A.14

A.15. bal su₃-ud nam-he₂-a im-ma-ni-in-pad₃-de₃
#lem: bala[turn]; sud[distant]; namhe[abundance]; pad[find]
#etcsl: line-id=A.15

A.16. en {d}dil-im₂-babbar ki-še₃ pa am₃-e₃!(DU)
#lem: en[lord]; Dilimbabbar[1]DN; ki[place]; pa[branch]; e[leave]
#etcsl: line-id=A.16

A.17. eš-bar an-na-kam <sa₂ gal mu-un-ŋa₂-ŋa₂>
#lem: ešbar[decision]; An[1]DN; sa[advice]; gal[big]; ŋar[put]
#etcsl: line-id=A.17

A.18. temen si sa₂-a <me šar₂ mi-ni-in-ed₂-e>
