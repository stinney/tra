A.4. [...] si mu-un-na-sa₂-sa₂-e
#lem: X; si[horn]; sa[equal]
#etcsl: line-id=A.4

A.5. [...] ab₂ lu-a gud-ab₂-bi
#lem: X; ab[cow]; lu[abundant]; gudabak[breed bull]
#etcsl: line-id=A.5

A.6. [...] gu₃ nun mi-ni-ib₂-be₂-ne
#lem: X; gu[voice]; nun[prince]; e[speak]
#etcsl: line-id=A.6

A.7. [...] i₃ ga nunuz mu-un-ak-e
#lem: X; i[oil]; ga[milk]; nunuz[egg]; ak[do]
#etcsl: line-id=A.7

A.8. [...] giri₁₇-zal-la-na šar₂-šar₂-ra-zu
#lem: X; kirizal[joy]; šar[numerous]V/i
#etcsl: line-id=A.8

A.9. [...] DU₈-mu-un nun-a-bi
#lem: X; X; nun[prince]
#etcsl: line-id=A.9

A.10. [...] {d#}suen-ra he₂-ŋal₂ an ki-a
#lem: X; Suen[1]DN; heŋal[plenty]; an[sky]; ki[place]
#etcsl: line-id=A.10

A.11. [...] si# mu-un-sa₂-sa₂-e-ne
#lem: X; si[horn]; sa[equal]
#etcsl: line-id=A.11

A.12. [...] lugal# an kug-ga-še₃ tum₂-ma
#lem: X; lugal[king]; an[sky]; kug[pure]; tum[suitable]
#etcsl: line-id=A.12

A.13. [...] X tum₃ an-šag₄-ga#
#lem: X; X; tum[bring]; anšag[the interior of heaven]
#etcsl: line-id=A.13

