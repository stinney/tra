&Q000578 = Letter from Aba-taḫ-lugalŋa to his brothers
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.3.3.06
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.3.3.06&display=Crit&charenc=gcirc#

1. šeš-ŋu₁₀-ne u₃-na-dug₄
#lem: šeš[brother]; dug[speak]
#etcsl: line-id=1

2. {m}{d}a-ba₄-tah-lugal-ŋa₂-ke₄ na-ab-be₂-a
#lem: Abatahlugalŋak[1]PN; e[speak]
#etcsl: line-id=2

3. al-su₃-ud kaskal i-im-re₇-de₃-en
#lem: sud[distant]; kaskal[way]; ere[go (perfect plural stem of ŋen⟦to go⟧)]
#etcsl: line-id=3

4. u₃ lugal gen₆-na lugal-me ŋiri₃# ba-an-us₂#
#lem: u[and]; lugal[king]; gin[confirm]; lugal[king]; ŋiri[foot]; us[accompany]
#etcsl: line-id=4

5. kaskal-kaskal-e kaskal ba-an-tah
#lem: kaskal[way]; kaskal[way]; tah[add]
#etcsl: line-id=5

6. ama-me en₃ li-bi₂-in-tar-re-de₃-en
#lem: ama[mother]; en[cvne]; tar[cut]
#etcsl: line-id=6

7. dag-gi₄-me ud na#-an-šu₂-uš-a lul-aš
#lem: daggi[city quarter]; ud[sun]; šuš[cover]; lul[false]
#etcsl: line-id=7

8. 1(DIŠ) sila₃ mun 1(DIŠ) sila₃ gazi
#lem: n; sila[unit of capacity]; mun[salt]; n; sila[unit of capacity]; gazi[condiment]
#etcsl: line-id=8

@variants

#note: 1 ms. adds on the lower edge:
8A. [...] UŠ šu-ta e-[...]
#lem: X; X; šu[hand]; X
#etcsl: line-id=8A

@endvariants
9. 1(DIŠ) šag₄-ga-du₃{tug₂}
#lem: n; šagadu[belt]
#etcsl: line-id=9

10. lu₂ du hu-mu-e#-[...]
#lem: lu[person]; ŋen[go]; X
#etcsl: line-id=10

11. kaskal-me al-su₃-ud
#lem: kaskal[way]; sud[distant]
#etcsl: line-id=11

12. a-ma-ru-kam
#lem: amaru[flood]
#etcsl: line-id=12






