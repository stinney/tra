&Q000533 = A praise poem of Abī-Ešuḫ (Abī-Ešuḫ B)
@composite
#project: epsd2/literary
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.8.5.a
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.8.5.a&display=Crit&charenc=gcirc#

@div segment A

1. ud babbar-ta hu-mu-ra-X [...]
#lem: ud[sun]; babbar[white]; X; X
#etcsl: line-id=A.1

2. ud zalag-ga šag₄-zu he₂#-[...]
#lem: ud[sun]; zalag[bright]; šag[heart]; X
#etcsl: line-id=A.2

3. ud zalag-ga ud {d}utu di-kud niŋ₂ X [...]
#lem: ud[sun]; zalag[bright]; ud[sun]; Utu[1]DN; dikud[judge]; niŋ[thing]; X; X
#etcsl: line-id=A.3

4. sag₉-ga niŋ₂-si-a-ni KA-KA X [...]
#lem: sag[good]; niŋsi[provisions]; X; X; X
#etcsl: line-id=A.4

5. ešgiri₂ an-na an ki-bi X [...]
#lem: ešgiri[staff]; An[1]DN; an[sky]; ki[place]; X; X
#etcsl: line-id=A.5

6. [...] X X {d}marduk X [...]
#lem: X; X; X; Marduk[1]DN; X; X
#etcsl: line-id=A.6

$ (approx. 4 lines missing)
@end segment

@div segment B

1. šag₄-ba# [...]
#lem: šag[heart]; X
#etcsl: line-id=B.1

2. bal AN [...]
#lem: bala[turn]; X; X
#etcsl: line-id=B.2

3. nam an-gub-bu# [...]
#lem: nam[fate]; gub[stand]; X
#etcsl: line-id=B.3

4. igi {d}utu {d}nanše X [...]
#lem: igi[eye]; Utu[1]DN; Nanše[1]DN; X; X
#etcsl: line-id=B.4

5. igi a-bi-e-šu-uh# [...]
#lem: igi[eye]; Abiešuh[1]RN; X
#etcsl: line-id=B.5

6. TU-TU-zu e₂ AN X [...]
#lem: X; e[house]; X; X; X
#etcsl: line-id=B.6

7. ki za-ba nam-diŋir-zu [...]
#lem: ki[place]; zaza[bow down]; namdiŋir[divinity]; X
#etcsl: line-id=B.7

8. ŋiš-šub-ba-zu [...]
#lem: ŋeššub[lot]; X
#etcsl: line-id=B.8

9. ŋiš e₂-e ŋiš X [...]
#lem: ŋeš[tree]; e[house]; ŋeš[tree]; X; X
#etcsl: line-id=B.9

10. ud ŋi₆-a X [...]
#lem: ud[sun]; ŋi[night]; X; X
#etcsl: line-id=B.10

11. ka-ta eme-bi [...]
#lem: kag[mouth]; eme[tongue]; X
#etcsl: line-id=B.11

12. diŋir-zu nam-til₃-gin₇# [...]
#lem: diŋir[deity]; namtil[life]; X
#etcsl: line-id=B.12

13. {d}lamma nam-til₃-la [...]
#lem: lammar[(female) tutelary deity]; namtil[life]; X
#etcsl: line-id=B.13

14. nam-til₃-la u₂ šudu₃ A X [...]
#lem: namtil[life]; u[and]; šud[prayer]; X; X; X
#etcsl: line-id=B.14

15. ud re-a mu su₃-ra₂ re-a [...]
#lem: ud[sun]; re[that]; mu[year]; sud[distant]; re[that]; X
#etcsl: line-id=B.15

16. šu kug-ga {d}lamma-ni [...]
#lem: šu[hand]; kug[pure]; lammar[(female) tutelary deity]; X
#etcsl: line-id=B.16

17. {d}nisaba nin!(NIN₉) ereš₂{ki}-ke₄ TUG₂ [...]
#lem: Nisabak[1]DN; nin[lady]; Ereš[1]SN; X; X
#etcsl: line-id=B.17

18. i₃-dub še ŋal₂-la [...]
#lem: idub[granary]; še[barley]; ŋal[⟦be⟧ to be (there]; X
#etcsl: line-id=B.18

19. du-du-e [...]
#lem: du[go]; X
#etcsl: line-id=B.19

20. kaskal har-ra-an-na X [...]
#lem: kaskal[way]; harran[route]; X; X
#etcsl: line-id=B.20

21. dug₄-ga bi₂-in-dug₄-ga a-ra₂-a-ra₂-zu# [...]
#lem: dug[speak]; dug[speak]; ara[way]; X
#etcsl: line-id=B.21

22. lu₂ huŋ munus-šag₄-zu-gin₇ {f}uš-bar X [...]
#lem: lu[person]; huŋ[hire]; šagzu[midwife]; ušbar[weaver]; X; X
#etcsl: line-id=B.22

23. {d}utu-ra bi₂-in-dug₄-ga [...]
#lem: Utu[1]DN; dug[speak]; X
#etcsl: line-id=B.23

24. {d}nanna-ra bi₂-in-dug₄-ga# [...]
#lem: Nanna[1]DN; dug[speak]; X
#etcsl: line-id=B.24

25. e₂ kur₉-ra-ke₄ [...] X-ga-zu# [...]
#lem: e[house]; kur[enter]; X; X; X
#etcsl: line-id=B.25

26. tur-ra gu-la [...]-ga-zu bi₂-in#-[...]
#lem: tur[small]; gal[big]; X; X
#etcsl: line-id=B.26

27. {ŋiš}gu-za tuš-a-ni ŋiš-nu₂-[a nu₂-a-ni]
#lem: guza[chair]; tuš[sit (down)]; ŋešnud[bed]; nud[lie down]
#etcsl: line-id=B.27

28. DI sig₁₀-ge₅ di-di-da [...] X [...]
#lem: X; sig[put into]; di[speak]; X; X; X
#etcsl: line-id=B.28

29. a-ra₂-zu diŋir-zu X [...] X X X [...]
#lem: ara[way]; diŋir[deity]; X; X; X; X; X; X
#etcsl: line-id=B.29

30. mu nam-til₃-la itid silim-ma# ki šag₄ hul₂-la# [...]
#lem: mu[year]; namtil[life]; itud[moon]; silim[healthy]; ki[place]; šag[heart]; hul[rejoice]; X
#etcsl: line-id=B.30

@end segment






