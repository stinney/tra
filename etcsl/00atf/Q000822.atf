@div version 1 (MDP 27 206)

1. KASKAL{mušen} gu₃ de₂!-e {ŋiš}kiri₆! me-ta!-bi-e
#lem: irsaŋ[pigeon]; gu[voice]; de[pour]; kiri[(fruit) plantation]; mete[appropriate thing]
#etcsl: line-id=1.1

#note: cf. 6.1.02.c13, 6.2.3: UET 6/2 244 ll. 1-2, 6.2.3: UET 6/3 80 l. 4

2. bi-za-za-a gu₃ de₂!-e a-ambar-ra-am me-ta-bi-e#
#lem: bizaza[frog]; gu[voice]; de[pour]; aʾambar[marsh water]; mete[appropriate thing]
#etcsl: line-id=1.2

#note: cf. 6.2.3: UET 6/2 244 ll. 5-6, 6.2.3: UET 6/3 80 l. 5

3. dar!{mušen} gu₃ de₂!-[e] a-šag₄-ga me-ta-[bi-e]
#lem: dar[bird]; gu[voice]; de[pour]; ašag[field]; mete[appropriate thing]
#etcsl: line-id=1.3

#note: cf. 6.1.02.c14, 6.2.3: UET 6/2 244 ll. 3-4, 6.2.3: UET 6/3 80 l. 6

@end version

@div version 2 (MDP 27 89)

