&Q000519 = A prayer to Enki for Ḫammu-ràbi (Ḫammu-ràbi B)
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.8.2.2
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.8.2.2&display=Crit&charenc=gcirc#

1. {[d]}lugal-šubur{ki} men# edin-na nam-lugal-la [saŋ-ŋa₂ hu-mu-ra-an-ŋal₂]
#lem: Lugalšubur[1]DN; men[tiara]; eden[back]; namlugal[kingship]; saŋ[head]; ŋal[⟦be⟧ to be (there]
#etcsl: line-id=1

2. {[d]}en-ki-ke₄# [en] nam-til₃-la nam-til₃-la he₂#-[eb-X]
#lem: Enkik[1]DN; en[lord]; namtil[life]; namtil[life]; X
#etcsl: line-id=2

3. e₂-u₆-nir e₂ ŋiš-hur an ki-a me šar₂#-[ra u₅-a]
#lem: Eunir[1]TN; e[house]; ŋešhur[plan]; an[sky]; ki[place]; me[Being]; šar[numerous]V/i; u[ride]
#etcsl: line-id=3

4. suh₁₀ nam-en-na-zu ni₂ [me]-lem₄ ha-ra-dul-e#
#lem: suh[crown]; namen[the office of en-priest]; ni[fear]; melim[frightening splendor]; dul[cover]
#etcsl: line-id=4

5. me nam-lugal-la pa e₃ ha-ra-ab-ak-e
#lem: me[Being]; namlugal[kingship]; pa[branch]; e[leave]; ak[do]
#etcsl: line-id=5

6. ŋiš-hur nam-en-na gi₁₆-sa-še₃ hu-mu-ra-ab-la₂
#lem: ŋešhur[plan]; namen[the office of en-priest]; gilsa[treasure]; la[hang]
#etcsl: line-id=6

7. mu₇-mu₇ nam-til₃-la-kam mi₂ zid hu-mu-ri-in-dug₄ nam su₃-ud-ŋal₂ ha-ra-ab-tah-e
#lem: mu[incantation]; namtil[life]; mi[cvne]; zid[right]; dug[speak]; nam[fate]; sudŋal[long-lasting]; tah[add]
#etcsl: line-id=7

8. mu pad₃-da-ni-gin₇ mu pad₃-da-zu su {d}en-ki-ke₄ ha-ba-ni-dug₃
#lem: mu[name]; pad[find]; mu[name]; pad[find]; su[flesh]; Enkik[1]DN; dug[good]
#etcsl: line-id=8

9. ŋeštug₃ ŋizzal šu zid ha-ra-an-ŋa₂-ŋa₂
#lem: ŋeštug[ear]; ŋizzal[hearing]; šu[hand]; zid[right]; ŋar[put]
#etcsl: line-id=9

10. [niŋ₂] du-ri₂#-še₃ [nu]-ub-kur₂-ru-gin₇ mu nam-lugal-zu
#lem: niŋ[thing]; duri[forever]; kur[different]; mu[name]; namlugal[kingship]
#etcsl: line-id=10

11. a-a {d}en-ki mu nam-til₃-la-zu ha-ba-ni-sud-sud
#lem: aya[father]; Enkik[1]DN; mu[year]; namtil[life]; sud[distant]
#etcsl: line-id=11

12. kur-kur kilib-ba-bi nam-en-bi ha-ra-ab-rig₇-ge
#lem: kur[mountain(s)]; kilib[total]; namen[the office of en-priest]; rig[donate]
#etcsl: line-id=12

13. {[d]}ha-am-mu-ra-bi lugal-ŋu₁₀
#lem: Hammurabi[1]RN; lugal[king]
#etcsl: line-id=13






