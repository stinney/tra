@div version 1 (IM 62823 = TIM 9 18 (Alster 1997 p. 298))

@div segment A

1.A.1. [...] X X ZI
#lem: X; X; X; X
#etcsl: line-id=1.A.1

1.A.2. [...] X-am₃
#lem: X; X
#etcsl: line-id=1.A.2

1.A.3. [...]-am₃
#lem: X
#etcsl: line-id=1.A.3

1.A.4. [...] lu₂ X X-a-kam
#lem: X; lu[person]; X; X
#etcsl: line-id=1.A.4

1.A.5. [...] IG-bi [...] ki
#lem: X; X; X; ki[place]
#etcsl: line-id=1.A.5

1.A.6. [...] X X X [...] X
#lem: X; X; X; X; X; X
#etcsl: line-id=1.A.6

1.A.7. [kug tuku šag₄] an-hul₂# še tuku ur₅ [an]-sag₉
#lem: kug[metal]; tuku[acquire]; šag[heart]; hul[rejoice]; še[barley]; tuku[acquire]; ur[liver]; sag[good]
#etcsl: line-id=1.A.7

#note: cf. 6.1.03.23, 6.1.22: ll. 284-286, 6.2.3: UET 6/2 265 l. 2

1.A.8. [niŋ₂-ur₂-limmu₂ tuku]-e# u₃ nu-un-da-[ku]-ku#
#lem: niŋurlimmu[four legged creature]; tuku[acquire]; u[sleep]; ku[place]
#etcsl: line-id=1.A.8

#note: cf. 6.1.03.23, 6.1.22: ll. 284-286, 6.2.3: UET 6/2 265 l. 3

1.A.9. [ur-saŋ dili na-nam dili]-na# lu₂ šar₂-ra-am₃#
#lem: ursaŋ[warrior]; dili[single]; me[be]; dili[single]; lu[person]; šar[numerous]V/i
#etcsl: line-id=1.A.9

#note: cf. 5.6.1: l. 69

1.A.10. [...] UD ba-X
#lem: X; X; X
#etcsl: line-id=1.A.10

1.A.11. [...] EN# is-hab₂-ba X [...]
#lem: X; X; ishab[rogue]; X; X
#etcsl: line-id=1.A.11

$ (unknown no. of lines missing)
@end segment

@div segment B

1.B.1. [...] X HA GU-bi AN [...]
