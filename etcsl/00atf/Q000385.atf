#lem: en[lord]; Ninŋirsuk[1]DN; igi[eye]; zid[right]; bar[place outside]
#etcsl: line-id=B.27

B.28. [hi-li-a ...] X ZI# [...]
#lem: hili[attractiveness]; X; X; X; X
#etcsl: line-id=B.28

