#etcsl: line-id=B.39

B.40. nin-ŋu₁₀ unken-na igi mi-ni-il₂ la-la mi-ni#-[...]
#lem: nin[lady]; unkin[assembly]; igi[eye]; il[raise]; lala[plenty]; X
#etcsl: line-id=B.40

B.41. lu₂ zid šag₄-ga im-mi-ni-pad₃ sipad zid gu₃-de₂-a
#lem: lu[person]; zid[right]; šag[heart]; pad[find]; sipad[shepherd]; zid[right]; Gudea[1]RN
#etcsl: line-id=B.41

B.42. ama {d}ba-u₂ iri-za lagaš{ki}-a me-teš₂ he₂-e-[i]-i
#lem: ama[mother]; Bau[1]DN; iri[city]; Lagaš[1]SN; meteš[praise]; e[bring out]
#etcsl: line-id=B.42

B.43. {d}ba-u₂ unken-<na igi mi-ni-il₂ la-la mi-ni-X>
