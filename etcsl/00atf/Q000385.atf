&Q000385 = A tigi to Bau for Gudea (Gudea A)
@composite
#project: ucsl/etcsl
#atf: use unicode
#atf: use math
#etcsl: text-id=c.2.3.2
#key: after http://etcsl.orinst.ox.ac.uk/cgi-bin/etcsl.cgi?text=c.2.3.2&display=Crit&charenc=gcirc#

@div sa-gida A

A.1. nin-ŋu₁₀ <munus> sag₉-ga dumu an kug-ga
#lem: nin[lady]; munus[woman]; sag[good]; dumu[child]; An[1]DN; kug[pure]
#etcsl: line-id=A.1

A.2. hi-li du₈-du₈-a ki aŋ₂ {d}en-lil₂-la₂
#lem: hili[attractiveness]; du[spread]; ki[place]; aŋ[measure]; Enlil[1]DN
#etcsl: line-id=A.2

A.3. ni₂ gal gur₃-ru an-šag₄-ta e₃-a
#lem: ni[fear]; gal[big]; gur[lift]; anšag[the interior of heaven]; e[leave]
#etcsl: line-id=A.3

A.4. nin mi₂ dug₄-ga diŋir-re-e-ne
#lem: nin[lady]; mi[cvne]; dug[speak]; diŋir[deity]
#etcsl: line-id=A.4

A.5. {d}ba-u₂ <munus> sag₉-ga <dumu an kug-ga>
#lem: Bau[1]DN; munus[woman]; sag[good]; dumu[child]; An[1]DN; kug[pure]
#etcsl: line-id=A.5

A.6. hi-li du₈-du₈-<a ki aŋ₂ {d}en-lil₂-la₂>
#lem: hili[attractiveness]; du[spread]; ki[place]; aŋ[measure]; Enlil[1]DN
#etcsl: line-id=A.6

A.7. ni₂ gal gur₃-<ru an-šag₄-ta e₃-a>
#lem: ni[fear]; gal[big]; gur[lift]; anšag[the interior of heaven]; e[leave]
#etcsl: line-id=A.7

A.8. nin mi₂ dug₄-ga <diŋir-re-e-ne>
#lem: nin[lady]; mi[cvne]; dug[speak]; diŋir[deity]
#etcsl: line-id=A.8

A.9. nin-ŋu₁₀ an-šag₄-ta me mu-e-de₆
#lem: nin[lady]; anšag[the interior of heaven]; me[Being]; de[carry]
#etcsl: line-id=A.9

A.10. a-a tud-da-zu an lugal-e
#lem: aya[father]; utud[give birth (to)]; An[1]DN; lugal[king]
#etcsl: line-id=A.10

A.11. me niŋ₂ galam saŋ-e-eš mu-ri-in-rig₇
#lem: me[Being]; niŋ[thing]; galam[skilful]; saŋ[head]; rig[donate]
#etcsl: line-id=A.11

A.12. ni₂ guru₃ {d}a-nun-na-ke₄-ne-me-en
#lem: ni[fear]; gur[lift]; Anunak[1]DN
#etcsl: line-id=A.12

A.13. {d}ba-u₂ an-šag₄-ta <me mu-e-de₆>
#lem: Bau[1]DN; anšag[the interior of heaven]; me[Being]; de[carry]
#etcsl: line-id=A.13

A.14. a-a tud-da-zu <an lugal-e>
#lem: aya[father]; utud[give birth (to)]; An[1]DN; lugal[king]
#etcsl: line-id=A.14

A.15. me niŋ₂ galam <saŋ-e-eš mu-ri-in-rig₇>
#lem: me[Being]; niŋ[thing]; galam[skilful]; saŋ[head]; rig[donate]
#etcsl: line-id=A.15

A.16. ni₂ guru₃ {d}a-nun-ke₄-ne-me-en
#lem: ni[fear]; gur[lift]; Anunak[1]DN
#etcsl: line-id=A.16

A.17. sipad unken-na hi-li-a mu-e-ni-pad₃-a
#lem: sipad[shepherd]; unkin[assembly]; hili[attractiveness]; pad[find]
#etcsl: line-id=A.17

A.18. [...] ki mah-a-na mu-ni-zu
#lem: X; ki[place]; mah[great]; zu[know]
#etcsl: line-id=A.18

A.19. [...] mu-na-an-šum₂
#lem: X; šum[give]
#etcsl: line-id=A.19

A.20. [...] X dug₃-ge-eš [...]
#lem: X; X; dug[good]; X
#etcsl: line-id=A.20

A.21. {[d]}[ba-u₂ gu₃-de₂-a unken-na hi-li-a mu-e-ni-pad₃-a]
#lem: Bau[1]DN; Gudea[1]RN; unkin[assembly]; hili[attractiveness]; pad[find]
#etcsl: line-id=A.21

A.22. [... ki mah-a-na mu-ni-zu]
#lem: X; ki[place]; mah[great]; zu[know]
#etcsl: line-id=A.22

A.23. [... mu-na-an-šum₂]
#lem: X; šum[give]
#etcsl: line-id=A.23

A.24. [... dug₃-ge-eš ...]
#lem: X; dug[good]; X
#etcsl: line-id=A.24

@div trailer 

A.25. [sa-gid₂-da-am₃]
#lem: sagida[musical notation]
#etcsl: line-id=A.25

@end trailer

@end sa-gida

@div sa-jara B

B.26. [nin-ŋu₁₀ ni₂ gal guru₃ ...]
#lem: nin[lady]; ni[fear]; gal[big]; gur[lift]; X
#etcsl: line-id=B.26

