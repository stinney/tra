#lem: abzu[(cosmic) underground water]; kituš[dwelling place]; kug[purify]; šul[youth]; Suen[1]DN
#etcsl: line-id=A.11

12. {ŋiš}ešgiri₂ mah an-na saŋ il₂-la u₆ di ki us₂-sa
#lem: ešgiri[staff]; mah[great]; an[sky]; saŋ[head]; il[raise]; u[admiration]; di[speak]; ki[place]; us[accompany]
#etcsl: line-id=A.12

