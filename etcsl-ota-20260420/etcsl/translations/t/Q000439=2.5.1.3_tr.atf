@(12=c2513.B.12) @fsux{Šagbatuku}.

#lg C	barsud


@(13-16=c2513.C.13) Righteous woman who knows well the verdicts of the good decisions of the Land, @wDN{Nanaya}, who is wise in directing the city and the numerous people, exalted woman adept at holy speech, lady fitted for beauty, @wDN{Nanaya}, pride of @wTN{E-ana}, well-spoken one of the Land!

#trailer rubric	barsud


@(17=c2513.C.17) 2nd @fsux{barsud}.

