@(1-5=c131.I.1) @q[Nincubur,Inana]{“@wDN{Inana}, you have brought with you the office of @fsux{en} priest, you have brought with you the office of @fsux{lagar} priest, you have brought with you divinity, you have brought with you the great and good crown, you have brought with you the royal throne.”

@(6-10=c131.I.6) @q[,]{“You have brought with you the noble sceptre, you have brought with you the staff and crook, you have brought with you the noble dress, you have brought with you shepherdship, you have brought with you kingship.”

@(11-15=c131.I.11) @q[,]{“You have brought with you the office of @fsux{egir-zid} priestess, you have brought with you the office of @fsux{nin-diŋir} priestess, you have brought with you the office of @fsux{išib} priest, you have brought with you the office of @fsux{lu-maḫ} priest, you have brought with you the office of @fsux{gudug} priest.”

@(16-21=c131.I.16) @q[,]{“You have brought with you constancy, you have brought with you ……, you have brought with you ……, you have brought with you going down to the underworld, you have brought with you coming up from the underworld, you have brought with you the @fsux{kur-ŋara} priest.”

@(22-27=c131.I.22) @q[,]{“You have brought with you sword and club, you have brought with you the cultic functionary @fsux{saŋ-ursaŋ}, you have brought with you the black garment, you have brought with you the colourful garment, you have brought with you the …… hair-style, you have brought with you the …… hair-style.”

@(28-34=c131.I.28) @q[,]{“You have brought with you ……, you have brought with you ……, you have brought with you ……, you have brought with you ……, you have brought with you ……, you have brought with you ……, you have brought with you …….”

@(35-40=c131.I.35) @q[,]{“You have brought with you the standard, you have brought with you the quiver, you have brought with you sexual intercourse, you have brought with you kissing, you have brought with you prostitution, you have brought with you …… running (?).”

@(41-46=c131.I.41) @q[,]{“You have brought with you forthright speech, you have brought with you deceitful speech, you have brought with you grandiloquent speech, you have brought with you ……, you have brought with you the cultic prostitute, you have brought with you the holy tavern.”

@(47-52=c131.I.47) @q[,]{“You have brought with you the holy @fsux{niŋin-ŋar} shrine, you have brought with you ……, you have brought with you the mistress of heaven, you have brought with you loud musical instruments, you have brought with you the art of song, you have brought with you venerable old age.”

@(53-59=c131.I.53) @q[,]{“You have brought with you heroism, you have brought with you power, you have brought with you wickedness, you have brought with you righteousness, you have brought with you the plundering of cities, you have brought with you making lamentations, you have brought with you rejoicing.”

@(60-64=c131.I.60) @q[,]{“You have brought with you deceit, you have brought with you the rebel lands, you have brought with you kindness, you have brought with you being on the move, you have brought with you being sedentary.”

@(65-72=c131.I.65) @q[,]{“You have brought with you the craft of the carpenter, you have brought with you the craft of the coppersmith, you have brought with you the craft of the scribe, you have brought with you the craft of the smith, you have brought with you the craft of the leather-worker, you have brought with you the craft of the fuller, you have brought with you the craft of the builder, you have brought with you the craft of the reed-worker.”

@(73-81=c131.I.73) @q[,]{“You have brought with you wisdom, you have brought with you attentiveness, you have brought with you holy purification rites, you have brought with you the shepherd's hut, you have brought with you piling up glowing charcoals, you have brought with you the sheepfold, you have brought with you respect, you have brought with you awe, you have brought with you reverent silence.”

@(82-88=c131.I.82) @q[,]{“You have brought with you the bitter-toothed (?) ……, you have brought with you the kindling of fire, you have brought with you the extinguishing of fire, you have brought with you hard work, you have brought with you ……, you have brought with you the assembled family, you have brought with you descendants.”

@(89-94=c131.I.89) @q[,]{“You have brought with you strife, you have brought with you triumph, you have brought with you counselling, you have brought with you comforting, you have brought with you judging, you have brought with you decision-making.”

