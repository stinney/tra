<lg xml:id="t.6.1.01.163" type="proverb" n="1.163"><p xml:id="t6101.p153" n="48" corresp="c6101.D.1.163.48">
<w type="DN">Inana</w> …….</p></lg>
<lg xml:id="t.6.1.01.164" type="proverb" n="1.164"><p xml:id="t6101.p154" n="49-50" corresp="c6101.D.1.164.49">
