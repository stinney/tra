<lg xml:id="t.6.1.01.175" type="proverb" n="1.175"><p xml:id="t6101.p165" n="72-74" corresp="c6101.D.1.175.72">
<note lang="eng">cf. <xref doc="t.6.1.07" from="t.6.1.07.49">6.1.07.49</xref></note>
