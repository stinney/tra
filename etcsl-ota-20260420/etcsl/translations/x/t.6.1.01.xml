<lg xml:id="t.6.1.01.177" type="proverb" n="1.177"><p xml:id="t6101.p167" n="77-78" corresp="c6101.D.1.177.77">
<note lang="eng">cf. <xref doc="t.6.1.07" from="t.6.1.07.53">6.1.07.53</xref></note>
