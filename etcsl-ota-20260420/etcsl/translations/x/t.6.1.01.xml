<lg xml:id="t.6.1.01.176" type="proverb" n="1.176"><p xml:id="t6101.p166" n="75-76" corresp="c6101.D.1.176.75">
<note lang="eng">cf. <xref doc="t.6.1.07" from="t.6.1.07.52">6.1.07.52</xref></note>
